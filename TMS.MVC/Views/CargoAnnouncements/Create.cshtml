@model TMS.MVC.ViewModels.CargoAnnouncementFormViewModel

@{
    ViewData["Title"] = "ثبت اعلام بار";
}

<style>
    .cargo-announcement-form-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .cargo-announcement-form-compact .form-control,
    .cargo-announcement-form-compact .form-select,
    .cargo-announcement-form-compact .input-group-text,
    .cargo-announcement-form-compact .btn,
    .cargo-announcement-form-compact .table,
    .cargo-announcement-form-compact .badge,
    .cargo-announcement-form-compact .form-check-label {
        font-size: 0.82rem;
    }

    .cargo-announcement-form-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .cargo-announcement-form-compact .card-body {
        padding-top: 0.85rem;
    }

    .cargo-announcement-form-compact .small-muted {
        font-size: 0.78rem;
    }

    .cargo-announcement-form-compact .field-validation-valid,
    .cargo-announcement-form-compact .field-validation-error,
    .cargo-announcement-form-compact span.text-danger {
        font-size: 0.75rem;
    }

    .cargo-announcement-form-compact .section-note {
        font-size: 0.78rem;
        color: #6c757d;
    }
</style>

<div class="container-fluid cargo-announcement-form-compact">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">سامانه اعلام بار</a></li>
                    <li class="breadcrumb-item active">ثبت اعلام بار</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid cargo-announcement-form-compact">
    <form asp-action="Create" method="post" id="cargoAnnouncementCreateForm">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

        <div class="alert alert-info py-2 small mb-3">
            این فرم فقط برای اعلام بار مشتری است و مستقیماً حواله ایجاد نمی‌کند. پس از ثبت، اپراتور با شرکت تماس می‌گیرد و در صورت تایید، حواله به‌صورت جداگانه ثبت می‌شود.
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h6 class="mb-0">اطلاعات مشتری و تماس</h6>
                <small class="text-muted small-muted">اطلاعات شرکت یا شخصی که بار را اعلام می‌کند.</small>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="CustomerCompanyName" class="form-label"></label>
                        <input asp-for="CustomerCompanyName" class="form-control form-control-sm" placeholder="مثلاً شرکت نمونه" />
                        <span asp-validation-for="CustomerCompanyName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="ContactPersonName" class="form-label"></label>
                        <input asp-for="ContactPersonName" class="form-control form-control-sm" placeholder="نام شخص رابط" />
                    </div>

                    <div class="col-md-2">
                        <label asp-for="ContactMobile" class="form-label"></label>
                        <input asp-for="ContactMobile" class="form-control form-control-sm" placeholder="09..." />
                        <span asp-validation-for="ContactMobile" class="text-danger small"></span>
                    </div>

                    <div class="col-md-2">
                        <label asp-for="ContactPhone" class="form-label"></label>
                        <input asp-for="ContactPhone" class="form-control form-control-sm" placeholder="تلفن ثابت" />
                    </div>

                    <div class="col-md-3">
                        <label asp-for="ContactEmail" class="form-label"></label>
                        <input asp-for="ContactEmail" class="form-control form-control-sm" placeholder="ایمیل، در صورت وجود" />
                        <span asp-validation-for="ContactEmail" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="AnnouncementType" class="form-label"></label>
                        <input asp-for="AnnouncementType" class="form-control form-control-sm" placeholder="مثلاً حمل داخلی / قراردادی / فوری" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label d-block">&nbsp;</label>
                        <div class="form-check mt-1">
                            <input asp-for="RequiresFleetEntryPermit" class="form-check-input" />
                            <label asp-for="RequiresFleetEntryPermit" class="form-check-label small"></label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h6 class="mb-0">مسیر و زمان‌بندی بارگیری</h6>
                <small class="text-muted small-muted">مبدا، مقصد و بازه زمانی مناسب برای بارگیری.</small>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="OriginPlaceName" class="form-label"></label>
                        <input asp-for="OriginPlaceName" class="form-control form-control-sm" placeholder="مثلاً تهران / پالایشگاه ..." />
                        <span asp-validation-for="OriginPlaceName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="DestinationPlaceName" class="form-label"></label>
                        <input asp-for="DestinationPlaceName" class="form-control form-control-sm" placeholder="مثلاً اصفهان / انبار مقصد ..." />
                        <span asp-validation-for="DestinationPlaceName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-2">
                        <label asp-for="LoadingStartDate" class="form-label"></label>
                        <input type="hidden" asp-for="LoadingStartDate" id="LoadingStartDate" value="@(Model.LoadingStartDate?.ToString("yyyy-MM-dd"))" />
                        <input id="LoadingStartDate_shamsi" class="form-control jalali-date form-control-sm" autocomplete="off" />
                    </div>

                    <div class="col-md-2">
                        <label asp-for="LoadingEndDate" class="form-label"></label>
                        <input type="hidden" asp-for="LoadingEndDate" id="LoadingEndDate" value="@(Model.LoadingEndDate?.ToString("yyyy-MM-dd"))" />
                        <input id="LoadingEndDate_shamsi" class="form-control jalali-date form-control-sm" autocomplete="off" />
                        <span asp-validation-for="LoadingEndDate" class="text-danger small"></span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header">
                <h6 class="mb-0">مشخصات محموله</h6>
                <small class="text-muted small-muted">نوع محصول، مقدار و توضیحات مورد نیاز برای بررسی اپراتور.</small>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="ProductName" class="form-label"></label>
                        <input asp-for="ProductName" class="form-control form-control-sm" placeholder="مثلاً گازوئیل / قیر / محصول ..." />
                        <span asp-validation-for="ProductName" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="ProductAmount" class="form-label"></label>
                        <input asp-for="ProductAmount" class="form-control form-control-sm" type="number" step="0.001" />
                        <span asp-validation-for="ProductAmount" class="text-danger small"></span>
                    </div>

                    <div class="col-md-2">
                        <label asp-for="Unit" class="form-label"></label>
                        <select asp-for="Unit" class="form-select form-select-sm">
                            <option value="کیلوگرم">کیلوگرم</option>
                            <option value="تن">تن</option>
                            <option value="لیتر">لیتر</option>
                        </select>
                        <span asp-validation-for="Unit" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="ShortagePenaltyPerUnit" class="form-label"></label>
                        <div class="input-group input-group-sm">
                            <input asp-for="ShortagePenaltyPerUnit" class="form-control form-control-sm" type="number" step="1" />
                            <span class="input-group-text">ریال</span>
                        </div>
                    </div>

                    <div class="col-12">
                        <label asp-for="CustomerNotes" class="form-label"></label>
                        <textarea asp-for="CustomerNotes" class="form-control form-control-sm" rows="4" placeholder="توضیحات تکمیلی بار، شرایط بارگیری، محدودیت‌ها یا نکات تماس..."></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-3 d-flex justify-content-end gap-2">
            <button type="submit" class="btn btn-primary btn-sm px-3">ثبت اعلام بار</button>
            <a asp-action="Index" class="btn btn-secondary btn-sm px-3">انصراف</a>
        </div>
    </form>
</div>

@section Scripts {
    <link rel="stylesheet" href="~/assets/css/persianDatepicker-default.css">
    <script src="~/assets/js/persianDatepicker.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("cargoAnnouncementCreateForm");
            setupJalaliDateField("LoadingStartDate", "LoadingStartDate_shamsi");
            setupJalaliDateField("LoadingEndDate", "LoadingEndDate_shamsi");

            function setupJalaliDateField(hiddenInputId, shamsiInputId) {
                const hiddenInput = document.getElementById(hiddenInputId);
                const shamsiInput = document.getElementById(shamsiInputId);
                if (!hiddenInput || !shamsiInput) return;

                if (typeof $ !== "undefined" && typeof $(shamsiInput).persianDatepicker === "function") {
                    $(shamsiInput).persianDatepicker({
                        formatDate: "YYYY/0M/0D",
                        autoClose: true,
                        onSelect: function () {
                            syncShamsiToGregorian(hiddenInput, shamsiInput);
                        }
                    });
                }

                if (hiddenInput.value) {
                    const g = normalizeGregorianDate(hiddenInput.value);
                    if (g) {
                        const j = gregorianToJalali(g.y, g.m, g.d);
                        shamsiInput.value = j.y + "/" + pad2(j.m) + "/" + pad2(j.d);
                    }
                }

                shamsiInput.addEventListener("change", function () { syncShamsiToGregorian(hiddenInput, shamsiInput); });
                shamsiInput.addEventListener("blur", function () { syncShamsiToGregorian(hiddenInput, shamsiInput); });
            }

            if (form) {
                form.addEventListener("submit", function () {
                    syncShamsiToGregorian(document.getElementById("LoadingStartDate"), document.getElementById("LoadingStartDate_shamsi"));
                    syncShamsiToGregorian(document.getElementById("LoadingEndDate"), document.getElementById("LoadingEndDate_shamsi"));
                });
            }

            function syncShamsiToGregorian(hiddenInput, shamsiInput) {
                if (!hiddenInput || !shamsiInput) return;

                let value = (shamsiInput.value || "").trim();
                value = toEnglishDigits(value);

                if (!value) {
                    hiddenInput.value = "";
                    return;
                }

                const parts = value.replace(/-/g, "/").split("/");
                if (parts.length !== 3) {
                    hiddenInput.value = "";
                    return;
                }

                const jy = parseInt(parts[0], 10);
                const jm = parseInt(parts[1], 10);
                const jd = parseInt(parts[2], 10);

                if (isNaN(jy) || isNaN(jm) || isNaN(jd)) {
                    hiddenInput.value = "";
                    return;
                }

                const g = jalaliToGregorian(jy, jm, jd);
                hiddenInput.value = g.y + "-" + pad2(g.m) + "-" + pad2(g.d);
            }

            function normalizeGregorianDate(value) {
                if (!value) return null;
                value = toEnglishDigits(value).trim();
                if (value.includes("T")) value = value.split("T")[0];
                const parts = value.split("-");
                if (parts.length !== 3) return null;
                const y = parseInt(parts[0], 10);
                const m = parseInt(parts[1], 10);
                const d = parseInt(parts[2], 10);
                if (isNaN(y) || isNaN(m) || isNaN(d)) return null;
                return { y, m, d };
            }

            function toEnglishDigits(str) {
                if (!str) return str;
                const fa = ['۰','۱','۲','۳','۴','۵','۶','۷','۸','۹'];
                const ar = ['٠','١','٢','٣','٤','٥','٦','٧','٨','٩'];
                for (let i = 0; i < 10; i++) {
                    str = str.replaceAll(fa[i], i.toString());
                    str = str.replaceAll(ar[i], i.toString());
                }
                return str;
            }

            function pad2(n) { return n < 10 ? "0" + n : n.toString(); }

            function gregorianToJalali(gy, gm, gd) {
                var g_d_m, jy, jm, jd, gy2, days;
                g_d_m = [0,31,59,90,120,151,181,212,243,273,304,334];
                gy2 = (gm > 2) ? (gy + 1) : gy;
                days = 355666 + (365 * gy) + Math.floor((gy2 + 3) / 4) - Math.floor((gy2 + 99) / 100) + Math.floor((gy2 + 399) / 400) + gd + g_d_m[gm - 1];
                jy = -1595 + (33 * Math.floor(days / 12053));
                days %= 12053;
                jy += 4 * Math.floor(days / 1461);
                days %= 1461;
                if (days > 365) {
                    jy += Math.floor((days - 1) / 365);
                    days = (days - 1) % 365;
                }
                if (days < 186) {
                    jm = 1 + Math.floor(days / 31);
                    jd = 1 + (days % 31);
                } else {
                    jm = 7 + Math.floor((days - 186) / 30);
                    jd = 1 + ((days - 186) % 30);
                }
                return { y: jy, m: jm, d: jd };
            }

            function jalaliToGregorian(jy, jm, jd) {
                var sal_a, gy, gm, gd, days;
                jy += 1595;
                days = -355668 + (365 * jy) + Math.floor(jy / 33) * 8 + Math.floor(((jy % 33) + 3) / 4) + jd + ((jm < 7) ? (jm - 1) * 31 : ((jm - 7) * 30) + 186);
                gy = 400 * Math.floor(days / 146097);
                days %= 146097;

                if (days > 36524) {
                    gy += 100 * Math.floor(--days / 36524);
                    days %= 36524;
                    if (days >= 365) days++;
                }

                gy += 4 * Math.floor(days / 1461);
                days %= 1461;

                if (days > 365) {
                    gy += Math.floor((days - 1) / 365);
                    days = (days - 1) % 365;
                }

                gd = days + 1;
                sal_a = [0,31,((gy % 4 === 0 && gy % 100 !== 0) || (gy % 400 === 0)) ? 29 : 28,31,30,31,30,31,31,30,31,30,31];
                for (gm = 1; gm <= 12 && gd > sal_a[gm]; gm++) gd -= sal_a[gm];
                return { y: gy, m: gm, d: gd };
            }
        });
    </script>
}
