@using System.Globalization
@model TMS.MVC.ViewModels.ChatViewModel

@{
    ViewData["Title"] = $"گفتگو با راننده";

    string ToJalali(DateTime? date)
    {
        if (!date.HasValue) return "-";
        var pc = new PersianCalendar();
        var d = date.Value;
        return $"{pc.GetYear(d):0000}/{pc.GetMonth(d):00}/{pc.GetDayOfMonth(d):00}";
    }

}

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">داشبورد</li>
                    <li class="breadcrumb-item">حواله ها</li>
                    <li class="breadcrumb-item">جزئیات حمل</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="card shadow-sm border-0">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-2">
                <div class="rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white fw-bold"
                     style="width: 38px; height: 38px; font-size: 0.9rem;">
                    @(Model.DriverName?.Substring(0, 1) ?? "ر")
                </div>
                <div>
                    <strong>گفتگو با @(Model.DriverName ?? "راننده")</strong>
                    <small class="text-muted d-block mt-2" style="font-size: 0.7rem;">@Model.TractorPlateNumber</small>
                </div>
            </div>
            <a asp-controller="TractorAssignment" asp-action="Details" asp-route-id="@Model.AssignmentId"
               class="btn btn-secondary btn-sm">
                بازگشت به جزئیات حمل
            </a>
        </div>

        @* بدنه چت *@
        <div class="card-body p-3" style="background: #f8f9fa;">
            <div id="chatMessages" style="height: 450px; overflow-y: auto;">
                @if (!Model.Messages.Any())
                {
                    <div class="text-center text-muted mt-5 pt-5">
                        <p>هنوز پیامی ارسال نشده است</p>
                    </div>
                }
                else
                {
                    @foreach (var msg in Model.Messages.OrderBy(m => m.SentDate))
                    {
                        var isCurrentUser = User.Identity?.Name == msg.SenderName;
                        var align = isCurrentUser ? "justify-content-start" : "justify-content-end";
                        var bg = isCurrentUser ? "border-primary text-muted" : "border-secondry";
                        var nameColor = isCurrentUser ? "text-muted" : "text-muted";

                        <div class="d-flex @align mb-2" id="msg_@msg.Id">
                            <div class="rounded-3 p-2 @bg" style="max-width: 70%;">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="@nameColor" style="font-size: 0.65rem; direction: ltr; display: inline-block;">
                                            @ToJalali(msg.SentDate) - @msg.SentDate.ToString("HH:mm")
                                        </span>
                                        @if (msg.IsRead && isCurrentUser)
                                        {
                                            <span class="text-success" style="font-size: 0.7rem;">✓✓</span>
                                        }
                                    </div>
                                </div>
                                @if (!string.IsNullOrEmpty(msg.Message))
                                {
                                    <p class="mb-1 mt-1" style="font-size: 0.85rem;">@msg.Message</p>
                                }

                                @if (!string.IsNullOrEmpty(msg.FilePath))
                                {
                                    <a  href="@msg.FilePath" target="_blank" class="d-inline-block mt-1 text-decoration-none">
                                        مشاهده فایل
                                    </a>
                                }
                            </div>
                        </div>
                    }
                }
                <div id="chatEnd"></div>
            </div>
        </div>

        @* فوتر *@
        <div class="card-footer bg-white border-top py-2">
            <form id="sendMessageForm" enctype="multipart/form-data">
                <input type="hidden" id="assignmentId" value="@Model.AssignmentId" />
                <div class="input-group">
                    @* دکمه افزودن فایل *@
                    <label class="btn btn-secondary border-end-0" style="cursor: pointer; margin: 0;">
                        افزودن فایل
                        <input type="file" id="fileInput" hidden />
                    </label>

                    @* فیلد پیام *@
                    <input type="text" id="messageInput" class="form-control border-start-0 border-end-0"
                           placeholder="پیام..." autocomplete="off" />

                    @* دکمه ارسال *@
                    <button type="submit" class="btn btn-primary border-start-0">
                        ارسال
                    </button>
                </div>
            </form>

            @* نام فایل انتخاب شده *@
            <small id="fileInfo" class="text-muted d-none mt-1">فایل انتخاب شده: <span id="fileNameDisplay"></span></small>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var assignmentId = @Model.AssignmentId;
        var lastMessageId = @(Model.Messages.Any() ? Model.Messages.Max(m => m.Id) : 0);
        var currentUserName = '@User.Identity?.Name';

        document.addEventListener("DOMContentLoaded", function () {
            scrollToBottom();
            setInterval(checkNewMessages, 5000);

            document.getElementById("messageInput").addEventListener("keydown", function (e) {
                if (e.key === "Enter" && !e.shiftKey) {
                    e.preventDefault(); sendMessage();
                }
            });
        });

        document.getElementById("sendMessageForm").addEventListener("submit", function (e) {
            e.preventDefault(); sendMessage();
        });

        document.getElementById("fileInput").addEventListener("change", function () {
            var f = this.files[0];
            if (f) {
                document.getElementById("fileNameDisplay").textContent = f.name;
                document.getElementById("fileInfo").classList.remove("d-none");
            }
        });

        function sendMessage() {
            var msg = document.getElementById("messageInput");
            var file = document.getElementById("fileInput");
            var fd = new FormData();
            fd.append("assignmentId", assignmentId);
            fd.append("message", msg.value.trim());
            if (file.files[0]) fd.append("file", file.files[0]);
            if (!msg.value.trim() && !file.files[0]) return;

            msg.value = "";
            file.value = "";
            document.getElementById("fileInfo").classList.add("d-none");
            scrollToBottom();

            fetch("/Chat/SendMessage", { method: "POST", body: fd })
                .then(r => r.json())
                .then(d => { if (d.success) checkNewMessages(); });
        }

        function checkNewMessages() {
            fetch(`/Chat/GetNewMessages?assignmentId=${assignmentId}&lastMessageId=${lastMessageId}`)
                .then(r => r.json())
                .then(messages => {
                    if (messages.length > 0) {
                        var empty = document.querySelector("#chatMessages .text-center.text-muted");
                        if (empty) empty.remove();
                        messages.forEach(function(m) {
                            if (!document.getElementById("msg_" + m.id)) {
                                appendMessage(m);
                                lastMessageId = Math.max(lastMessageId, m.id);
                            }
                        });
                        scrollToBottom();
                    }
                });
        }

        function appendMessage(m) {
            var isMe = m.senderName === currentUserName;
            var bg = isMe ? "bg-primary text-white" : "bg-white";
            var roleBadge = "";
            if (m.senderRole === "Driver") roleBadge = '<span class="badge bg-info ms-1" style="font-size:0.65rem;">راننده</span>';
            else if (m.senderRole === "Admin") roleBadge = '<span class="badge bg-secondary ms-1" style="font-size:0.65rem;">ادمین</span>';
            var tick = (isMe && m.isRead) ? '<span class="ms-1">✓</span>' : "";

            var html = '<div class="d-flex ' + (isMe ? "justify-content-end" : "justify-content-start") + ' mb-2" id="msg_' + m.id + '">';
            html += '<div class="rounded-3 p-2 ' + bg + '" style="max-width:70%;">';
            html += '<small class="d-block ' + (isMe ? "text-white-50" : "text-muted") + '" style="font-size:0.7rem;"><strong>' + m.senderName + '</strong>' + roleBadge + ' - ' + (m.sentDateFormatted || "") + tick + '</small>';
            if (m.message) html += '<p class="mb-1 mt-1" style="font-size:0.85rem;">' + m.message + '</p>';
            if (m.filePath) {
                html += '<a href="' + m.filePath + '" target="_blank" class="d-inline-block mt-1 text-decoration-none" style="font-size:0.8rem;' + (isMe ? "color:rgba(255,255,255,0.9);" : "color:#0d6efd;") + '">مشاهده فایل</a>';
            }
            html += '</div></div>';

            document.getElementById("chatEnd").insertAdjacentHTML("beforebegin", html);
        }

        function scrollToBottom() {
            var d = document.getElementById("chatMessages");
            d.scrollTop = d.scrollHeight;
        }
    </script>
}