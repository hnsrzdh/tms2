@using System.Globalization
@using TMS.MVC.Models
@model TMS.MVC.ViewModels.DriverWalletWithdrawalIndexVm

@{
    ViewData["Title"] = "درخواست‌های برداشت کیف پول رانندگان";

    string ToJalali(DateTime? date)
    {
        if (!date.HasValue) return "-";
        var pc = new PersianCalendar();
        var d = date.Value;
        return $"{pc.GetYear(d):0000}/{pc.GetMonth(d):00}/{pc.GetDayOfMonth(d):00}";
    }

    string Money(decimal? amount) => amount.HasValue ? $"{amount.Value:N0} ریال" : "-";
}

<style>
    .withdrawal-index-compact .form-label { margin-bottom: .25rem; font-size: .82rem; }
    .withdrawal-index-compact .form-control,
    .withdrawal-index-compact .form-select,
    .withdrawal-index-compact .btn,
    .withdrawal-index-compact .table,
    .withdrawal-index-compact .badge { font-size: .82rem; }
    .withdrawal-index-compact .table > :not(caption) > * > * { padding: .45rem .55rem; }
    .withdrawal-index-compact .card-header { padding-top: .65rem; padding-bottom: .65rem; }
    .withdrawal-index-compact .card-body { padding-top: .85rem; }
    .withdrawal-index-compact .pagination .page-link { padding: .22rem .48rem; font-size: .78rem; }
    .withdrawal-index-compact .small-muted { font-size: .78rem; }
    .withdrawal-index-compact .actions-wrap { display: flex; flex-wrap: wrap; gap: .35rem; }
    .withdrawal-index-compact .amount-cell { white-space: nowrap; }
    .withdrawal-index-compact .driver-title { font-weight: 700; color: #343a40; font-size: .82rem; }
    .withdrawal-index-compact .driver-subtitle { display: block; color: #6c757d; font-size: .74rem; margin-top: .1rem; }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li>
                    <li class="breadcrumb-item active">درخواست‌های برداشت</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid withdrawal-index-compact">
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success py-2 small">@TempData["Ok"]</div>
    }
    @if (TempData["Err"] != null)
    {
        <div class="alert alert-danger py-2 small">@TempData["Err"]</div>
    }

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">لیست درخواست‌های برداشت کیف پول</h6>
                <small class="text-muted small-muted">بخش مالی می‌تواند درخواست‌ها را پرداخت یا رد کند. پس از ثبت پرداخت، مبلغ از کیف پول راننده کسر می‌شود.</small>
            </div>
        </div>

        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-2 mb-3">
                <input type="hidden" name="page" value="1" />

                <div class="col-md-6">
                    <label class="form-label">جستجو</label>
                    <input name="search" value="@Model.Search" class="form-control form-control-sm" placeholder="نام راننده، کد ملی، موبایل یا ایمیل..." />
                </div>

                <div class="col-md-3">
                    <label class="form-label">وضعیت</label>
                    <select name="statusFilter" class="form-select form-select-sm">
                        <option value="">همه وضعیت‌ها</option>
                        @foreach (var status in Enum.GetValues<DriverWalletWithdrawalRequestStatus>())
                        {
                            var name = status.ToString();
                            var text = status switch
                            {
                                DriverWalletWithdrawalRequestStatus.Pending => "در انتظار بررسی",
                                DriverWalletWithdrawalRequestStatus.Paid => "پرداخت شده",
                                DriverWalletWithdrawalRequestStatus.Rejected => "رد شده",
                                DriverWalletWithdrawalRequestStatus.Cancelled => "لغو شده",
                                _ => name
                            };
                            if (Model.StatusFilter == name)
                            {
                                <option value="@name" selected>@text</option>
                            }
                            else
                            {
                                <option value="@name">@text</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">تعداد</label>
                    <select name="pageSize" class="form-select form-select-sm">
                        @foreach (var size in new[] { 10, 20, 50, 100 })
                        {
                            if (Model.PageSize == size)
                            {
                                <option value="@size" selected>@size رکورد</option>
                            }
                            else
                            {
                                <option value="@size">@size رکورد</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-1">
                    <label class="form-label d-block">&nbsp;</label>
                    <button type="submit" class="btn btn-info btn-sm w-100">فیلتر</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>راننده</th>
                            <th>موجودی فعلی</th>
                            <th>مبلغ درخواست</th>
                            <th>تاریخ درخواست</th>
                            <th>توضیح درخواست</th>
                            <th>وضعیت</th>
                            <th>اطلاعات پرداخت / رد</th>
                            <th style="width:190px;">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Any())
                        {
                            var rowNo = Model.RowNumberStart;
                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@rowNo</td>
                                    <td>
                                        <span class="driver-title">@item.DriverName</span>
                                        <span class="driver-subtitle">کد ملی: @(item.NationalId ?? "-")</span>
                                        <span class="driver-subtitle">موبایل: @(item.PhoneNumber ?? "-")</span>
                                    </td>
                                    <td class="amount-cell fw-bold text-success">@Money(item.WalletBalance)</td>
                                    <td class="amount-cell fw-bold text-primary">@Money(item.Amount)</td>
                                    <td>@ToJalali(item.CreatedAt)</td>
                                    <td>@(string.IsNullOrWhiteSpace(item.RequestNote) ? "-" : item.RequestNote)</td>
                                    <td><span class="badge @item.StatusBadgeClass">@item.StatusDisplay</span></td>
                                    <td>
                                        @if (item.Status == DriverWalletWithdrawalRequestStatus.Paid)
                                        {
                                            <div><strong>مبلغ:</strong> @Money(item.PaidAmount)</div>
                                            <small class="text-muted">تاریخ: @ToJalali(item.PaidAt)</small>
                                            <br />
                                            <small class="text-muted">رسید: @(item.PaymentReceiptNote ?? "-")</small>
                                        }
                                        else if (item.Status == DriverWalletWithdrawalRequestStatus.Rejected)
                                        {
                                            <small class="text-danger">@(item.RejectionNote ?? "رد شده")</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">-</small>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Status == DriverWalletWithdrawalRequestStatus.Pending)
                                        {
                                            <div class="actions-wrap">
                                                <button type="button" class="btn btn-outline-success btn-sm" data-bs-toggle="modal" data-bs-target="#payModal_@item.Id">پرداخت</button>
                                                <button type="button" class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#rejectModal_@item.Id">رد</button>
                                            </div>

                                            <div class="modal fade" id="payModal_@item.Id" tabindex="-1" aria-hidden="true">
                                                <div class="modal-dialog modal-dialog-centered">
                                                    <div class="modal-content">
                                                        <form asp-action="Pay" method="post">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@item.Id" />

                                                            <div class="modal-header py-2">
                                                                <h6 class="modal-title">ثبت پرداخت برداشت</h6>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                            </div>

                                                            <div class="modal-body small">
                                                                <div class="alert alert-info py-2">
                                                                    <div><strong>راننده:</strong> @item.DriverName</div>
                                                                    <div><strong>موجودی فعلی:</strong> @Money(item.WalletBalance)</div>
                                                                    <div><strong>مبلغ درخواست:</strong> @Money(item.Amount)</div>
                                                                </div>

                                                                <div class="mb-2">
                                                                    <label class="form-label">مبلغ پرداخت</label>
                                                                    <div class="input-group input-group-sm">
                                                                        <input name="paidAmount" class="form-control form-control-sm" type="number" min="1" step="1" value="@item.Amount" />
                                                                        <span class="input-group-text">ریال</span>
                                                                    </div>
                                                                </div>

                                                                <div>
                                                                    <label class="form-label">توضیحات رسید / شماره تراکنش / توضیح پرداخت</label>
                                                                    <textarea name="paymentReceiptNote" class="form-control form-control-sm" rows="4" placeholder="مثلاً شماره پیگیری، بانک، ساعت پرداخت، توضیحات رسید..."></textarea>
                                                                </div>
                                                            </div>

                                                            <div class="modal-footer py-2 gap-2">
                                                                <button type="submit" class="btn btn-success btn-sm px-3">ثبت پرداخت و کسر از کیف پول</button>
                                                                <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">انصراف</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="modal fade" id="rejectModal_@item.Id" tabindex="-1" aria-hidden="true">
                                                <div class="modal-dialog modal-dialog-centered">
                                                    <div class="modal-content">
                                                        <form asp-action="Reject" method="post">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="id" value="@item.Id" />

                                                            <div class="modal-header py-2">
                                                                <h6 class="modal-title">رد درخواست برداشت</h6>
                                                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                            </div>

                                                            <div class="modal-body small">
                                                                <p class="mb-2">آیا این درخواست برداشت رد شود؟</p>
                                                                <label class="form-label">علت رد</label>
                                                                <textarea name="rejectionNote" class="form-control form-control-sm" rows="3"></textarea>
                                                            </div>

                                                            <div class="modal-footer py-2 gap-2">
                                                                <button type="submit" class="btn btn-danger btn-sm px-3">رد درخواست</button>
                                                                <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">انصراف</button>
                                                            </div>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <small class="text-muted">بررسی شده</small>
                                        }
                                    </td>
                                </tr>
                                rowNo++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">درخواست برداشتی یافت نشد.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-2">
                    <div class="text-muted small">صفحه @Model.Page از @Model.TotalPages - تعداد کل: @Model.TotalItems</div>
                    <nav>
                        <ul class="pagination pagination-primary mb-0">
                            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="1" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-statusFilter="@Model.StatusFilter">اول</a>
                            </li>
                            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-statusFilter="@Model.StatusFilter">قبلی</a>
                            </li>
                            @{ var startPage = Math.Max(1, Model.Page - 2); var endPage = Math.Min(Model.TotalPages, Model.Page + 2); }
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")">
                                    <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-statusFilter="@Model.StatusFilter">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-statusFilter="@Model.StatusFilter">بعدی</a>
                            </li>
                            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@Model.TotalPages" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search" asp-route-statusFilter="@Model.StatusFilter">آخر</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>
