@model TMS.MVC.ViewModels.DriverUpsertViewModel

@{
    ViewData["Title"] = "تعریف راننده";
}

<style>
    .driver-form-compact .form-label { margin-bottom: 0.25rem; font-size: 0.82rem; }
    .driver-form-compact .form-control,
    .driver-form-compact .btn,
    .driver-form-compact .table,
    .driver-form-compact .form-check-label { font-size: 0.82rem; }
    .driver-form-compact .field-validation-valid,
    .driver-form-compact .field-validation-error { font-size: 0.75rem; }
    .driver-form-compact .card-header { padding-top: 0.65rem; padding-bottom: 0.65rem; }
    .driver-form-compact .card-body { padding-top: 0.85rem; }
    .driver-form-compact .small-muted { font-size: 0.78rem; }
    .driver-form-compact .form-check { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0; min-height: 31px; }
    .driver-form-compact .form-check-input { margin-top: 0; }
    .driver-form-compact .table > :not(caption) > * > * { padding: 0.45rem 0.55rem; }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">رانندگان</a></li>
                    <li class="breadcrumb-item active">تعریف راننده</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid driver-form-compact">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">تعریف راننده</h6>
                <small class="text-muted small-muted">انتخاب کاربر راننده و ثبت اطلاعات کارت هوشمند و گواهینامه</small>
            </div>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">کاربر راننده</label>
                        <div class="input-group input-group-sm">
                            <input asp-for="ApplicationUserId" type="hidden" />
                            <input asp-for="UserDisplayName" class="form-control" readonly />
                            <button type="button" class="btn btn-outline-secondary" id="openUserModal">انتخاب</button>
                        </div>
                        <span asp-validation-for="ApplicationUserId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="NationalId" class="form-label"></label>
                        <input asp-for="NationalId" class="form-control form-control-sm" />
                        <span asp-validation-for="NationalId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SmartCardNumber" class="form-label"></label>
                        <input asp-for="SmartCardNumber" class="form-control form-control-sm" />
                        <span asp-validation-for="SmartCardNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DrivingLicenseNumber" class="form-label"></label>
                        <input asp-for="DrivingLicenseNumber" class="form-control form-control-sm" />
                        <span asp-validation-for="DrivingLicenseNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label class="form-label d-block">&nbsp;</label>
                        <div class="form-check">
                            <input asp-for="IsBlocked" class="form-check-input" />
                            <label asp-for="IsBlocked" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="col-md-9">
                        <label asp-for="BlockDescription" class="form-label"></label>
                        <textarea asp-for="BlockDescription" class="form-control form-control-sm" rows="3"></textarea>
                        <span asp-validation-for="BlockDescription" class="text-danger"></span>
                    </div>
                </div>

                <hr class="my-3" />

                <div class="d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary btn-sm px-3">ذخیره</button>
                    <a asp-action="Index" class="btn btn-secondary btn-sm px-3">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="userPickerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">انتخاب راننده</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body small">
                <input type="text" id="userSearchInput" class="form-control form-control-sm mb-3" placeholder="جستجو..." />
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle">
                        <thead>
                            <tr>
                                <th>نام</th>
                                <th>ایمیل</th>
                                <th>کد ملی</th>
                                <th style="width:90px">انتخاب</th>
                            </tr>
                        </thead>
                        <tbody id="userSearchResults"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const modal = new bootstrap.Modal(document.getElementById("userPickerModal"));
            const searchInput = document.getElementById("userSearchInput");
            const results = document.getElementById("userSearchResults");

            document.getElementById("openUserModal").addEventListener("click", function () {
                searchInput.value = "";
                results.innerHTML = "";
                modal.show();
                setTimeout(() => searchInput.focus(), 200);
            });

            let timeout;
            searchInput.addEventListener("input", function () {
                clearTimeout(timeout);
                const term = this.value.trim();

                timeout = setTimeout(() => {
                    if (!term) {
                        results.innerHTML = "";
                        return;
                    }

                    fetch(`/Drivers/SearchUsers?term=${encodeURIComponent(term)}`)
                        .then(r => r.json())
                        .then(data => {
                            results.innerHTML = data.map(x => `
                                <tr>
                                    <td>${x.fullName ?? ""}</td>
                                    <td>${x.email ?? ""}</td>
                                    <td>${x.nationalId ?? ""}</td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-sm btn-primary js-select-user"
                                                data-id="${x.applicationUserId}"
                                                data-text="${(x.fullName ?? "")} - ${x.email ?? ""}"
                                                data-national-id="${x.nationalId ?? ""}">
                                            انتخاب
                                        </button>
                                    </td>
                                </tr>
                            `).join("");

                            document.querySelectorAll(".js-select-user").forEach(btn => {
                                btn.addEventListener("click", function () {
                                    document.getElementById("ApplicationUserId").value = this.dataset.id;
                                    document.getElementById("UserDisplayName").value = this.dataset.text;
                                    document.getElementById("NationalId").value = this.dataset.nationalId;
                                    modal.hide();
                                });
                            });
                        });
                }, 300);
            });
        });
    </script>
}
