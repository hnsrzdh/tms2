@using System.Globalization
@using TMS.MVC.Models
@model TMS.MVC.Models.DriverProfile

@{
    ViewData["Title"] = "مشخصات کامل راننده";

    var fullName = Model.ApplicationUser == null
        ? "-"
        : (
            !string.IsNullOrWhiteSpace(((Model.ApplicationUser.FirstName ?? "") + " " + (Model.ApplicationUser.LastName ?? "")).Trim())
                ? ((Model.ApplicationUser.FirstName ?? "") + " " + (Model.ApplicationUser.LastName ?? "")).Trim()
                : (Model.ApplicationUser.Email ?? "-")
          );

    var assignments = ViewBag.Assignments as List<TractorAssignment> ?? new List<TractorAssignment>();
    var walletTransactions = (ViewBag.WalletTransactions as IEnumerable<dynamic> ?? new List<dynamic>()).ToList();

    int totalAssignments = ViewBag.TotalAssignments ?? 0;
    int activeAssignments = ViewBag.ActiveAssignments ?? 0;
    int completedAssignments = ViewBag.CompletedAssignments ?? 0;
    int cancelledAssignments = ViewBag.CancelledAssignments ?? 0;

    decimal totalAssignedAmount = ViewBag.TotalAssignedAmount ?? 0;
    decimal totalLoadedAmount = ViewBag.TotalLoadedAmount ?? 0;
    decimal totalUnloadedAmount = ViewBag.TotalUnloadedAmount ?? 0;
    decimal totalPaidAmount = ViewBag.TotalPaidAmount ?? 0;

    string ToJalali(DateTime? date)
    {
        if (!date.HasValue) return "-";
        var pc = new PersianCalendar();
        var d = date.Value;
        return $"{pc.GetYear(d):0000}/{pc.GetMonth(d):00}/{pc.GetDayOfMonth(d):00}";
    }

    string Amount(decimal? amount, string? unit = null)
    {
        if (!amount.HasValue) return "-";
        return string.IsNullOrWhiteSpace(unit)
            ? amount.Value.ToString("N0")
            : $"{amount.Value:N0} {unit}";
    }

    string ContactText(string? value) => string.IsNullOrWhiteSpace(value) ? "-" : value.Trim();
}

<style>
    .driver-details-compact .form-label { margin-bottom: 0.25rem; font-size: 0.82rem; }
    .driver-details-compact .form-control,
    .driver-details-compact .form-select,
    .driver-details-compact .btn,
    .driver-details-compact .table,
    .driver-details-compact .badge { font-size: 0.82rem; }
    .driver-details-compact .table > :not(caption) > * > * { padding: 0.45rem 0.55rem; }
    .driver-details-compact .card-header { padding-top: 0.65rem; padding-bottom: 0.65rem; }
    .driver-details-compact .card-body { padding-top: 0.85rem; }
    .driver-details-compact .small-muted { font-size: 0.78rem; }
    .driver-details-compact .info-item { font-size: 0.84rem; margin-bottom: 0.45rem; }
    .driver-details-compact .detail-actions { display: flex; flex-wrap: wrap; gap: 0.35rem; }
    .driver-details-compact .summary-box { border: 1px solid #e5e7eb; border-radius: 0.75rem; padding: 0.7rem 0.8rem; background: #f8f9fa; height: 100%; }
    .driver-details-compact .summary-box small { display: block; color: #6c757d; font-size: 0.76rem; margin-bottom: 0.2rem; }
    .driver-details-compact .summary-box .value { display: block; font-size: 0.95rem; font-weight: 700; color: #343a40; }
    .driver-details-compact .wallet-balance-box { border: 1px solid rgba(25, 135, 84, 0.25); background: rgba(25, 135, 84, 0.06); }
    .driver-details-compact .wallet-balance-box .value { color: #198754; font-size: 1.15rem; }
    .driver-details-compact .amount-cell { white-space: nowrap; }
    
    .modern-contact-table th,
    .modern-contact-table td {
        vertical-align: middle;
    }

</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">رانندگان</a></li>
                    <li class="breadcrumb-item active">جزئیات</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid driver-details-compact">
    @if (TempData["Ok"] != null) { <div class="alert alert-success py-2 small">@TempData["Ok"]</div> }
    @if (TempData["Err"] != null) { <div class="alert alert-danger py-2 small">@TempData["Err"]</div> }

    <div class="row g-2 mb-3">
        <div class="col-md-3"><div class="summary-box"><small>وضعیت راننده</small><span class="value @(Model.IsBlocked ? "text-danger" : "text-success")">@(Model.IsBlocked ? "محدود" : "فعال")</span></div></div>
        <div class="col-md-3"><div class="summary-box wallet-balance-box"><small>موجودی کیف پول</small><span class="value">@Amount(Model.WalletBalance, "ریال")</span></div></div>
        <div class="col-md-3"><div class="summary-box"><small>کل تخصیص‌ها</small><span class="value">@totalAssignments</span></div></div>
        <div class="col-md-3"><div class="summary-box"><small>مبلغ واریزشده به کیف پول</small><span class="value text-success">@Amount(totalPaidAmount, "ریال")</span></div></div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div><h6 class="mb-0">اطلاعات کلی</h6><small class="text-muted small-muted">اطلاعات هویتی و وضعیت راننده</small></div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="DriverWalletWithdrawalRequests" asp-action="Create" asp-route-driverProfileId="@Model.Id" class="btn btn-outline-success btn-sm px-3">درخواست برداشت از کیف پول</a>
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm px-3">ویرایش</a>
                <a asp-action="Index" class="btn btn-secondary btn-sm px-3">بازگشت</a>
            </div>
        </div>
        <div class="card-body row">
            <div class="col-md-4 info-item"><strong>نام راننده:</strong> @fullName</div>
            <div class="col-md-4 info-item"><strong>کد ملی:</strong> @(Model.ApplicationUser?.NationalId ?? "-")</div>
            <div class="col-md-4 info-item"><strong>ایمیل:</strong> @(Model.ApplicationUser?.Email ?? "-")</div>
            <div class="col-md-4 info-item"><strong>شماره موبایل:</strong> @(Model.ApplicationUser?.PhoneNumber ?? "-")</div>
            <div class="col-md-4 info-item"><strong>شماره کارت هوشمند:</strong> @(Model.SmartCardNumber ?? "-")</div>
            <div class="col-md-4 info-item"><strong>شماره گواهینامه:</strong> @(Model.DrivingLicenseNumber ?? "-")</div>
            <div class="col-md-12 info-item"><strong>توضیحات محدودیت:</strong> @(string.IsNullOrWhiteSpace(Model.BlockDescription) ? "-" : Model.BlockDescription)</div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><h6 class="mb-0">خلاصه فعالیت راننده</h6><small class="text-muted small-muted">خلاصه وضعیت حمل‌ها، مقدار بار و عملکرد کلی راننده</small></div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-3"><div class="summary-box"><small>حمل‌های فعال</small><span class="value text-primary">@activeAssignments</span></div></div>
                <div class="col-md-3"><div class="summary-box"><small>حمل‌های تکمیل / تخلیه شده</small><span class="value text-success">@completedAssignments</span></div></div>
                <div class="col-md-3"><div class="summary-box"><small>حمل‌های لغو شده</small><span class="value text-danger">@cancelledAssignments</span></div></div>
                <div class="col-md-3"><div class="summary-box"><small>جمع مقدار تخصیص</small><span class="value">@Amount(totalAssignedAmount)</span></div></div>
                <div class="col-md-3"><div class="summary-box"><small>جمع مقدار بارگیری</small><span class="value">@Amount(totalLoadedAmount)</span></div></div>
                <div class="col-md-3"><div class="summary-box"><small>جمع مقدار تخلیه</small><span class="value">@Amount(totalUnloadedAmount)</span></div></div>
            </div>
        </div>
    </div>

    
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">راه‌های ارتباطی</h6>
                <small class="text-muted small-muted">شماره‌های جداگانه پیامک، واتساپ، فکس، تلفن و ایمیل</small>
            </div>
            <a asp-action="AddContact" asp-route-driverProfileId="@Model.Id" class="btn btn-primary btn-sm px-3">افزودن</a>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-hover table-sm align-middle modern-contact-table">
                <thead>
                    <tr>
                        <th>عنوان</th>
                        <th>پیامک</th>
                        <th>واتساپ</th>
                        <th>فکس</th>
                        <th>تلفن</th>
                        <th>ایمیل</th>
                        <th style="width:145px">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Contacts.Any())
                    {
                        foreach (var item in Model.Contacts.OrderBy(x => x.Id))
                        {
                            <tr>
                                <td>@(item.Title ?? "-")</td>
                                <td><span class=" @(string.IsNullOrWhiteSpace(item.SmsNumber) ? "empty" : "")">@ContactText(item.SmsNumber)</span></td>
                                <td><span class=" @(string.IsNullOrWhiteSpace(item.WhatsAppNumber) ? "empty" : "")">@ContactText(item.WhatsAppNumber)</span></td>
                                <td><span class=" @(string.IsNullOrWhiteSpace(item.FaxNumber) ? "empty" : "")">@ContactText(item.FaxNumber)</span></td>
                                <td><span class=" @(string.IsNullOrWhiteSpace(item.PhoneNumber) ? "empty" : "")">@ContactText(item.PhoneNumber)</span></td>
                                <td><span class=" @(string.IsNullOrWhiteSpace(item.EmailAddress) ? "empty" : "")">@ContactText(item.EmailAddress)</span></td>
                                <td>
                                    <div class="detail-actions">
                                        <a asp-action="EditContact" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                        <form asp-action="DeleteContact" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="driverProfileId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">موردی ثبت نشده است.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>


    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2"><div><h6 class="mb-0">آدرس‌ها</h6><small class="text-muted small-muted">آدرس‌های ثبت‌شده</small></div><a asp-action="AddAddress" asp-route-driverProfileId="@Model.Id" class="btn btn-primary btn-sm px-3">افزودن</a></div>
        <div class="card-body table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead><tr><th>عنوان</th><th>آدرس</th><th style="width:145px">عملیات</th></tr></thead>
                <tbody>
                    @if (Model.Addresses.Any())
                    {
                        foreach (var item in Model.Addresses.OrderBy(x => x.Id))
                        {
                            <tr>
                                <td>@(item.Title ?? "-")</td><td>@(item.AddressText ?? "-")</td>
                                <td><div class="detail-actions"><a asp-action="EditAddress" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a><form asp-action="DeleteAddress" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><input type="hidden" name="driverProfileId" value="@Model.Id" /><button type="submit" class="btn btn-sm btn-outline-danger">حذف</button></form></div></td>
                            </tr>
                        }
                    }
                    else { <tr><td colspan="3" class="text-center text-muted py-4">موردی ثبت نشده است.</td></tr> }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2"><div><h6 class="mb-0">حساب‌های بانکی</h6><small class="text-muted small-muted">لیست حساب‌ها و شماره‌های بانکی</small></div><a asp-action="AddBankAccount" asp-route-driverProfileId="@Model.Id" class="btn btn-primary btn-sm px-3">افزودن</a></div>
        <div class="card-body table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead><tr><th>نام صاحب حساب</th><th>نام بانک</th><th>شماره حساب</th><th>شماره کارت</th><th>شماره شبا</th><th>پیش فرض</th><th>توضیحات</th><th style="width:145px">عملیات</th></tr></thead>
                <tbody>
                    @if (Model.BankAccounts.Any())
                    {
                        foreach (var item in Model.BankAccounts.OrderByDescending(x => x.IsDefault).ThenBy(x => x.Id))
                        {
                            <tr>
                                <td>@(item.AccountOwnerName ?? "-")</td><td>@(item.BankName ?? "-")</td><td>@(item.AccountNumber ?? "-")</td><td>@(item.CardNumber ?? "-")</td><td>@(item.ShebaNumber ?? "-")</td><td>@(item.IsDefault ? "بله" : "-")</td><td>@(item.Description ?? "-")</td>
                                <td><div class="detail-actions"><a asp-action="EditBankAccount" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a><form asp-action="DeleteBankAccount" method="post">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@item.Id" /><input type="hidden" name="driverProfileId" value="@Model.Id" /><button type="submit" class="btn btn-sm btn-outline-danger">حذف</button></form></div></td>
                            </tr>
                        }
                    }
                    else { <tr><td colspan="8" class="text-center text-muted py-4">موردی ثبت نشده است.</td></tr> }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header"><h6 class="mb-0">تراکنش‌های کیف پول</h6><small class="text-muted small-muted">آخرین تراکنش‌های کیف پول</small></div>
        <div class="card-body table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead><tr><th>#</th><th>تاریخ</th><th>نوع تراکنش</th><th>مبلغ</th><th>شرح</th></tr></thead>
                <tbody>
                    @if (walletTransactions.Any())
                    {
                        var rowNo = 1;
                        foreach (var item in walletTransactions.Take(20))
                        {
                            decimal? amount = item.Amount;
                            <tr><td>@rowNo</td><td>@ToJalali(item.Date)</td><td>@(item.Type ?? "-")</td><td class="amount-cell">@(amount.HasValue ? $"{amount.Value:N0} ریال" : "-")</td><td>@(item.Description ?? "-")</td></tr>
                            rowNo++;
                        }
                    }
                    else { <tr><td colspan="5" class="text-center text-muted py-4">تراکنشی ثبت نشده است.</td></tr> }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><h6 class="mb-0">تخصیص‌ها</h6><small class="text-muted small-muted">آخرین تخصیص‌های ثبت‌شده</small></div>
        <div class="card-body table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead><tr><th>#</th><th>حواله</th><th>ریزحواله</th><th>کشنده</th><th>تاریخ تخصیص</th><th>تخصیص</th><th>بارگیری</th><th>تخلیه</th><th>وضعیت</th><th style="width:105px;">عملیات</th></tr></thead>
                <tbody>
                    @if (assignments.Any())
                    {
                        var rowNo = 1;
                        foreach (var item in assignments.OrderByDescending(x => x.AssignmentDate).Take(20))
                        {
                            var unit = item.SubHavaleh?.Havaleh?.Unit;
                            <tr><td>@rowNo</td><td>@(item.SubHavaleh?.Havaleh?.HavalehNumber ?? "-")</td><td>@(item.SubHavaleh?.Title ?? "-")</td><td>@(item.Tractor?.PolicePlateNumber ?? "-")</td><td>@ToJalali(item.AssignmentDate)</td><td class="amount-cell">@Amount(item.AssignedCargoAmount, unit)</td><td class="amount-cell">@Amount(item.LoadedAmount, unit)</td><td class="amount-cell">@Amount(item.UnloadedAmount, unit)</td><td>@item.Status</td><td><a asp-controller="TractorAssignment" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">جزئیات</a></td></tr>
                            rowNo++;
                        }
                    }
                    else { <tr><td colspan="10" class="text-center text-muted py-4">تخصیصی ثبت نشده است.</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
