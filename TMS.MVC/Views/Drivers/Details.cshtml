    <!-- حساب‌های بانکی -->
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">حساب‌های بانکی</h6>
                <small class="text-muted small-muted">لیست حساب‌ها و شماره‌های بانکی راننده</small>
            </div>
            <a asp-action="AddBankAccount" asp-route-driverProfileId="@Model.Id" class="btn btn-primary btn-sm px-3">افزودن</a>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead>
                    <tr>
                        <th>نام صاحب حساب</th>
                        <th>نام بانک</th>
                        <th>شماره حساب</th>
                        <th>شماره کارت</th>
                        <th>شماره شبا</th>
                        <th>پیش فرض</th>
                        <th>توضیحات</th>
                        <th style="width:145px">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (bankAccounts.Any())
                    {
                        foreach (var item in bankAccounts)
                        {
                            <tr>
                                <td>@(item.AccountOwnerName ?? "-")</td>
                                <td>@(item.BankName ?? "-")</td>
                                <td>@(item.AccountNumber ?? "-")</td>
                                <td>@(item.CardNumber ?? "-")</td>
                                <td>@(item.ShebaNumber ?? "-")</td>
                                <td class="text-center">
                                    @if (item.IsDefault)
                                    {
                                        <span class="badge bg-success">بله</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>@(item.Description ?? "-")</td>
                                <td>
                                    <div class="detail-actions">
                                        <a asp-action="EditBankAccount" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                        <form asp-action="DeleteBankAccount" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="driverProfileId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">موردی ثبت نشده است.</td></tr>
                    }
                </tbody>
            </table>

            @if (bankTotalItems > bankPageSize)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-2">
                    <div class="text-muted small">صفحه @bankPage از @bankTotalPages - تعداد کل: @bankTotalItems</div>
                    <nav>
                        <ul class="pagination pagination-primary mb-0">
                            <li class="page-item @(bankPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="1" asp-route-bankPageSize="@bankPageSize" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@assignmentPage">اول</a>
                            </li>
                            <li class="page-item @(bankPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@(bankPage - 1)" asp-route-bankPageSize="@bankPageSize" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@assignmentPage">قبلی</a>
                            </li>
                            @{
                                var bankStart = Math.Max(1, bankPage - 2);
                                var bankEnd = Math.Min(bankTotalPages, bankPage + 2);
                            }
                            @for (int i = bankStart; i <= bankEnd; i++)
                            {
                                <li class="page-item @(i == bankPage ? "active" : "")">
                                    <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@i" asp-route-bankPageSize="@bankPageSize" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@assignmentPage">@i</a>
                                </li>
                            }
                            <li class="page-item @(bankPage >= bankTotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@(bankPage + 1)" asp-route-bankPageSize="@bankPageSize" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@assignmentPage">بعدی</a>
                            </li>
                            <li class="page-item @(bankPage >= bankTotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@bankTotalPages" asp-route-bankPageSize="@bankPageSize" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@assignmentPage">آخر</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>

    <!-- تراکنش‌های کیف پول -->
    <div class="card mb-3">
        <div class="card-header">
            <h6 class="mb-0">تراکنش‌های کیف پول</h6>
            <small class="text-muted small-muted">واریزها و برداشت‌های کیف پول راننده</small>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>تاریخ</th>
                        <th>نوع تراکنش</th>
                        <th>مبلغ</th>
                        <th>شرح</th>
                        <th style="width:120px;">ارجاع</th>
                    </tr>
                </thead>
                <tbody>
                    @if (walletItems.Any())
                    {
                        var rowNo = ((walletPage - 1) * walletPageSize) + 1;
                        foreach (var item in walletItems)
                        {
                            <tr>
                                <td>@rowNo</td>
                                <td>@ToJalali(item.Date)</td>
                                <td><span class="badge bg-success">@item.Type</span></td>
                                <td class="amount-cell fw-bold text-success">@Amount(item.Amount, "ریال")</td>
                                <td>@item.Description</td>
                                <td>
                                    <a asp-controller="TractorAssignment"
                                       asp-action="Details"
                                       asp-route-id="@item.ReferenceId"
                                       class="btn btn-outline-info btn-sm">
                                        جزئیات
                                    </a>
                                </td>
                            </tr>
                            rowNo++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                تراکنشی برای کیف پول این راننده ثبت نشده است.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (walletTotalItems > walletPageSize)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-2">
                    <div class="text-muted small">صفحه @walletPage از @walletTotalPages - تعداد کل: @walletTotalItems</div>
                    <nav>
                        <ul class="pagination pagination-primary mb-0">
                            <li class="page-item @(walletPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@bankPage" asp-route-walletPage="1" asp-route-walletPageSize="@walletPageSize" asp-route-assignmentPage="@assignmentPage">اول</a>
                            </li>
                            <li class="page-item @(walletPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@bankPage" asp-route-walletPage="@(walletPage - 1)" asp-route-walletPageSize="@walletPageSize" asp-route-assignmentPage="@assignmentPage">قبلی</a>
                            </li>
                            @{
                                var walletStart = Math.Max(1, walletPage - 2);
                                var walletEnd = Math.Min(walletTotalPages, walletPage + 2);
                            }
                            @for (int i = walletStart; i <= walletEnd; i++)
                            {
                                <li class="page-item @(i == walletPage ? "active" : "")">
                                    <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@bankPage" asp-route-walletPage="@i" asp-route-walletPageSize="@walletPageSize" asp-route-assignmentPage="@assignmentPage">@i</a>
                                </li>
                            }
                            <li class="page-item @(walletPage >= walletTotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@bankPage" asp-route-walletPage="@(walletPage + 1)" asp-route-walletPageSize="@walletPageSize" asp-route-assignmentPage="@assignmentPage">بعدی</a>
                            </li>
                            <li class="page-item @(walletPage >= walletTotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@bankPage" asp-route-walletPage="@walletTotalPages" asp-route-walletPageSize="@walletPageSize" asp-route-assignmentPage="@assignmentPage">آخر</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }

            <div class="alert alert-info py-2 small mb-0 mt-2">
                برداشت از کیف پول زمانی نمایش داده می‌شود که برای کیف پول جدول تراکنش مستقل یا عملیات برداشت تعریف شود. در وضعیت فعلی، واریزهای ناشی از تسویه حمل نمایش داده می‌شوند.
            </div>
        </div>
    </div>

    <!-- تخصیص‌های راننده -->
    <div class="card">
        <div class="card-header">
            <h6 class="mb-0">تخصیص‌های راننده</h6>
            <small class="text-muted small-muted">تمام تخصیص‌هایی که این راننده در آن‌ها ثبت شده است</small>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>حواله</th>
                        <th>ریزحواله</th>
                        <th>کشنده</th>
                        <th>مسیر</th>
                        <th>تاریخ تخصیص</th>
                        <th>تخصیص</th>
                        <th>بارگیری</th>
                        <th>تخلیه</th>
                        <th>وضعیت</th>
                        <th style="width:105px;">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (assignmentItems.Any())
                    {
                        var rowNo = ((assignmentPage - 1) * assignmentPageSize) + 1;
                        foreach (var item in assignmentItems)
                        {
                            var unit = item.SubHavaleh?.Havaleh?.Unit;
                            <tr>
                                <td>@rowNo</td>
                                <td>@(item.SubHavaleh?.Havaleh?.HavalehNumber ?? "-")</td>
                                <td>@(item.SubHavaleh?.Title ?? "-")</td>
                                <td>@(item.Tractor?.PolicePlateNumber ?? "-")</td>

                                <td>
                                    <div class="route-mini">
                                        <div class="route-point route-origin">
                                            <span class="route-dot"></span>
                                            <div>
                                                <span class="route-label">مبدا</span>
                                                <strong>@(item.SubHavaleh?.Havaleh?.OriginPlace?.Name ?? "-")</strong>
                                            </div>
                                        </div>

                                        <div class="route-line"></div>

                                        <div class="route-point route-destination">
                                            <span class="route-dot"></span>
                                            <div>
                                                <span class="route-label">مقصد</span>
                                                <strong>@(item.SubHavaleh?.DestinationPlace?.Name ?? "-")</strong>
                                            </div>
                                        </div>
                                    </div>
                                </td>

                                <td>@ToJalali(item.AssignmentDate)</td>
                                <td class="amount-cell">@Amount(item.AssignedCargoAmount, unit)</td>
                                <td class="amount-cell">@Amount(item.LoadedAmount, unit)</td>
                                <td class="amount-cell">@Amount(item.UnloadedAmount, unit)</td>
                                <td>
                                    <span class="badge @StatusBadge(item.Status)">
                                        @StatusText(item.Status)
                                    </span>
                                </td>
                                <td>
                                    <a asp-controller="TractorAssignment"
                                       asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-outline-info btn-sm">
                                        جزئیات
                                    </a>
                                </td>
                            </tr>
                            rowNo++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11" class="text-center text-muted py-4">
                                تخصیصی برای این راننده ثبت نشده است.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (assignmentTotalItems > assignmentPageSize)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-2">
                    <div class="text-muted small">صفحه @assignmentPage از @assignmentTotalPages - تعداد کل: @assignmentTotalItems</div>
                    <nav>
                        <ul class="pagination pagination-primary mb-0">
                            <li class="page-item @(assignmentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@bankPage" asp-route-walletPage="@walletPage" asp-route-assignmentPage="1" asp-route-assignmentPageSize="@assignmentPageSize">اول</a>
                            </li>
                            <li class="page-item @(assignmentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@bankPage" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@(assignmentPage - 1)" asp-route-assignmentPageSize="@assignmentPageSize">قبلی</a>
                            </li>
                            @{
                                var assignmentStart = Math.Max(1, assignmentPage - 2);
                                var assignmentEnd = Math.Min(assignmentTotalPages, assignmentPage + 2);
                            }
                            @for (int i = assignmentStart; i <= assignmentEnd; i++)
                            {
                                <li class="page-item @(i == assignmentPage ? "active" : "")">
                                    <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@bankPage" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@i" asp-route-assignmentPageSize="@assignmentPageSize">@i</a>
                                </li>
                            }
                            <li class="page-item @(assignmentPage >= assignmentTotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@bankPage" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@(assignmentPage + 1)" asp-route-assignmentPageSize="@assignmentPageSize">بعدی</a>
                            </li>
                            <li class="page-item @(assignmentPage >= assignmentTotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressPage" asp-route-bankPage="@bankPage" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@assignmentTotalPages" asp-route-assignmentPageSize="@assignmentPageSize">آخر</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>