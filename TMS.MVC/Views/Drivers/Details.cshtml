@model TMS.MVC.Models.DriverProfile

@{
    ViewData["Title"] = "مشخصات کامل راننده";

    var fullName = Model.ApplicationUser == null
        ? "-"
        : (
            !string.IsNullOrWhiteSpace(((Model.ApplicationUser.FirstName ?? "") + " " + (Model.ApplicationUser.LastName ?? "")).Trim())
                ? ((Model.ApplicationUser.FirstName ?? "") + " " + (Model.ApplicationUser.LastName ?? "")).Trim()
                : (Model.ApplicationUser.Email ?? "-")
          );
}

<style>
    .driver-details-compact .form-label { margin-bottom: 0.25rem; font-size: 0.82rem; }
    .driver-details-compact .form-control,
    .driver-details-compact .form-select,
    .driver-details-compact .btn,
    .driver-details-compact .table,
    .driver-details-compact .badge { font-size: 0.82rem; }
    .driver-details-compact .table > :not(caption) > * > * { padding: 0.45rem 0.55rem; }
    .driver-details-compact .card-header { padding-top: 0.65rem; padding-bottom: 0.65rem; }
    .driver-details-compact .card-body { padding-top: 0.85rem; }
    .driver-details-compact .small-muted { font-size: 0.78rem; }
    .driver-details-compact .info-item { font-size: 0.84rem; margin-bottom: 0.45rem; }
    .driver-details-compact .detail-actions { display: flex; flex-wrap: wrap; gap: 0.35rem; }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">رانندگان</a></li>
                    <li class="breadcrumb-item active">جزئیات</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid driver-details-compact">
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success py-2 small">@TempData["Ok"]</div>
    }

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">اطلاعات کلی</h6>
                <small class="text-muted small-muted">اطلاعات هویتی و وضعیت راننده</small>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Index" class="btn btn-secondary btn-sm px-3">بازگشت</a>
            </div>
        </div>
        <div class="card-body row">
            <div class="col-md-4 info-item"><strong>نام راننده:</strong> @fullName</div>
            <div class="col-md-4 info-item"><strong>کد ملی:</strong> @(Model.ApplicationUser?.NationalId ?? "-")</div>
            <div class="col-md-4 info-item"><strong>شماره کارت هوشمند:</strong> @(Model.SmartCardNumber ?? "-")</div>
            <div class="col-md-4 info-item"><strong>شماره گواهینامه:</strong> @(Model.DrivingLicenseNumber ?? "-")</div>
            <div class="col-md-4 info-item">
                <strong>وضعیت:</strong>
                @if (Model.IsBlocked)
                {
                    <span class="badge bg-danger">محدود</span>
                }
                else
                {
                    <span class="badge bg-success">فعال</span>
                }
            </div>
            <div class="col-md-12 info-item"><strong>توضیحات محدودیت:</strong> @(string.IsNullOrWhiteSpace(Model.BlockDescription) ? "-" : Model.BlockDescription)</div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">راه‌های ارتباطی</h6>
                <small class="text-muted small-muted">شماره تماس، ایمیل، واتساپ و سایر مسیرهای ارتباطی</small>
            </div>
            <a asp-action="AddContact" asp-route-driverProfileId="@Model.Id" class="btn btn-primary btn-sm px-3">افزودن</a>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead>
                    <tr>
                        <th>عنوان</th>
                        <th>راه ارتباطی</th>
                        <th>پیامک</th>
                        <th>واتساپ</th>
                        <th>فکس</th>
                        <th>تلفن</th>
                        <th>ایمیل</th>
                        <th style="width:145px">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Contacts.Any())
                    {
                        @foreach (var item in Model.Contacts.OrderBy(x => x.Id))
                        {
                            <tr>
                                <td>@item.Title</td>
                                <td>@item.ContactValue</td>
                                <td>@(item.HasSms ? "بله" : "-")</td>
                                <td>@(item.HasWhatsApp ? "بله" : "-")</td>
                                <td>@(item.IsFax ? "بله" : "-")</td>
                                <td>@(item.IsPhone ? "بله" : "-")</td>
                                <td>@(item.IsEmail ? "بله" : "-")</td>
                                <td>
                                    <div class="detail-actions">
                                        <a asp-action="EditContact" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                        <form asp-action="DeleteContact" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="driverProfileId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">موردی ثبت نشده است.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">آدرس‌ها</h6>
                <small class="text-muted small-muted">آدرس‌های ثبت‌شده برای راننده</small>
            </div>
            <a asp-action="AddAddress" asp-route-driverProfileId="@Model.Id" class="btn btn-primary btn-sm px-3">افزودن</a>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead>
                    <tr>
                        <th>عنوان</th>
                        <th>آدرس</th>
                        <th style="width:145px">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Addresses.Any())
                    {
                        @foreach (var item in Model.Addresses.OrderBy(x => x.Id))
                        {
                            <tr>
                                <td>@item.Title</td>
                                <td>@item.AddressText</td>
                                <td>
                                    <div class="detail-actions">
                                        <a asp-action="EditAddress" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                        <form asp-action="DeleteAddress" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="driverProfileId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="3" class="text-center text-muted py-4">موردی ثبت نشده است.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">حساب‌های بانکی</h6>
                <small class="text-muted small-muted">لیست حساب‌ها و شماره‌های بانکی راننده</small>
            </div>
            <a asp-action="AddBankAccount" asp-route-driverProfileId="@Model.Id" class="btn btn-primary btn-sm px-3">افزودن</a>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-hover table-sm align-middle">
                <thead>
                    <tr>
                        <th>نام صاحب حساب</th>
                        <th>نام بانک</th>
                        <th>شماره حساب</th>
                        <th>شماره کارت</th>
                        <th>شماره شبا</th>
                        <th>پیش فرض</th>
                        <th>توضیحات</th>
                        <th style="width:145px">عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.BankAccounts.Any())
                    {
                        @foreach (var item in Model.BankAccounts.OrderByDescending(x => x.IsDefault).ThenBy(x => x.Id))
                        {
                            <tr>
                                <td>@(item.AccountOwnerName ?? "-")</td>
                                <td>@(item.BankName ?? "-")</td>
                                <td>@(item.AccountNumber ?? "-")</td>
                                <td>@(item.CardNumber ?? "-")</td>
                                <td>@(item.ShebaNumber ?? "-")</td>
                                <td class="text-center">
                                    @if (item.IsDefault)
                                    {
                                        <span class="badge bg-success">بله</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>@(item.Description ?? "-")</td>
                                <td>
                                    <div class="detail-actions">
                                        <a asp-action="EditBankAccount" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                        <form asp-action="DeleteBankAccount" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="driverProfileId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="8" class="text-center text-muted py-4">موردی ثبت نشده است.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>
