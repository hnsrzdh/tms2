                            {
                                <li class="page-item @(i == addressPage ? "active" : "")">
                                    <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@i" asp-route-addressPageSize="@addressPageSize" asp-route-bankPage="@bankPage" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@assignmentPage">@i</a>
                                </li>
                            }
                            <li class="page-item @(addressPage >= addressTotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@(addressPage + 1)" asp-route-addressPageSize="@addressPageSize" asp-route-bankPage="@bankPage" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@assignmentPage">بعدی</a>
                            </li>
                            <li class="page-item @(addressPage >= addressTotalPages ? "disabled" : "")">
                                <a class="page-link" asp-action="Details" asp-route-id="@Model.Id" asp-route-contactPage="@contactPage" asp-route-addressPage="@addressTotalPages" asp-route-addressPageSize="@addressPageSize" asp-route-bankPage="@bankPage" asp-route-walletPage="@walletPage" asp-route-assignmentPage="@assignmentPage">آخر</a>
