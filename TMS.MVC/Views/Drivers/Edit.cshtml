@model TMS.MVC.ViewModels.DriverUpsertViewModel

@{
    ViewData["Title"] = "ویرایش راننده";
}

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item active">داشبورد</li>
                    <li class="breadcrumb-item">رانندگان</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ApplicationUserId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="UserDisplayName" class="form-label"></label>
                        <input asp-for="UserDisplayName" class="form-control" readonly />
                    </div>

                    <div class="col-md-6">
                        <label asp-for="NationalId" class="form-label"></label>
                        <input asp-for="NationalId" class="form-control" />
                        <span asp-validation-for="NationalId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SmartCardNumber" class="form-label"></label>
                        <input asp-for="SmartCardNumber" class="form-control" />
                        <span asp-validation-for="SmartCardNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="DrivingLicenseNumber" class="form-label"></label>
                        <input asp-for="DrivingLicenseNumber" class="form-control" />
                        <span asp-validation-for="DrivingLicenseNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <div class="form-check mt-4">
                            <input asp-for="IsBlocked" class="form-check-input" />
                            <label asp-for="IsBlocked" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="col-md-9">
                        <label asp-for="BlockDescription" class="form-label"></label>
                        <textarea asp-for="BlockDescription" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="BlockDescription" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">ذخیره تغییرات</button>
                    <a asp-action="Index" class="btn btn-secondary">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>
