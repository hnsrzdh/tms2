@model TMS.MVC.ViewModels.HavalehUpsertViewModel

@{
    ViewData["Title"] = "ویرایش حواله";
}

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item active">داشبورد</li>
                    <li class="breadcrumb-item">حواله‌ها</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <form asp-action="Edit" method="post" id="havalehEditForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <!-- دسته: اطلاعات پایه حواله -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">اطلاعات پایه حواله</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-2">
                        <label asp-for="HavalehNumber" class="form-label fw-bold small"></label>
                        <input asp-for="HavalehNumber" class="form-control" />
                        <span asp-validation-for="HavalehNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="ContractNumber" class="form-label fw-bold small"></label>
                        <input asp-for="ContractNumber" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="HavalehType" class="form-label fw-bold small"></label>
                        <input asp-for="HavalehType" class="form-control" />
                    </div>

                    <div class="col-md-3">
                        <label class="form-label fw-bold small">صاحب کالا</label>
                        <div class="input-group">
                            <input asp-for="GoodsOwnerLegalEntityId" type="hidden" />
                            <input asp-for="GoodsOwnerDisplayName" class="form-control" readonly />
                            <button type="button" class="btn btn-outline-secondary" id="openGoodsOwnerModal">انتخاب</button>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label fw-bold small">پیمانکار حمل</label>
                        <div class="input-group">
                            <input asp-for="TransportContractorLegalEntityId" type="hidden" />
                            <input asp-for="TransportContractorDisplayName" class="form-control" readonly />
                            <button type="button" class="btn btn-outline-secondary" id="openTransportContractorModal">انتخاب</button>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-check mt-0">
                            <input asp-for="RequiresFleetEntryPermit" class="form-check-input" />
                            <label asp-for="RequiresFleetEntryPermit" class="form-check-label small"></label>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- دسته: مبدا و زمان‌بندی -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">مبدا و زمان‌بندی</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold small">مبدا</label>
                        <div class="input-group">
                            <input asp-for="OriginCityId" type="hidden" />
                            <input asp-for="OriginCityDisplayName" class="form-control" readonly />
                            <button type="button" class="btn btn-outline-secondary" id="openOriginCityModal">انتخاب</button>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="PurchaseDate" class="form-label fw-bold small"></label>
                        <input type="hidden" asp-for="PurchaseDate" id="PurchaseDate" value="@(Model.PurchaseDate?.ToString("yyyy-MM-dd"))" />
                        <input id="PurchaseDate_shamsi" class="form-control jalali-date" autocomplete="off" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="AllowedLoadingDate" class="form-label fw-bold small"></label>
                        <input type="hidden" asp-for="AllowedLoadingDate" id="AllowedLoadingDate" value="@(Model.AllowedLoadingDate?.ToString("yyyy-MM-dd"))" />
                        <input id="AllowedLoadingDate_shamsi" class="form-control jalali-date" autocomplete="off" />
                    </div>
                </div>
            </div>
        </div>

        <!-- دسته: محصول و مقدار -->
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">محموله</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label fw-bold small">محصول</label>
                        <div class="input-group">
                            <input asp-for="ProductId" type="hidden" />
                            <input asp-for="ProductDisplayName" class="form-control" readonly />
                            <button type="button" class="btn btn-outline-secondary" id="openProductModal">انتخاب</button>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="ProductAmount" class="form-label fw-bold small"></label>
                        <input asp-for="ProductAmount" class="form-control" type="number" step="1" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="Unit" class="form-label fw-bold small"></label>
                        <select asp-for="Unit" class="form-select">
                            <option value="کیلوگرم">کیلوگرم</option>
                            <option value="لیتر">لیتر</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label asp-for="ShortagePenaltyPerUnit" class="form-label fw-bold small"></label>
                        <div class="input-group">
                            <input asp-for="ShortagePenaltyPerUnit" class="form-control" type="number" step="1" />
                            <span class="input-group-text">ریال</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- دکمه‌های اقدام -->
        <div class="mt-4 d-flex gap-2 justify-content-start">
            <button type="submit" class="btn btn-primary px-4">ذخیره تغییرات</button>
            <a asp-action="Index" class="btn btn-secondary px-4">انصراف</a>
        </div>
    </form>
</div>

<!-- مودال‌ها (بدون تغییر) -->
<div class="modal fade" id="transportContractorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">انتخاب پیمانکار حمل</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" id="transportContractorSearchInput" class="form-control mb-3" placeholder="جستجو..." />
                <table class="table table-hover">
                    <thead><tr><th>نام شرکت</th><th>نوع</th><th>شهر</th><th>انتخاب</th></tr></thead>
                    <tbody id="transportContractorSearchResults"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="goodsOwnerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">انتخاب صاحب کالا</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" id="goodsOwnerSearchInput" class="form-control mb-3" placeholder="جستجو..." />
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>نام شرکت</th>
                            <th>نوع</th>
                            <th>شهر</th>
                            <th>انتخاب</th>
                        </tr>
                    </thead>
                    <tbody id="goodsOwnerSearchResults"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="originCityModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">انتخاب مبدا</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" id="originCitySearchInput" class="form-control mb-3" placeholder="جستجو..." />
                <table class="table table-hover">
                    <thead><tr><th>شهر</th><th>انتخاب</th></tr></thead>
                    <tbody id="originCitySearchResults"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">انتخاب محصول</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="text" id="productSearchInput" class="form-control mb-3" placeholder="جستجو..." />
                <table class="table table-hover">
                    <thead><tr><th>محصول</th><th>انتخاب</th></tr></thead>
                    <tbody id="productSearchResults"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="~/assets/css/persianDatepicker-default.css">
    <script src="~/assets/js/persianDatepicker.min.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("havalehEditForm");
            setupJalaliDateField("PurchaseDate", "PurchaseDate_shamsi");
            setupJalaliDateField("AllowedLoadingDate", "AllowedLoadingDate_shamsi");

            function setupJalaliDateField(hiddenInputId, shamsiInputId) {
                const hiddenInput = document.getElementById(hiddenInputId);
                const shamsiInput = document.getElementById(shamsiInputId);
                if (!hiddenInput || !shamsiInput) return;

                if (typeof $ !== "undefined" && typeof $(shamsiInput).persianDatepicker === "function") {
                    $(shamsiInput).persianDatepicker({
                        formatDate: "YYYY/0M/0D",
                        autoClose: true,
                        onSelect: function () {
                            syncShamsiToGregorian(hiddenInput, shamsiInput);
                        }
                    });
                }

                if (hiddenInput.value) {
                    const g = normalizeGregorianDate(hiddenInput.value);
                    if (g) {
                        const j = gregorianToJalali(g.y, g.m, g.d);
                        shamsiInput.value = j.y + "/" + pad2(j.m) + "/" + pad2(j.d);
                    }
                }

                shamsiInput.addEventListener("change", function () { syncShamsiToGregorian(hiddenInput, shamsiInput); });
                shamsiInput.addEventListener("blur", function () { syncShamsiToGregorian(hiddenInput, shamsiInput); });
            }

            if (form) {
                form.addEventListener("submit", function () {
                    syncShamsiToGregorian(document.getElementById("PurchaseDate"), document.getElementById("PurchaseDate_shamsi"));
                    syncShamsiToGregorian(document.getElementById("AllowedLoadingDate"), document.getElementById("AllowedLoadingDate_shamsi"));
                });
            }

            function syncShamsiToGregorian(hiddenInput, shamsiInput) {
                if (!hiddenInput || !shamsiInput) return;

                let value = (shamsiInput.value || "").trim();
                value = toEnglishDigits(value);

                if (!value) {
                    hiddenInput.value = "";
                    return;
                }

                const parts = value.replace(/-/g, "/").split("/");
                if (parts.length !== 3) {
                    hiddenInput.value = "";
                    return;
                }

                const jy = parseInt(parts[0], 10);
                const jm = parseInt(parts[1], 10);
                const jd = parseInt(parts[2], 10);

                if (isNaN(jy) || isNaN(jm) || isNaN(jd)) {
                    hiddenInput.value = "";
                    return;
                }

                const g = jalaliToGregorian(jy, jm, jd);
                hiddenInput.value = g.y + "-" + pad2(g.m) + "-" + pad2(g.d);
            }

            function normalizeGregorianDate(value) {
                if (!value) return null;
                value = toEnglishDigits(value).trim();
                if (value.includes("T")) value = value.split("T")[0];
                const parts = value.split("-");
                if (parts.length !== 3) return null;
                const y = parseInt(parts[0], 10);
                const m = parseInt(parts[1], 10);
                const d = parseInt(parts[2], 10);
                if (isNaN(y) || isNaN(m) || isNaN(d)) return null;
                return { y, m, d };
            }

            function toEnglishDigits(str) {
                if (!str) return str;
                const fa = ['۰','۱','۲','۳','۴','۵','۶','۷','۸','۹'];
                const ar = ['٠','١','٢','٣','٤','٥','٦','٧','٨','٩'];
                for (let i = 0; i < 10; i++) {
                    str = str.replaceAll(fa[i], i.toString());
                    str = str.replaceAll(ar[i], i.toString());
                }
                return str;
            }

            function pad2(n) { return n < 10 ? "0" + n : n.toString(); }

            function gregorianToJalali(gy, gm, gd) {
                var g_d_m, jy, jm, jd, gy2, days;
                g_d_m = [0,31,59,90,120,151,181,212,243,273,304,334];
                gy2 = (gm > 2) ? (gy + 1) : gy;
                days = 355666 + (365 * gy) + Math.floor((gy2 + 3) / 4) - Math.floor((gy2 + 99) / 100) + Math.floor((gy2 + 399) / 400) + gd + g_d_m[gm - 1];
                jy = -1595 + (33 * Math.floor(days / 12053));
                days %= 12053;
                jy += 4 * Math.floor(days / 1461);
                days %= 1461;
                if (days > 365) {
                    jy += Math.floor((days - 1) / 365);
                    days = (days - 1) % 365;
                }
                if (days < 186) {
                    jm = 1 + Math.floor(days / 31);
                    jd = 1 + (days % 31);
                } else {
                    jm = 7 + Math.floor((days - 186) / 30);
                    jd = 1 + ((days - 186) % 30);
                }
                return { y: jy, m: jm, d: jd };
            }

            function jalaliToGregorian(jy, jm, jd) {
                var sal_a, gy, gm, gd, days;
                jy += 1595;
                days = -355668 + (365 * jy) + Math.floor(jy / 33) * 8 + Math.floor(((jy % 33) + 3) / 4) + jd + ((jm < 7) ? (jm - 1) * 31 : ((jm - 7) * 30) + 186);
                gy = 400 * Math.floor(days / 146097);
                days %= 146097;

                if (days > 36524) {
                    gy += 100 * Math.floor(--days / 36524);
                    days %= 36524;
                    if (days >= 365) days++;
                }

                gy += 4 * Math.floor(days / 1461);
                days %= 1461;

                if (days > 365) {
                    gy += Math.floor((days - 1) / 365);
                    days = (days - 1) % 365;
                }

                gd = days + 1;
                sal_a = [0,31,((gy % 4 === 0 && gy % 100 !== 0) || (gy % 400 === 0)) ? 29 : 28,31,30,31,30,31,31,30,31,30,31];
                for (gm = 1; gm <= 12 && gd > sal_a[gm]; gm++) gd -= sal_a[gm];
                return { y: gy, m: gm, d: gd };
            }

            // Bind modal functions
            bindLegalEntityModal("openTransportContractorModal", "transportContractorModal", "transportContractorSearchInput", "transportContractorSearchResults", "TransportContractorLegalEntityId", "TransportContractorDisplayName");
            bindLegalEntityModal("openGoodsOwnerModal", "goodsOwnerModal", "goodsOwnerSearchInput", "goodsOwnerSearchResults", "GoodsOwnerLegalEntityId", "GoodsOwnerDisplayName");
            bindCityModal();
            bindProductModal();

            function bindLegalEntityModal(openBtnId, modalId, searchInputId, resultsId, hiddenId, textId) {
                const modal = new bootstrap.Modal(document.getElementById(modalId));
                const searchInput = document.getElementById(searchInputId);
                const results = document.getElementById(resultsId);

                document.getElementById(openBtnId).addEventListener("click", function () {
                    searchInput.value = "";
                    results.innerHTML = "";
                    modal.show();
                    setTimeout(() => searchInput.focus(), 200);
                });

                let timeout;
                searchInput.addEventListener("input", function () {
                    clearTimeout(timeout);
                    const term = this.value.trim();

                    timeout = setTimeout(() => {
                        if (!term) {
                            results.innerHTML = "";
                            return;
                        }

                        fetch(`/Havalehs/SearchLegalEntities?term=${encodeURIComponent(term)}`)
                            .then(r => r.json())
                            .then(data => {
                                results.innerHTML = data.map(x => `
                                    <tr>
                                        <td>${x.companyName ?? ""}</td>
                                        <td>${x.companyType ?? ""}</td>
                                        <td>${x.city ?? ""}</td>
                                        <td>
                                            <button type="button"
                                                    class="btn btn-sm btn-primary js-select-item"
                                                    data-id="${x.id}"
                                                    data-text="${x.companyName ?? ""}">
                                                انتخاب
                                            </button>
                                        </td>
                                    ｜DSML｜
                                `).join("");

                                results.querySelectorAll(".js-select-item").forEach(btn => {
                                    btn.addEventListener("click", function () {
                                        document.getElementById(hiddenId).value = this.dataset.id;
                                        document.getElementById(textId).value = this.dataset.text;
                                        modal.hide();
                                    });
                                });
                            });
                    }, 300);
                });
            }

            function bindCityModal() {
                const modal = new bootstrap.Modal(document.getElementById("originCityModal"));
                const searchInput = document.getElementById("originCitySearchInput");
                const results = document.getElementById("originCitySearchResults");

                document.getElementById("openOriginCityModal").addEventListener("click", function () {
                    searchInput.value = "";
                    results.innerHTML = "";
                    modal.show();
                    setTimeout(() => searchInput.focus(), 200);
                });

                let timeout;
                searchInput.addEventListener("input", function () {
                    clearTimeout(timeout);
                    const term = this.value.trim();

                    timeout = setTimeout(() => {
                        if (!term) {
                            results.innerHTML = "";
                            return;
                        }

                        fetch(`/Havalehs/SearchCities?term=${encodeURIComponent(term)}`)
                            .then(r => r.json())
                            .then(data => {
                                results.innerHTML = data.map(x => `
                                    <tr>
                                        <td>${x.text ?? ""}</td>
                                        <td>
                                            <button type="button"
                                                    class="btn btn-sm btn-primary js-select-city"
                                                    data-id="${x.id}"
                                                    data-text="${x.text ?? ""}">
                                                انتخاب
                                            </button>
                                        </td>
                                    </tr>
                                `).join("");

                                results.querySelectorAll(".js-select-city").forEach(btn => {
                                    btn.addEventListener("click", function () {
                                        document.getElementById("OriginCityId").value = this.dataset.id;
                                        document.getElementById("OriginCityDisplayName").value = this.dataset.text;
                                        modal.hide();
                                    });
                                });
                            });
                    }, 300);
                });
            }

            function bindProductModal() {
                const modal = new bootstrap.Modal(document.getElementById("productModal"));
                const searchInput = document.getElementById("productSearchInput");
                const results = document.getElementById("productSearchResults");

                document.getElementById("openProductModal").addEventListener("click", function () {
                    searchInput.value = "";
                    results.innerHTML = "";
                    modal.show();
                    setTimeout(() => searchInput.focus(), 200);
                });

                let timeout;
                searchInput.addEventListener("input", function () {
                    clearTimeout(timeout);
                    const term = this.value.trim();

                    timeout = setTimeout(() => {
                        if (!term) {
                            results.innerHTML = "";
                            return;
                        }

                        fetch(`/Havalehs/SearchProducts?term=${encodeURIComponent(term)}`)
                            .then(r => r.json())
                            .then(data => {
                                results.innerHTML = data.map(x => `
                                    <tr>
                                        <td>${x.text ?? ""}</td>
                                        <td>
                                            <button type="button"
                                                    class="btn btn-sm btn-primary js-select-product"
                                                    data-id="${x.id}"
                                                    data-text="${x.text ?? ""}">
                                                انتخاب
                                            </button>
                                        </td>
                                    </tr>
                                `).join("");

                                results.querySelectorAll(".js-select-product").forEach(btn => {
                                    btn.addEventListener("click", function () {
                                        document.getElementById("ProductId").value = this.dataset.id;
                                        document.getElementById("ProductDisplayName").value = this.dataset.text;
                                        modal.hide();
                                    });
                                });
                            });
                    }, 300);
                });
            }
        });
    </script>
}