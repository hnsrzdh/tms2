@using System.Globalization
@using TMS.MVC.ViewModels
@model HavalehIndexViewModel

@{
    ViewData["Title"] = "حواله‌ها";

    string ToJalali(DateTime? date)
    {
        if (!date.HasValue) return "-";
        var pc = new PersianCalendar();
        var d = date.Value;
        return $"{pc.GetYear(d):0000}/{pc.GetMonth(d):00}/{pc.GetDayOfMonth(d):00}";
    }
}

<style>
    .havaleh-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .havaleh-compact .form-control,
    .havaleh-compact .form-select,
    .havaleh-compact .btn,
    .havaleh-compact .table,
    .havaleh-compact .badge,
    .havaleh-compact .input-group-text {
        font-size: 0.82rem;
    }

    .havaleh-compact .table > :not(caption) > * > * {
        padding: 0.35rem 0.45rem;
    }

    .havaleh-compact .card-header {
        padding: 0.65rem 0.85rem;
    }

    .havaleh-compact .card-body {
        padding: 0.85rem;
    }

    .havaleh-compact .modal-header,
    .havaleh-compact .modal-body,
    .havaleh-compact .modal-footer {
        padding: 0.75rem 0.9rem;
    }

    .havaleh-compact .small-muted {
        font-size: 0.78rem;
        color: #6c757d;
    }

    .havaleh-compact .info-box {
        padding: 0.65rem;
    }

    .havaleh-compact .pagination {
        margin-bottom: 0;
    }
</style>

<div class="container-fluid havaleh-compact">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item active">داشبورد</li>
                    <li class="breadcrumb-item">حواله‌ها</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid havaleh-compact">
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success py-2">@TempData["Ok"]</div>
    }

    <div class="card shadow-sm">

        <div class="card-header d-flex justify-content-between align-items-center">
            <a asp-action="Create" class="btn btn-primary btn-sm">تعریف حواله جدید</a>
        </div>

        <div class="card-body">
            <form method="get" class="row g-2 mb-3">
                <div class="col-md-9">
                    <input type="text" name="search" value="@Model.Search" class="form-control form-control-sm"
                           placeholder="جستجو بر اساس شماره حواله، قرارداد، نوع، شرکت، شهر یا محصول" />
                </div>
                <div class="col-md-2">
                    <select name="pageSize" class="form-select form-select-sm">
                        <option value="10" selected="@(Model.PageSize == 10)">10</option>
                        <option value="20" selected="@(Model.PageSize == 20)">20</option>
                        <option value="50" selected="@(Model.PageSize == 50)">50</option>
                    </select>
                </div>
                <div class="col-md-1 d-grid">
                    <button type="submit" class="btn btn-primary btn-sm">فیلتر</button>
                </div>
            </form>

            <div class="table-responsive table-sm">
                <table class="table table-hover align-middle table-sm">
                    <thead class="table-light table-sm">
                        <tr>
                            <th>#</th>
                            <th>شماره حواله</th>
                            <th>شماره قرارداد</th>
                            <th>پیمانکار حمل</th>
                            <th>صاحب کالا</th>
                            <th>مبدا</th>
                            <th>محصول</th>
                            <th>مقدار</th>
                            <th>عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Any())
                        {
                            var rowNo = Model.RowNumberStart;
                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@rowNo</td>
                                    <td>@item.HavalehNumber</td>
                                    <td>@item.ContractNumber</td>
                                    <td>@item.TransportContractorName</td>
                                    <td>@item.GoodsOwnerName</td>
                                    <td>@item.OriginCityText</td>
                                    <td>@item.ProductName</td>
                                    <td>@(item.ProductAmount.HasValue ? $"{item.ProductAmount:N0} {item.Unit}" : "-")</td>
                                    <td>
                                        <div class="d-flex gap-1 flex-wrap">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">ویرایش</a>
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">جزئیات</a>
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-danger"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteModal_@item.Id">
                                                حذف
                                            </button>
                                        </div>

                                        <div class="modal fade" id="deleteModal_@item.Id" tabindex="-1" aria-hidden="true">
                                            <div class="modal-dialog">
                                                <div class="modal-content">
                                                    <form asp-action="Delete" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.Id" />

                                                        <div class="modal-header">
                                                            <h6 class="modal-title">حذف حواله</h6>
                                                            <button type="button" class="btn-close ms-0 me-auto" data-bs-dismiss="modal"></button>
                                                        </div>

                                                        <div class="modal-body">
                                                            <p class="mb-0">آیا از حذف این حواله مطمئن هستید؟</p>
                                                            <div class="mt-2 text-muted">شماره حواله: @item.HavalehNumber</div>
                                                        </div>

                                                        <div class="modal-footer gap-2">
                                                            <button type="submit" class="btn btn-danger btn-sm">حذف</button>
                                                            <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">انصراف</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                rowNo++;
                            }
                        }
                        else
                        {
                            <tr><td colspan="14" class="text-center py-4">موردی یافت نشد.</td></tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
                    <div class="text-muted small">صفحه @Model.Page از @Model.TotalPages - تعداد کل: @Model.TotalItems</div>
                    <nav>
                        <ul class="pagination pagination-primary">
                            <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                                <a class="page-link" asp-route-page="1" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">اول</a>
                            </li>
                            <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                                <a class="page-link" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">قبلی</a>
                            </li>
                            @{
                                var startPage = Math.Max(1, Model.Page - 2);
                                var endPage = Math.Min(Model.TotalPages, Model.Page + 2);
                            }
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")">
                                    <a class="page-link" asp-route-page="@i" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">بعدی</a>
                            </li>
                            <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" asp-route-page="@Model.TotalPages" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">آخر</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
       
        </div>
    </div>
</div>