@model TMS.MVC.Models.LegalEntityAddress

@{
    ViewData["Title"] = "افزودن آدرس";
}

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item active">داشبورد</li>
                    <li class="breadcrumb-item">اشخاص حقوقی</li>
                </ol>
            </div>

        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="AddAddress" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="LegalEntityId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-md-8 mb-3">
                        <label asp-for="PostalCode" class="form-label"></label>
                        <input asp-for="PostalCode" class="form-control" />
                        <span asp-validation-for="PostalCode" class="text-danger"></span>
                    </div>

                    <div class="col-md-12 mb-3">
                        <label asp-for="AddressText" class="form-label"></label>
                        <textarea asp-for="AddressText" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="AddressText" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">ذخیره</button>
                    <a asp-action="Details" asp-route-id="@Model.LegalEntityId" class="btn btn-secondary">بازگشت</a>
                </div>
            </form>
        </div>
    </div>
</div>
