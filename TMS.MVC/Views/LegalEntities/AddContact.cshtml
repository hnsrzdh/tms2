@model TMS.MVC.ViewModels.LegalEntityContactChannelVm

@{
    ViewData["Title"] = "افزودن راه ارتباطی شخص حقوقی";
}

<style>
    .contact-form-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
        font-weight: 600;
    }

    .contact-form-compact .form-control,
    .contact-form-compact .btn {
        font-size: 0.82rem;
    }

    .contact-form-compact .field-validation-valid,
    .contact-form-compact .field-validation-error {
        font-size: 0.75rem;
    }

    .contact-form-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .contact-form-compact .card-body {
        padding-top: 0.85rem;
    }

    .contact-form-compact .small-muted {
        font-size: 0.78rem;
    }

    .contact-form-compact .contact-card {
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        background: #fff;
        padding: 0.75rem;
        height: 100%;
    }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">اشخاص حقوقی</a></li>
                    <li class="breadcrumb-item active">راه ارتباطی</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid contact-form-compact">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">افزودن راه ارتباطی شخص حقوقی</h6>
                <small class="text-muted small-muted">
                    مقدار هر مسیر ارتباطی را مستقیم در فیلد خودش وارد کنید.
                </small>
            </div>
        </div>

        <div class="card-body">
            <form asp-action="AddContact" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="LegalEntityId" type="hidden" />

                <div class="row g-2">
                    <div class="col-md-6">
                        <div class="contact-card">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control form-control-sm" placeholder="مثلاً دفتر مرکزی، حسابداری، مدیر ناوگان..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="contact-card">
                            <label asp-for="SmsNumber" class="form-label"></label>
                            <input asp-for="SmsNumber" class="form-control form-control-sm" placeholder="شماره موبایل برای پیامک" />
                            <span asp-validation-for="SmsNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="contact-card">
                            <label asp-for="WhatsAppNumber" class="form-label"></label>
                            <input asp-for="WhatsAppNumber" class="form-control form-control-sm" placeholder="شماره واتساپ" />
                            <span asp-validation-for="WhatsAppNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="contact-card">
                            <label asp-for="FaxNumber" class="form-label"></label>
                            <input asp-for="FaxNumber" class="form-control form-control-sm" placeholder="شماره فکس" />
                            <span asp-validation-for="FaxNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="contact-card">
                            <label asp-for="PhoneNumber" class="form-label"></label>
                            <input asp-for="PhoneNumber" class="form-control form-control-sm" placeholder="شماره تلفن ثابت" />
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="contact-card">
                            <label asp-for="EmailAddress" class="form-label"></label>
                            <input asp-for="EmailAddress" class="form-control form-control-sm" placeholder="آدرس ایمیل" />
                            <span asp-validation-for="EmailAddress" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <hr class="my-3" />

                <div class="d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary btn-sm px-3">ذخیره</button>
                    <a asp-action="Details" asp-route-id="@Model.LegalEntityId" class="btn btn-secondary btn-sm px-3">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>
