@model TMS.MVC.ViewModels.LegalEntityDetailsVm

@{
    ViewData["Title"] = "مشخصات کامل شخص حقوقی";
}

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item active">داشبورد</li>
                    <li class="breadcrumb-item">اشخاص حقوقی</li>
                </ol>
            </div>

        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4>اطلاعات کلی</h4>
            <div class="d-flex gap-2 mt-2">
                <a asp-action="Index" class="btn btn-secondary">بازگشت</a>
            </div>
        </div>
        <div class="card-body row">
            <div class="col-md-4 mb-2"><strong>نام شرکت:</strong> @Model.Entity.CompanyName</div>
            <div class="col-md-4 mb-2"><strong>نوع:</strong> @Model.Entity.CompanyType</div>
            <div class="col-md-4 mb-2"><strong>شهر:</strong> @Model.Entity.City</div>
            
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4>راه‌های ارتباطی</h4>
            <a asp-action="AddContact" asp-route-legalEntityId="@Model.Entity.Id" class="btn btn-primary">افزودن</a>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>عنوان</th>
                        <th>راه ارتباطی</th>
                        <th>پیامک</th>
                        <th>واتساپ</th>
                        <th>فکس</th>
                        <th>تلفن</th>
                        <th>ایمیل</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Entity.Contacts.OrderBy(x => x.Id))
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.ContactValue</td>
                            <td>@(item.HasSms ? "بله" : "-")</td>
                            <td>@(item.HasWhatsApp ? "بله" : "-")</td>
                            <td>@(item.IsFax ? "بله" : "-")</td>
                            <td>@(item.IsPhone ? "بله" : "-")</td>
                            <td>@(item.IsEmail ? "بله" : "-")</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="EditContact" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">ویرایش</a>
                                    <form asp-action="DeleteContact" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4>آدرس‌ها</h4>
            <a asp-action="AddAddress" asp-route-legalEntityId="@Model.Entity.Id" class="btn btn-primary">افزودن</a>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>عنوان</th>
                        <th>آدرس</th>
                        <th>کدپستی</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Entity.Addresses.OrderBy(x => x.Id))
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>@item.AddressText</td>
                            <td>@item.PostalCode</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="EditAddress" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                    <form asp-action="DeleteAddress" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4>حساب‌های بانکی</h4>
            <a asp-action="AddBankAccount" asp-route-legalEntityId="@Model.Entity.Id" class="btn btn-primary">افزودن</a>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>شماره شبا</th>
                        <th>نام صاحب حساب</th>
                        <th>نام استعلام شده</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Entity.BankAccounts.OrderBy(x => x.Id))
                    {
                        <tr>
                            <td>@item.Iban</td>
                            <td>@item.AccountHolderName</td>
                            <td>@item.VerifiedName</td>
                            <td>
                                <div class="d-flex gap-2">
                                    <a asp-action="EditBankAccount" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                    <form asp-action="DeleteBankAccount" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>


</div>