@model TMS.MVC.ViewModels.LegalEntityDetailsVm

@{
    ViewData["Title"] = "مشخصات کامل شخص حقوقی";
}

<style>
    .legal-entity-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .legal-entity-compact .form-control,
    .legal-entity-compact .form-select,
    .legal-entity-compact .btn,
    .legal-entity-compact .table,
    .legal-entity-compact .badge {
        font-size: 0.82rem;
    }

    .legal-entity-compact .table > :not(caption) > * > * {
        padding: 0.45rem 0.55rem;
    }

    .legal-entity-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .legal-entity-compact .card-body {
        padding-top: 0.85rem;
    }

    .legal-entity-compact .small-muted {
        font-size: 0.78rem;
    }

    .legal-entity-compact .entity-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.35rem;
    }

    .legal-entity-compact .info-item {
        font-size: 0.84rem;
        margin-bottom: 0.35rem;
    }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">اشخاص حقوقی</a></li>
                    <li class="breadcrumb-item active">جزئیات</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid legal-entity-compact">
    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">اطلاعات کلی</h6>
                <small class="text-muted small-muted">اطلاعات پایه شخص حقوقی</small>
            </div>
            <div class="d-flex gap-2">
                <a asp-action="Edit" asp-route-id="@Model.Entity.Id" class="btn btn-outline-primary btn-sm px-3">ویرایش</a>
                <a asp-action="Index" class="btn btn-secondary btn-sm px-3">بازگشت</a>
            </div>
        </div>

        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-4 info-item"><strong>نام شرکت:</strong> @Model.Entity.CompanyName</div>
                <div class="col-md-4 info-item"><strong>نوع:</strong> @Model.Entity.CompanyType</div>
                <div class="col-md-4 info-item"><strong>شهر:</strong> @Model.Entity.City</div>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">راه‌های ارتباطی</h6>
                <small class="text-muted small-muted">تلفن، ایمیل، فکس، پیامک و واتساپ</small>
            </div>
            <a asp-action="AddContact" asp-route-legalEntityId="@Model.Entity.Id" class="btn btn-primary btn-sm px-3">افزودن</a>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle">
                    <thead>
                        <tr>
                            <th>عنوان</th>
                            <th>راه ارتباطی</th>
                            <th>پیامک</th>
                            <th>واتساپ</th>
                            <th>فکس</th>
                            <th>تلفن</th>
                            <th>ایمیل</th>
                            <th style="width:200px">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Entity.Contacts != null && Model.Entity.Contacts.Any())
                        {
                            foreach (var item in Model.Entity.Contacts.OrderBy(x => x.Id))
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@item.ContactValue</td>
                                    <td>@(item.HasSms ? "بله" : "-")</td>
                                    <td>@(item.HasWhatsApp ? "بله" : "-")</td>
                                    <td>@(item.IsFax ? "بله" : "-")</td>
                                    <td>@(item.IsPhone ? "بله" : "-")</td>
                                    <td>@(item.IsEmail ? "بله" : "-")</td>
                                    <td>
                                        <div class="entity-actions">
                                            <a asp-action="EditContact" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">ویرایش</a>
                                            <form asp-action="DeleteContact" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">حذف</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">راه ارتباطی ثبت نشده است.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">آدرس‌ها</h6>
                <small class="text-muted small-muted">آدرس‌های ثبت‌شده برای شخص حقوقی</small>
            </div>
            <a asp-action="AddAddress" asp-route-legalEntityId="@Model.Entity.Id" class="btn btn-primary btn-sm px-3">افزودن</a>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle">
                    <thead>
                        <tr>
                            <th>عنوان</th>
                            <th>آدرس</th>
                            <th>کدپستی</th>
                            <th style="width:200px">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Entity.Addresses != null && Model.Entity.Addresses.Any())
                        {
                            foreach (var item in Model.Entity.Addresses.OrderBy(x => x.Id))
                            {
                                <tr>
                                    <td>@item.Title</td>
                                    <td>@item.AddressText</td>
                                    <td>@item.PostalCode</td>
                                    <td>
                                        <div class="entity-actions">
                                            <a asp-action="EditAddress" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">ویرایش</a>
                                            <form asp-action="DeleteAddress" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">حذف</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">آدرسی ثبت نشده است.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">حساب‌های بانکی</h6>
                <small class="text-muted small-muted">شماره شبا و اطلاعات صاحب حساب</small>
            </div>
            <a asp-action="AddBankAccount" asp-route-legalEntityId="@Model.Entity.Id" class="btn btn-primary btn-sm px-3">افزودن</a>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle">
                    <thead>
                        <tr>
                            <th>شماره شبا</th>
                            <th>نام صاحب حساب</th>
                            <th>نام استعلام شده</th>
                            <th style="width:200px">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Entity.BankAccounts != null && Model.Entity.BankAccounts.Any())
                        {
                            foreach (var item in Model.Entity.BankAccounts.OrderBy(x => x.Id))
                            {
                                <tr>
                                    <td class="text-center">@item.Iban</td>
                                    <td>@item.AccountHolderName</td>
                                    <td>@item.VerifiedName</td>
                                    <td>
                                        <div class="entity-actions">
                                            <a asp-action="EditBankAccount" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">ویرایش</a>
                                            <form asp-action="DeleteBankAccount" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm">حذف</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-4">حساب بانکی ثبت نشده است.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
