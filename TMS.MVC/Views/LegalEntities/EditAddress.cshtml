@model TMS.MVC.Models.LegalEntityAddress

@{
    ViewData["Title"] = "ویرایش آدرس";
}

<style>
    .legal-entity-compact .form-label { margin-bottom: 0.25rem; font-size: 0.82rem; }
    .legal-entity-compact .form-control,
    .legal-entity-compact .btn { font-size: 0.82rem; }
    .legal-entity-compact .field-validation-valid,
    .legal-entity-compact .field-validation-error { font-size: 0.75rem; }
    .legal-entity-compact .card-header { padding-top: 0.65rem; padding-bottom: 0.65rem; }
    .legal-entity-compact .card-body { padding-top: 0.85rem; }
    .legal-entity-compact .small-muted { font-size: 0.78rem; }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">اشخاص حقوقی</a></li>
                    <li class="breadcrumb-item active">ویرایش آدرس</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid legal-entity-compact">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">ویرایش آدرس</h6>
                <small class="text-muted small-muted">ویرایش آدرس ثبت‌شده برای شخص حقوقی</small>
            </div>

        </div>

        <div class="card-body">
            <form asp-action="EditAddress" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <input asp-for="LegalEntityId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control form-control-sm" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="PostalCode" class="form-label"></label>
                        <input asp-for="PostalCode" class="form-control form-control-sm" />
                        <span asp-validation-for="PostalCode" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="AddressText" class="form-label"></label>
                        <textarea asp-for="AddressText" class="form-control form-control-sm" rows="4"></textarea>
                        <span asp-validation-for="AddressText" class="text-danger"></span>
                    </div>
                </div>

                <hr class="my-3" />

                <div class="d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary btn-sm px-3">ذخیره تغییرات</button>
                    <a asp-action="Details" asp-route-id="@Model.LegalEntityId" class="btn btn-secondary btn-sm px-3">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>
