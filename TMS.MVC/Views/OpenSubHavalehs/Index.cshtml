@using System.Globalization
@model TMS.MVC.ViewModels.OpenSubHavalehIndexViewModel

@{
    ViewData["Title"] = "درخواست های حمل";

    string ToJalali(DateTime? date)
    {
        if (!date.HasValue) return "-";
        var pc = new PersianCalendar();
        var d = date.Value;
        return $"{pc.GetYear(d):0000}/{pc.GetMonth(d):00}/{pc.GetDayOfMonth(d):00}";
    }

    string Amount(decimal amount, string? unit) => $"{amount:N0} {unit}";
}

<style>
    .open-subhavaleh-compact .form-label { margin-bottom: .25rem; font-size: .82rem; }
    .open-subhavaleh-compact .form-control,
    .open-subhavaleh-compact .form-select,
    .open-subhavaleh-compact .btn,
    .open-subhavaleh-compact .table,
    .open-subhavaleh-compact .badge { font-size: .82rem; }
    .open-subhavaleh-compact .table > :not(caption) > * > * { padding: .45rem .55rem; }
    .open-subhavaleh-compact .card-header { padding-top: .65rem; padding-bottom: .65rem; }
    .open-subhavaleh-compact .card-body { padding-top: .85rem; }
    .open-subhavaleh-compact .pagination .page-link { padding: .22rem .48rem; font-size: .78rem; }
    .open-subhavaleh-compact .small-muted { font-size: .78rem; }
    .open-subhavaleh-compact .route-text { max-width: 260px; white-space: normal; }
    .open-subhavaleh-compact .amount-cell { white-space: nowrap; }

    .route-mini {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        min-width: 190px;
    }

    .route-point {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        line-height: 1.35;
    }

        .route-point strong {
            display: block;
            font-size: 0.82rem;
            color: #343a40;
            font-weight: 600;
        }

    .route-label {
        display: inline-block;
        font-size: 0.68rem;
        color: #6c757d;
        margin-bottom: 0.05rem;
    }

    .route-dot {
        width: 0.55rem;
        height: 0.55rem;
        border-radius: 50%;
        flex: 0 0 0.55rem;
    }

    .route-origin .route-dot {
        background: #198754;
        box-shadow: 0 0 0 3px rgba(25, 135, 84, 0.12);
    }

    .route-destination .route-dot {
        background: #dc3545;
        box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.12);
    }

    .route-line {
        width: 1px;
        height: 0.55rem;
        margin-right: 0.25rem;
        background: repeating-linear-gradient( to bottom, #adb5bd 0, #adb5bd 3px, transparent 3px, transparent 6px );
    }

    .route-summary {
        margin-top: 0.15rem;
        padding: 0.25rem 0.45rem;
        border-radius: 0.5rem;
        background: #f8f9fa;
        color: #6c757d;
        font-size: 0.74rem;
        border: 1px dashed #dee2e6;
    }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li>
                    <li class="breadcrumb-item active">درخواست های حمل</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid open-subhavaleh-compact">
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success py-2 small">@TempData["Ok"]</div>
    }
    @if (TempData["Err"] != null)
    {
        <div class="alert alert-danger py-2 small">@TempData["Err"]</div>
    }

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">درخواست های حمل معتبر برای تخصیص</h6>
                <small class="text-muted small-muted">فقط درخواست های حملی نمایش داده می‌شوند که تاریخ امروز در بازه شروع و پایان بارگیری آن‌ها باشد و مقدار قابل تخصیص داشته باشند.</small>
            </div>
        </div>
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-2 mb-3">
                <input type="hidden" name="page" value="1" />
                <div class="col-md-9">
                    <label class="form-label">جستجو</label>
                    <input name="search" value="@Model.Search" class="form-control form-control-sm" placeholder="شماره حواله، عنوان، محصول، مبدا یا مقصد..." />
                </div>
                <div class="col-md-2">
                    <label class="form-label">تعداد</label>
                    <select name="pageSize" class="form-select form-select-sm">
                        @foreach (var size in new[] { 10, 20, 50, 100 })
                        {
                            if (Model.PageSize == size) { <option value="@size" selected>@size رکورد</option> }
                            else { <option value="@size">@size رکورد</option> }
                        }
                    </select>
                </div>
                <div class="col-md-1">
                    <label class="form-label d-block">&nbsp;</label>
                    <button type="submit" class="btn btn-info btn-sm w-100">فیلتر</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>حواله</th>
                            <th>عنوان</th>
                            <th>محصول</th>
                            <th>مسیر</th>
                            <th>بازه بارگیری</th>
                            <th>مقدار کل</th>
                            <th>تخصیص</th>
                            <th>درخواست‌های معلق</th>
                            <th>باقی‌مانده</th>
                            <th style="width: 120px;">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Any())
                        {
                            var rowNo = Model.RowNumberStart;
                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@rowNo</td>
                                    <td>@item.HavalehNumber</td>
                                    <td>@(item.Title ?? "-")</td>
                                    <td>@(item.ProductName ?? "-")</td>
                                    <td class="route-text">
                                        <div class="route-mini">
                                            <div class="route-point route-origin">
                                                <span class="route-dot"></span>
                                                <div>
                                                    <span class="route-label">مبدا</span>
                                                    <strong>@(item.OriginPlaceName ?? "-")</strong>
                                                </div>
                                            </div>

                                            <div class="route-line"></div>

                                            <div class="route-point route-destination">
                                                <span class="route-dot"></span>
                                                <div>
                                                    <span class="route-label">مقصد</span>
                                                    <strong>@(item.DestinationPlaceName ?? "-")</strong>
                                                </div>
                                            </div>

                                            @if (!string.IsNullOrWhiteSpace(item.RouteSummary))
                                            {
                                                <div class="route-summary">
                                                    @item.RouteSummary
                                                </div>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div>@ToJalali(item.StartDate)</div>
                                        <small class="text-muted">تا @ToJalali(item.EndDate)</small>
                                    </td>
                                    <td class="amount-cell">@Amount(item.RequestedCargoAmount, item.Unit)</td>
                                    <td class="amount-cell">@Amount(item.AssignedAmount, item.Unit)</td>
                                    <td class="amount-cell">@Amount(item.PendingRequestedAmount, item.Unit)</td>
                                    <td class="amount-cell fw-bold text-primary">@Amount(item.RemainingAssignableAmount, item.Unit)</td>
                                    <td>
                                        <a asp-action="Request" asp-route-subHavalehId="@item.Id" class="btn btn-primary btn-sm px-3 @(item.CanRequest ? "" : "disabled")">درخواست تخصیص</a>
                                    </td>
                                </tr>
                                rowNo++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="11" class="text-center text-muted py-4">در حال حاضر ریزحواله قابل درخواست وجود ندارد.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-2">
                    <div class="text-muted small">صفحه @Model.Page از @Model.TotalPages - تعداد کل: @Model.TotalItems</div>
                    <nav>
                        <ul class="pagination pagination-primary">
                            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")"><a class="page-link" asp-action="Index" asp-route-page="1" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">اول</a></li>
                            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")"><a class="page-link" asp-action="Index" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">قبلی</a></li>
                            @{ var startPage = Math.Max(1, Model.Page - 2); var endPage = Math.Min(Model.TotalPages, Model.Page + 2); }
                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")"><a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">@i</a></li>
                            }
                            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")"><a class="page-link" asp-action="Index" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">بعدی</a></li>
                            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")"><a class="page-link" asp-action="Index" asp-route-page="@Model.TotalPages" asp-route-pageSize="@Model.PageSize" asp-route-search="@Model.Search">آخر</a></li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>
