@model TMS.MVC.Models.ViewModels.ProductFormVm

@{
    ViewData["Title"] = "ویرایش محصول";
}


<style>
    .product-form-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .product-form-compact .form-control,
    .product-form-compact .form-select,
    .product-form-compact .btn,
    .product-form-compact .form-text,
    .product-form-compact .table {
        font-size: 0.82rem;
    }

    .product-form-compact .field-validation-valid,
    .product-form-compact .field-validation-error {
        font-size: 0.75rem;
    }

    .product-form-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .product-form-compact .card-body {
        padding-top: 0.85rem;
    }

    .product-form-compact .small-muted {
        font-size: 0.78rem;
    }

    .product-form-compact .properties-table > :not(caption) > * > * {
        padding: 0.4rem 0.45rem;
    }

    .product-form-compact .readonly-property-name {
        background-color: #f8f9fa;
    }
</style>


<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>

            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">داشبورد</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-action="Index">محصولات</a>
                    </li>
                    <li class="breadcrumb-item active">ویرایش محصول</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid product-form-compact">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">ویرایش محصول</h6>
                <small class="text-muted small-muted">ویرایش نام محصول و خصوصیات آن</small>
            </div>
        </div>

        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()

                <input asp-for="Id" type="hidden" />

                <div class="row g-2">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label">نام محصول <span class="required-star">*</span></label>
                        <input asp-for="Name" class="form-control form-control-sm" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                </div>

                <div class="card mt-3 mb-0">
                    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h6 class="mb-0">خصوصیات</h6>
                            <small class="text-muted small-muted">برای هر محصول می‌توانید هر تعداد خصوصیت با نام و مقدار تعریف کنید.</small>
                        </div>

                        <button type="button" class="btn btn-outline-primary btn-sm px-3" id="addPropertyRow">
                            افزودن خصوصیت
                        </button>
                    </div>

                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm align-middle properties-table mb-0">
                                <thead>
                                    <tr>
                                        <th style="width:38%;">نام خصوصیت</th>
                                        <th>مقدار</th>
                                        <th style="width:85px;">عملیات</th>
                                    </tr>
                                </thead>
                                <tbody id="propertiesBody">
                                    @for (var i = 0; i < Model.Properties.Count; i++)
                                    {
                                        var propertyName = Model.Properties[i].Name ?? "";
                                        var isDefault =
                                        propertyName == "چگالی / دانسیته" ||
                                        propertyName == "نوع بار" ||
                                        propertyName == "ماهیت بار" ||
                                        propertyName == "واحد اندازه‌گیری";

                                        <tr>
                                            <td>
                                                <input type="hidden" name="Properties[@i].Id" value="@Model.Properties[i].Id" />
                                                <input type="hidden" name="Properties[@i].DisplayOrder" value="@Model.Properties[i].DisplayOrder" />

                                                @if (isDefault)
                                                {
                                                    <input name="Properties[@i].Name"
                                                           value="@Model.Properties[i].Name"
                                                           class="form-control form-control-sm readonly-property-name"
                                                           readonly />
                                                    <span class="text-danger small field-validation-valid" data-valmsg-for="Properties[@i].Name" data-valmsg-replace="true"></span>
                                                }
                                                else
                                                {
                                                    <input name="Properties[@i].Name"
                                                           value="@Model.Properties[i].Name"
                                                           class="form-control form-control-sm"
                                                           placeholder="مثلاً رنگ، گرید، درصد خلوص..." />
                                                    <span class="text-danger small field-validation-valid" data-valmsg-for="Properties[@i].Name" data-valmsg-replace="true"></span>
                                                }
                                            </td>

                                            <td>
                                                @if (propertyName == "چگالی / دانسیته")
                                                {
                                                    <div class="input-group input-group-sm">
                                                        <input name="Properties[@i].Value"
                                                               value="@Model.Properties[i].Value"
                                                               class="form-control form-control-sm"
                                                               placeholder="مقدار چگالی..." />
                                                        <span class="input-group-text">کیلوگرم بر متر مکعب</span>
                                                    </div>
                                                }
                                                else if (propertyName == "نوع بار")
                                                {
                                                    <select name="Properties[@i].Value" class="form-select form-select-sm">
                                                        @if (Model.Properties[i].Value == "تمیز")
                                                        {
                                                            <option value="تمیز" selected>تمیز</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="تمیز">تمیز</option>
                                                        }

                                                        @if (Model.Properties[i].Value == "کثیف")
                                                        {
                                                            <option value="کثیف" selected>کثیف</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="کثیف">کثیف</option>
                                                        }
                                                    </select>
                                                }
                                                else if (propertyName == "ماهیت بار")
                                                {
                                                    <select name="Properties[@i].Value" class="form-select form-select-sm">
                                                        @foreach (var option in new[] { "جامد", "مایع", "گاز" })
                                                        {
                                                            if (Model.Properties[i].Value == option)
                                                            {
                                                                <option value="@option" selected>@option</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@option">@option</option>
                                                            }
                                                        }
                                                    </select>
                                                }
                                                else if (propertyName == "واحد اندازه‌گیری")
                                                {
                                                    <select name="Properties[@i].Value" class="form-select form-select-sm">
                                                        @foreach (var option in new[] { "کیلوگرم", "لیتر" })
                                                        {
                                                            if (Model.Properties[i].Value == option)
                                                            {
                                                                <option value="@option" selected>@option</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@option">@option</option>
                                                            }
                                                        }
                                                    </select>
                                                }
                                                else
                                                {
                                                    <input name="Properties[@i].Value"
                                                           value="@Model.Properties[i].Value"
                                                           class="form-control form-control-sm"
                                                           placeholder="مقدار خصوصیت..." />
                                                }
                                                <span class="text-danger small field-validation-valid" data-valmsg-for="Properties[@i].Value" data-valmsg-replace="true"></span>
                                            </td>

                                            <td>
                                                @if (isDefault)
                                                {
                                                    <span class="badge badge-light-primary">پیش‌فرض</span>
                                                }
                                                else
                                                {
                                                    <button type="button" class="btn btn-outline-danger btn-sm remove-property-row">
                                                        حذف
                                                    </button>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <hr class="my-3" />

                <div class="d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary btn-sm px-3">ذخیره تغییرات</button>
                    <a asp-action="Index" class="btn btn-secondary btn-sm px-3">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const body = document.getElementById('propertiesBody');
            const addButton = document.getElementById('addPropertyRow');

            function reindexRows() {
                const rows = body.querySelectorAll('tr');

                rows.forEach(function (row, index) {
                    row.querySelectorAll('input, select').forEach(function (input) {
                        const name = input.getAttribute('name');
                        if (!name) return;

                        input.setAttribute('name', name.replace(/Properties\[\d+\]/, 'Properties[' + index + ']'));
                    });

                    row.querySelectorAll('[data-valmsg-for]').forEach(function (message) {
                        const forName = message.getAttribute('data-valmsg-for');
                        if (!forName) return;

                        message.setAttribute('data-valmsg-for', forName.replace(/Properties\[\d+\]/, 'Properties[' + index + ']'));
                    });

                    const orderInput = row.querySelector('input[name="Properties[' + index + '].DisplayOrder"]');
                    if (orderInput) {
                        orderInput.value = index + 1;
                    }
                });
            }

            addButton.addEventListener('click', function () {
                const index = body.querySelectorAll('tr').length;

                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>
                        <input type="hidden" name="Properties[${index}].Id" value="0" />
                        <input type="hidden" name="Properties[${index}].DisplayOrder" value="${index + 1}" />
                        <input name="Properties[${index}].Name"
                               class="form-control form-control-sm"
                               placeholder="مثلاً رنگ، گرید، درصد خلوص..." />
                        <span class="text-danger small field-validation-valid" data-valmsg-for="Properties[${index}].Name" data-valmsg-replace="true"></span>
                    </td>
                    <td>
                        <input name="Properties[${index}].Value"
                               class="form-control form-control-sm"
                               placeholder="مقدار خصوصیت..." />
                        <span class="text-danger small field-validation-valid" data-valmsg-for="Properties[${index}].Value" data-valmsg-replace="true"></span>
                    </td>
                    <td>
                        <button type="button" class="btn btn-outline-danger btn-sm remove-property-row">
                            حذف
                        </button>
                    </td>`;

                body.appendChild(tr);
            });

            body.addEventListener('click', function (e) {
                const btn = e.target.closest('.remove-property-row');
                if (!btn) return;

                btn.closest('tr').remove();
                reindexRows();
            });
        })();
    </script>
}
