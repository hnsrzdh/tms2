@model TMS.MVC.Models.ViewModels.CityFormVm
@using System.Text.Json

@{
    ViewData["Title"] = "ویرایش اطلاعات شهر";
    var countryProvinceJson = JsonSerializer.Serialize(Model.CountryProvinceMap);
}

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item active">داشبورد</li>
                    <li class="breadcrumb-item">مناطق</li>
                </ol>
            </div>

        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="card shadow-sm rounded-0">
        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="CountryName" class="form-label"></label>
                        <input asp-for="CountryName" class="form-control" list="countryList" id="CountryName" autocomplete="off" />
                        <datalist id="countryList">
                            @foreach (var item in Model.Countries)
                            {
                                <option value="@item.Text"></option>
                            }
                        </datalist>
                        <span asp-validation-for="CountryName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ProvinceName" class="form-label"></label>
                        <input asp-for="ProvinceName" class="form-control" list="provinceList" id="ProvinceName" autocomplete="off" />
                        <datalist id="provinceList">
                            @foreach (var item in Model.Provinces)
                            {
                                <option value="@item.Text"></option>
                            }
                        </datalist>
                        <span asp-validation-for="ProvinceName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Latitude" class="form-label"></label>
                        <input asp-for="Latitude" class="form-control" />
                        <span asp-validation-for="Latitude" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-3">
                        <label asp-for="Longitude" class="form-label"></label>
                        <input asp-for="Longitude" class="form-control" />
                        <span asp-validation-for="Longitude" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">ذخیره تغییرات</button>
                    <a asp-action="Index" class="btn btn-secondary">بازگشت</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const countryProvinceMap = @Html.Raw(countryProvinceJson);

        function refreshProvinceList() {
            const countryInput = document.getElementById('CountryName');
            const provinceInput = document.getElementById('ProvinceName');
            const provinceList = document.getElementById('provinceList');

            const selectedCountry = (countryInput.value || '').trim();

            while (provinceList.firstChild) {
                provinceList.removeChild(provinceList.firstChild);
            }

            const provinces = countryProvinceMap[selectedCountry] || [];

            for (const province of provinces) {
                const option = document.createElement('option');
                option.value = province;
                provinceList.appendChild(option);
            }

            if (provinceInput.value) {
                const exists = provinces.includes(provinceInput.value.trim());
                if (!exists) {
                    provinceInput.value = '';
                }
            }
        }

        document.getElementById('CountryName').addEventListener('input', refreshProvinceList);
        document.addEventListener('DOMContentLoaded', refreshProvinceList);
    </script>
}