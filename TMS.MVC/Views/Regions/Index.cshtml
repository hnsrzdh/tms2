@model TMS.MVC.Models.ViewModels.PlaceIndexVm

@{
    ViewData["Title"] = "لیست مکان‌ها";
}

<style>
    .place-index-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .place-index-compact .form-control,
    .place-index-compact .form-select,
    .place-index-compact .btn,
    .place-index-compact .table,
    .place-index-compact .badge {
        font-size: 0.82rem;
    }

        .place-index-compact .table > :not(caption) > * > * {
            padding: 0.45rem 0.55rem;
        }

    .place-index-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .place-index-compact .card-body {
        padding-top: 0.85rem;
    }

    .place-index-compact .pagination .page-link {
        padding: 0.22rem 0.48rem;
        font-size: 0.78rem;
    }

    .place-index-compact .small-muted {
        font-size: 0.78rem;
    }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">داشبورد</a>
                    </li>
                    <li class="breadcrumb-item active">مکان‌ها</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid place-index-compact">
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success py-2 small">@TempData["Ok"]</div>
    }

    @if (TempData["Err"] != null)
    {
        <div class="alert alert-danger py-2 small">@TempData["Err"]</div>
    }

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">مکان‌ها</h6>
                <small class="text-muted small-muted">تعریف مکان‌های دقیق برای بارگیری، تخلیه و مسیریابی</small>
            </div>

            <div class="d-flex gap-2">
                <button type="button"
                        class="btn btn-outline-success btn-sm px-3"
                        data-bs-toggle="modal"
                        data-bs-target="#importExcelModal">
                    ایمپورت از اکسل
                </button>

                <a asp-action="Create" class="btn btn-primary btn-sm px-3">
                    تعریف مکان جدید
                </a>
            </div>
        </div>

        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-2 mb-3">
                <div class="col-md-3">
                    <label class="form-label">جستجو</label>
                    <input name="search"
                           value="@Model.Search"
                           class="form-control form-control-sm"
                           placeholder="نام مکان، شهر، آدرس..." />
                </div>

                <div class="col-md-2">
                    <label class="form-label">کشور</label>
                    <select name="countryFilter" class="form-select form-select-sm">
                        <option value="">همه کشورها</option>
                        @foreach (var item in Model.Countries)
                        {
                            <option value="@item.Value" selected="@(Model.CountryFilter == item.Value)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">استان</label>
                    <select name="provinceFilter" class="form-select form-select-sm">
                        <option value="">همه استان‌ها</option>
                        @foreach (var item in Model.Provinces)
                        {
                            <option value="@item.Value" selected="@(Model.ProvinceFilter == item.Value)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">شهر</label>
                    <select name="cityFilter" class="form-select form-select-sm">
                        <option value="">همه شهرها</option>
                        @foreach (var item in Model.Cities)
                        {
                            <option value="@item.Value" selected="@(Model.CityFilter == item.Value)">
                                @item.Text
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">تعداد</label>
                    <select name="pageSize" class="form-select form-select-sm">
                        @foreach (var size in new[] { 10, 20, 50, 100 })
                        {
                            <option value="@size" selected="@(Model.PageSize == size)">
                                @size رکورد
                            </option>
                        }
                    </select>
                </div>

                <div class="col-md-1">
                    <label class="form-label d-block">&nbsp;</label>
                    <button type="submit" class="btn btn-info btn-sm w-100">
                        فیلتر
                    </button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle">
                    <thead>
                        <tr>
                            <th style="width:55px">#</th>
                            <th>کشور</th>
                            <th>استان</th>
                            <th>شهر</th>
                            <th>مکان</th>
                            <th>مختصات</th>
                            <th>وضعیت</th>
                            <th style="width:145px">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Any())
                        {
                            var row = Model.RowNumberStart;

                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@row</td>
                                    <td>@item.CountryName</td>
                                    <td>@item.ProvinceName</td>
                                    <td>@item.CityName</td>
                                    <td>
                                        <div class="fw-bold">@item.Name</div>
                                        @if (!string.IsNullOrWhiteSpace(item.Address))
                                        {
                                            <small class="text-muted">@item.Address</small>
                                        }
                                    </td>
                                    <td>
                                        @if (item.Latitude.HasValue && item.Longitude.HasValue)
                                        {
                                            <span dir="ltr">
                                                @item.Latitude.Value.ToString("0.0000000"),
                                                @item.Longitude.Value.ToString("0.0000000")
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.IsActive)
                                        {
                                            <span class="badge bg-success">فعال</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">غیرفعال</span>
                                        }
                                    </td>
                                    <td>
                                        <div>
                                            <a asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-outline-primary btn-sm">
                                                ویرایش
                                            </a>

                                            <button type="button"
                                                    class="btn btn-outline-danger btn-sm"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#deleteModal_@item.Id">
                                                حذف
                                            </button>
                                        </div>

                                        <div class="modal fade" id="deleteModal_@item.Id" tabindex="-1">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content">
                                                    <form asp-action="Delete" method="post">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.Id" />

                                                        <div class="modal-header py-2">
                                                            <h6 class="modal-title">حذف مکان</h6>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>

                                                        <div class="modal-body small">
                                                            <p>آیا از حذف این مکان مطمئن هستید؟</p>
                                                            <div class="alert alert-warning py-2 mb-0">
                                                                @item.CountryName / @item.ProvinceName / @item.CityName / @item.Name
                                                            </div>
                                                        </div>

                                                        <div class="modal-footer py-2 gap-2">
                                                            <button type="submit" class="btn btn-danger btn-sm px-3">حذف</button>
                                                            <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">انصراف</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>

                                row++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    داده‌ای یافت نشد.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-2">
                    <div class="text-muted small">
                        صفحه @Model.Page از @Model.TotalPages - تعداد کل: @Model.TotalItems
                    </div>

                    <nav>
                        <ul class="pagination pagination-primary">
                            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="1"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-search="@Model.Search"
                                   asp-route-countryFilter="@Model.CountryFilter"
                                   asp-route-provinceFilter="@Model.ProvinceFilter"
                                   asp-route-cityFilter="@Model.CityFilter">
                                    اول
                                </a>
                            </li>

                            <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(Model.Page - 1)"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-search="@Model.Search"
                                   asp-route-countryFilter="@Model.CountryFilter"
                                   asp-route-provinceFilter="@Model.ProvinceFilter"
                                   asp-route-cityFilter="@Model.CityFilter">
                                    قبلی
                                </a>
                            </li>

                            @{
                                var startPage = Math.Max(1, Model.Page - 2);
                                var endPage = Math.Min(Model.TotalPages, Model.Page + 2);
                            }

                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-pageSize="@Model.PageSize"
                                       asp-route-search="@Model.Search"
                                       asp-route-countryFilter="@Model.CountryFilter"
                                       asp-route-provinceFilter="@Model.ProvinceFilter"
                                       asp-route-cityFilter="@Model.CityFilter">
                                        @i
                                    </a>
                                </li>
                            }

                            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(Model.Page + 1)"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-search="@Model.Search"
                                   asp-route-countryFilter="@Model.CountryFilter"
                                   asp-route-provinceFilter="@Model.ProvinceFilter"
                                   asp-route-cityFilter="@Model.CityFilter">
                                    بعدی
                                </a>
                            </li>

                            <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@Model.TotalPages"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-search="@Model.Search"
                                   asp-route-countryFilter="@Model.CountryFilter"
                                   asp-route-provinceFilter="@Model.ProvinceFilter"
                                   asp-route-cityFilter="@Model.CityFilter">
                                    آخر
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="importExcelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="ImportExcel" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <div class="modal-header py-2">
                    <h6 class="modal-title">ایمپورت مکان‌ها از اکسل</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body small">
                    <div class="mb-3">
                        <label class="form-label">فایل اکسل</label>
                        <input type="file"
                               name="excelFile"
                               class="form-control form-control-sm"
                               accept=".xlsx,.xls" />
                    </div>

                    <div class="alert alert-info py-2 mb-0">
                        <div>ستون 1: کشور</div>
                        <div>ستون 2: استان</div>
                        <div>ستون 3: شهر</div>
                        <div>ستون 4: نام مکان</div>
                        <div>ستون 5: عرض جغرافیایی</div>
                        <div>ستون 6: طول جغرافیایی</div>
                        <div>ستون 7: آدرس / توضیحات</div>
                    </div>
                </div>

                <div class="modal-footer py-2">
                    <button type="submit" class="btn btn-success btn-sm px-3">ایمپورت</button>
                    <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">انصراف</button>
                </div>
            </form>
        </div>
    </div>
</div>