@using Microsoft.AspNetCore.Identity
@using TMS.MVC.Models
@inject UserManager<ApplicationUser> UserManager

@{
    var currentUser = User?.Identity?.IsAuthenticated == true
        ? await UserManager.GetUserAsync(User)
        : null;

    var currentUserFullName = currentUser == null
        ? ""
        : $"{currentUser.FirstName ?? ""} {currentUser.LastName ?? ""}".Trim();

    if (string.IsNullOrWhiteSpace(currentUserFullName))
    {
        currentUserFullName = "کاربر";
    }
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - آرناپترو لیا</title>

    <link rel="icon" href="~/assets/images/favicon.png" type="image/x-icon">
    <link rel="shortcut icon" href="~/assets/images/favicon.png" type="image/x-icon">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="">

    <link rel="stylesheet" href="~/assets/css/vendors/flag-icon.css">
    <link rel="stylesheet" href="~/assets/css/iconly-icon.css">
    <link rel="stylesheet" href="~/assets/css/bulk-style.css">
    <link rel="stylesheet" href="~/assets/css/themify.css">
    <link rel="stylesheet" href="~/assets/css/fontawesome-min.css">
    <link rel="stylesheet" type="text/css" href="~/assets/css/vendors/weather-icons/weather-icons.min.css">
    <link rel="stylesheet" type="text/css" href="~/assets/css/vendors/scrollbar.css">
    <link rel="stylesheet" type="text/css" href="~/assets/css/vendors/slick.css">
    <link rel="stylesheet" type="text/css" href="~/assets/css/vendors/slick-theme.css">

    <link id="color" rel="stylesheet" href="~/assets/css/color-1.css" media="screen">
    <link rel="stylesheet" href="~/assets/css/style.css">
    <link rel="stylesheet" href="~/assets/css/site.css">

    <style>
        .sidebar-link .sidebar-fa-icon {
            width: 22px;
            min-width: 22px;
            height: 22px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
            margin-left: 10px;
            color: currentColor;
        }

        .profile-body .profile-fa-icon {
            width: 20px;
            min-width: 20px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-left: 8px;
            color: currentColor;
        }

        .profile-logout-form button {
            color: inherit;
            font-size: inherit;
            line-height: inherit;
        }

            .profile-logout-form button:hover {
                color: var(--theme-default);
            }

        .header-icon-btn {
            width: 38px;
            height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 17px;
        }

        .logo-wrapper a {
            text-decoration: none;
        }

        .required-star {
            color: #dc3545;
            font-weight: 700;
            margin-right: .15rem;
        }
    </style>
</head>

