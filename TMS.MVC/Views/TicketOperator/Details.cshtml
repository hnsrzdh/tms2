@using System.Globalization
@using TMS.MVC.Models
@model TMS.MVC.ViewModels.TicketDetailsViewModel

@{
    ViewData["Title"] = "جزئیات تیکت";
    string ToJalali(DateTime? date)
    {
        if (!date.HasValue) return "-";
        var pc = new PersianCalendar();
        var d = date.Value;
        return $"{pc.GetYear(d):0000}/{pc.GetMonth(d):00}/{pc.GetDayOfMonth(d):00}";
    }
}

<style>
    .ticket-details-compact .form-label { margin-bottom: .25rem; font-size: .82rem; }
    .ticket-details-compact .form-control,
    .ticket-details-compact .form-select,
    .ticket-details-compact .btn,
    .ticket-details-compact .badge { font-size: .82rem; }
    .ticket-details-compact .card-header { padding-top: .65rem; padding-bottom: .65rem; }
    .ticket-details-compact .card-body { padding-top: .85rem; }
    .ticket-details-compact .small-muted { font-size: .78rem; }
    .ticket-details-compact .summary-box { border: 1px solid #e5e7eb; border-radius: .75rem; padding: .7rem .8rem; background: #f8f9fa; height: 100%; }
    .ticket-details-compact .summary-box small { display: block; color: #6c757d; font-size: .76rem; margin-bottom: .2rem; }
    .ticket-details-compact .summary-box .value { display: block; font-weight: 700; color: #343a40; }
    .ticket-message { border: 1px solid #e5e7eb; border-radius: .75rem; padding: .7rem .8rem; margin-bottom: .6rem; background: #fff; }
    .ticket-message.operator { background: rgba(13, 110, 253, .04); border-color: rgba(13, 110, 253, .18); }
    .ticket-message .message-meta { font-size: .76rem; color: #6c757d; margin-bottom: .35rem; display:flex; justify-content:space-between; gap:.5rem; flex-wrap:wrap; }
    .ticket-message .message-body { white-space: pre-wrap; font-size:.84rem; line-height:1.8; }
</style>

<div class="container-fluid"><div class="page-title"><div class="row"><div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div><div class="col-sm-6 col-12"><ol class="breadcrumb"><li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li><li class="breadcrumb-item"><a asp-action="Index">مدیریت تیکت‌ها</a></li><li class="breadcrumb-item active">جزئیات</li></ol></div></div></div></div>

<div class="container-fluid ticket-details-compact">
    @if (TempData["Ok"] != null) { <div class="alert alert-success py-2 small">@TempData["Ok"]</div> }
    @if (TempData["Err"] != null) { <div class="alert alert-danger py-2 small">@TempData["Err"]</div> }

    <div class="row g-2 mb-3">
        <div class="col-md-3"><div class="summary-box"><small>وضعیت</small><span class="value"><span class="badge @Model.StatusBadgeClass">@Model.StatusDisplay</span></span></div></div>
        <div class="col-md-3"><div class="summary-box"><small>اولویت</small><span class="value"><span class="badge @Model.PriorityBadgeClass">@Model.PriorityDisplay</span></span></div></div>
        <div class="col-md-3"><div class="summary-box"><small>ثبت‌کننده</small><span class="value">@(Model.CreatedByName ?? "-")</span></div></div>
        <div class="col-md-3"><div class="summary-box"><small>آخرین بروزرسانی</small><span class="value">@ToJalali(Model.UpdatedAt)</span></div></div>
    </div>

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2"><div><h6 class="mb-0">@Model.Title</h6><small class="text-muted small-muted">دسته‌بندی: @(Model.Category ?? "-")</small></div><div class="d-flex gap-2"><a asp-action="Index" class="btn btn-secondary btn-sm px-3">بازگشت</a></div></div>
        <div class="card-body">
            @if (Model.ClosedAt.HasValue)
            {
                <div class="alert alert-info py-2 small">این تیکت در تاریخ @ToJalali(Model.ClosedAt) بسته شده است. توضیح: @(Model.CloseNote ?? "-")</div>
            }
            @foreach (var msg in Model.Messages)
            {
                <div class="ticket-message @(msg.IsOperatorReply ? "operator" : "")">
                    <div class="message-meta"><span><strong>@msg.SenderName</strong> @(msg.IsOperatorReply ? "(اپراتور)" : "")</span><span>@ToJalali(msg.CreatedAt)</span></div>
                    <div class="message-body">@msg.Body</div>
                </div>
            }
        </div>
    </div>

    @if (Model.CanReply)
    {
        <div class="card mb-3">
            <div class="card-header"><h6 class="mb-0">ثبت پاسخ</h6><small class="text-muted small-muted">پاسخ شما برای کاربر ارسال می‌شود.</small></div>
            <div class="card-body">
                <form asp-action="Reply" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Reply.TicketId" name="TicketId" />
                    <textarea name="Body" class="form-control form-control-sm" rows="5" placeholder="متن پاسخ..."></textarea>
                    <div class="mt-2 d-flex justify-content-end gap-2"><button type="submit" class="btn btn-primary btn-sm px-3">ارسال پاسخ</button></div>
                </form>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-header"><h6 class="mb-0">مدیریت وضعیت</h6><small class="text-muted small-muted">اپراتور می‌تواند وضعیت تیکت را تغییر دهد.</small></div>
            <div class="card-body">
                <form asp-action="ChangeStatus" method="post" class="row g-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="TicketId" value="@Model.Id" />
                    <div class="col-md-3">
                        <label class="form-label">وضعیت</label>
                        <select name="Status" class="form-select form-select-sm">
                            <option value="Open">باز</option>
                            <option value="WaitingForOperator">در انتظار اپراتور</option>
                            <option value="WaitingForUser">در انتظار کاربر</option>
                            <option value="Closed">بسته شده</option>
                            <option value="Cancelled">لغو شده</option>
                        </select>
                    </div>
                    <div class="col-md-7">
                        <label class="form-label">توضیح</label>
                        <input name="Note" class="form-control form-control-sm" placeholder="توضیح اختیاری برای بستن یا لغو تیکت..." />
                    </div>
                    <div class="col-md-2">
                        <label class="form-label d-block">&nbsp;</label>
                        <button type="submit" class="btn btn-success btn-sm w-100">ثبت وضعیت</button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
