@using TMS.MVC.Models
@model TMS.MVC.ViewModels.TicketCreateViewModel

@{
    ViewData["Title"] = "ثبت تیکت جدید";
}

<style>
    .ticket-form-compact .form-label { margin-bottom: .25rem; font-size: .82rem; }
    .ticket-form-compact .form-control,
    .ticket-form-compact .form-select,
    .ticket-form-compact .btn { font-size: .82rem; }
    .ticket-form-compact .card-header { padding-top: .65rem; padding-bottom: .65rem; }
    .ticket-form-compact .card-body { padding-top: .85rem; }
    .ticket-form-compact span.text-danger { font-size: .75rem; }
    .ticket-form-compact .small-muted { font-size: .78rem; }
</style>

<div class="container-fluid"><div class="page-title"><div class="row"><div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div><div class="col-sm-6 col-12"><ol class="breadcrumb"><li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li><li class="breadcrumb-item"><a asp-action="Index">تیکت‌های من</a></li><li class="breadcrumb-item active">ثبت تیکت</li></ol></div></div></div></div>

<div class="container-fluid ticket-form-compact">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
        <div class="card">
            <div class="card-header"><h6 class="mb-0">اطلاعات تیکت</h6><small class="text-muted small-muted">درخواست یا مشکل خود را با جزئیات کافی ثبت کنید.</small></div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-md-6"><label asp-for="Title" class="form-label"></label><input asp-for="Title" class="form-control form-control-sm" /><span asp-validation-for="Title" class="text-danger"></span></div>
                    <div class="col-md-3"><label asp-for="Category" class="form-label"></label><input asp-for="Category" class="form-control form-control-sm" placeholder="مثلاً مالی، حواله، ناوگان..." /><span asp-validation-for="Category" class="text-danger"></span></div>
                    <div class="col-md-3"><label asp-for="Priority" class="form-label"></label><select asp-for="Priority" class="form-select form-select-sm"><option value="Low">کم</option><option value="Normal">معمولی</option><option value="High">زیاد</option><option value="Urgent">فوری</option></select></div>
                    <div class="col-md-12"><label asp-for="Body" class="form-label"></label><textarea asp-for="Body" class="form-control form-control-sm" rows="7"></textarea><span asp-validation-for="Body" class="text-danger"></span></div>
                </div>
            </div>
        </div>
        <div class="mt-3 d-flex justify-content-end gap-2"><button type="submit" class="btn btn-primary btn-sm px-3">ثبت تیکت</button><a asp-action="Index" class="btn btn-secondary btn-sm px-3">انصراف</a></div>
    </form>
</div>
