@model TMS.MVC.ViewModels.Tickets.TicketDetailsVm
@using TMS.MVC.Models.Tickets
@using TMS.MVC.Infrastructure

@{
    ViewData["Title"] = "جزئیات تیکت";
    var t = Model.Ticket;
    bool isAdmin = User.IsInRole(AppRoles.SystemAdmin);
}

<h1 class="mb-3">جزئیات تیکت</h1>

@if (TempData["Ok"] != null)
{
    <div class="alert alert-success">@TempData["Ok"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-md-4">
                <div class="text-muted">کد</div>
                <div class="fw-bold">@t.Code</div>
            </div>
            <div class="col-md-8">
                <div class="text-muted">عنوان</div>
                <div class="fw-bold">@t.Subject</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted">وضعیت</div>
                <div class="fw-bold">@t.Status</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted">اولویت</div>
                <div class="fw-bold">@t.Priority</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted">دسته</div>
                <div class="fw-bold">@(@t.Category?.Title ?? "—")</div>
            </div>
            <div class="col-md-3">
                <div class="text-muted">ثبت</div>
                <div class="fw-bold">@t.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(t.RelatedEntityType) && t.RelatedEntityId != null)
            {
                <div class="col-12">
                    <div class="text-muted">مرتبط با</div>
                    <div class="fw-bold">@t.RelatedEntityType #@t.RelatedEntityId</div>
                </div>
            }
        </div>
    </div>
</div>

@if (isAdmin)
{
    <div class="card shadow-sm mb-3">
        <div class="card-body">
            <div class="fw-bold mb-2">مدیریت ادمین</div>

            <form method="post" asp-controller="AdminTickets" asp-action="ChangeStatus" asp-route-id="@t.Id" class="row g-2 align-items-end">
                @Html.AntiForgeryToken()
                <div class="col-md-4">
                    <label class="form-label">وضعیت</label>
                    <select name="status" class="form-select">
                        @foreach (var s in Enum.GetNames(typeof(TicketStatus)))
                        {
                            <option value="@s" selected="@(t.Status.ToString() == s)">@s</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">یادداشت</label>
                    <input name="note" class="form-control" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-outline-primary w-100" type="submit">ثبت</button>
                </div>
            </form>

            <hr />

            <form method="post" asp-controller="AdminTickets" asp-action="AddInternalNote" asp-route-id="@t.Id">
                @Html.AntiForgeryToken()
                <label class="form-label">یادداشت داخلی</label>
                <textarea name="body" class="form-control" rows="3"></textarea>
                <div class="mt-2">
                    <button class="btn btn-outline-secondary" type="submit">ثبت یادداشت داخلی</button>
                </div>
            </form>
        </div>
    </div>
}

<div class="card shadow-sm mb-3">
    <div class="card-body">
        <div class="fw-bold mb-2">گفتگو</div>

        @foreach (var m in Model.Messages)
        {
            <div class="border rounded p-3 mb-3">
                <div class="d-flex justify-content-between">
                    <div class="fw-bold">@m.AuthorDisplay</div>
                    <div class="text-muted small">@m.Message.CreatedAt.ToString("yyyy-MM-dd HH:mm")</div>
                </div>

                @if (m.Message.IsInternal)
                {
                    <div class="text-danger small">یادداشت داخلی (فقط ادمین)</div>
                }

                <div class="mt-2" style="white-space:pre-wrap;">@m.Message.Body</div>

                @if (m.Attachments.Count > 0)
                {
                    <div class="mt-2">
                        <div class="text-muted small">ضمیمه‌ها:</div>
                        <ul class="mb-0">
                            @foreach (var a in m.Attachments)
                            {
                                <li>
                                    <a href="@a.FilePath" target="_blank">@((a.OriginalFileName ?? "فایل"))</a>
                                    <span class="text-muted small">(@(a.SizeBytes / 1024) KB)</span>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <div class="fw-bold mb-2">ارسال پیام</div>

        <form method="post" enctype="multipart/form-data" asp-action="AddMessage" asp-route-id="@t.Id">
            @Html.AntiForgeryToken()

            <div class="mb-2">
                <label class="form-label">متن پیام</label>
                <textarea name="body" class="form-control" rows="4"></textarea>
            </div>

            <div class="mb-2">
                <label class="form-label">ضمیمه‌ها (اختیاری)</label>
                <input type="file" name="files" multiple class="form-control" />
            </div>

            <button class="btn btn-primary" type="submit">ارسال</button>
            <a class="btn btn-outline-secondary" asp-action="MyTickets">بازگشت</a>
        </form>
    </div>
</div>