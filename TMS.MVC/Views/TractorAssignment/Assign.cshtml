@model TMS.MVC.ViewModels.TractorAssignmentUpsertViewModel

@{
    ViewData["Title"] = "تخصیص کشنده جدید";
}

<style>
    .assignment-form-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .assignment-form-compact .form-control,
    .assignment-form-compact .form-select,
    .assignment-form-compact .input-group-text,
    .assignment-form-compact .btn,
    .assignment-form-compact .table,
    .assignment-form-compact .badge {
        font-size: 0.82rem;
    }

    .assignment-form-compact .table > :not(caption) > * > * {
        padding: 0.45rem 0.55rem;
    }

    .assignment-form-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .assignment-form-compact .card-body {
        padding-top: 0.85rem;
    }

    .assignment-form-compact .small-muted {
        font-size: 0.78rem;
    }

    .assignment-form-compact .field-validation-valid,
    .assignment-form-compact .field-validation-error,
    .assignment-form-compact span.text-danger {
        font-size: 0.75rem;
    }

    .assignment-form-compact .summary-box {
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 0.65rem 0.75rem;
        background: #f8f9fa;
        height: 100%;
    }

    .assignment-form-compact .summary-box small {
        font-size: 0.76rem;
    }

    .assignment-form-compact .summary-box .value {
        display: block;
        margin-top: 0.25rem;
        font-weight: 600;
        color: #495057;
    }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">داشبورد</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-controller="Havalehs" asp-action="Index">حواله‌ها</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-controller="Havalehs" asp-action="SubHavalehDetails" asp-route-id="@Model.SubHavalehId">زیرحواله</a>
                    </li>
                    <li class="breadcrumb-item active">تخصیص کشنده</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid assignment-form-compact">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">تخصیص کشنده جدید</h6>
                <small class="text-muted small-muted">کشنده و راننده را برای این زیرحواله انتخاب کنید.</small>
            </div>

            <a asp-action="Index"
               asp-route-subHavalehId="@Model.SubHavalehId"
               class="btn btn-secondary btn-sm px-3">
                بازگشت
            </a>
        </div>

        <div class="card-body">
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <div class="summary-box">
                        <small class="text-muted">شماره حواله</small>
                        <span class="value">@Model.HavalehNumber</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="summary-box">
                        <small class="text-muted">زیرحواله</small>
                        <span class="value">@(Model.SubHavalehTitle ?? "-")</span>
                    </div>
                </div>
            </div>

            <form asp-action="Assign" method="post" id="assignmentForm">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="SubHavalehId" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="alert alert-info py-2 small mb-3">
                    فقط کشنده‌ها و رانندگانی که در سفر فعال دیگری نیستند در جستجو نمایش داده می‌شوند.
                </div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">کشنده <span class="text-danger">*</span></label>
                        <div class="input-group input-group-sm">
                            <input asp-for="TractorId" type="hidden" />
                            <input asp-for="TractorPlateNumber" class="form-control form-control-sm" readonly placeholder="انتخاب کنید..." />
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="openTractorModal">انتخاب</button>
                        </div>
                        <span asp-validation-for="TractorId" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">راننده</label>
                        <div class="input-group input-group-sm">
                            <input asp-for="DriverProfileId" type="hidden" />
                            <input asp-for="DriverFullName" class="form-control form-control-sm" readonly placeholder="انتخاب کنید..." />
                            <button type="button" class="btn btn-outline-secondary btn-sm" id="openDriverModal">انتخاب</button>
                        </div>
                    </div>

                    <div class="col-12">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control form-control-sm" rows="3" placeholder="توضیحات داخلی تخصیص، در صورت نیاز..."></textarea>
                    </div>
                </div>

                <div class="mt-3 d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary btn-sm px-3">ذخیره</button>
                    <a asp-action="Index" asp-route-subHavalehId="@Model.SubHavalehId" class="btn btn-secondary btn-sm px-3">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="tractorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">انتخاب کشنده</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"></button>
            </div>
            <div class="modal-body small">
                <input type="text" id="tractorSearchInput" class="form-control form-control-sm mb-2" placeholder="حداقل ۲ کاراکتر از پلاک را وارد کنید..." />
                <small class="text-muted d-block mb-3">فقط کشنده‌های فعال و آزاد نمایش داده می‌شوند.</small>
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle">
                        <thead><tr><th>پلاک</th><th>نوع</th><th>ظرفیت</th><th style="width:90px;">انتخاب</th></tr></thead>
                        <tbody id="tractorSearchResults">
                            <tr><td colspan="4" class="text-muted text-center py-3">لطفاً حداقل ۲ کاراکتر برای جستجو وارد کنید.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="driverModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">انتخاب راننده</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"></button>
            </div>
            <div class="modal-body small">
                <input type="text" id="driverSearchInput" class="form-control form-control-sm mb-2" placeholder="حداقل ۲ کاراکتر از نام راننده را وارد کنید..." />
                <small class="text-muted d-block mb-3">فقط رانندگان آزاد و غیرمسدود نمایش داده می‌شوند.</small>
                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle">
                        <thead><tr><th>نام</th><th>کد ملی</th><th>شماره تماس</th><th style="width:90px;">انتخاب</th></tr></thead>
                        <tbody id="driverSearchResults">
                            <tr><td colspan="4" class="text-muted text-center py-3">لطفاً حداقل ۲ کاراکتر برای جستجو وارد کنید.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const tractorModal = new bootstrap.Modal(document.getElementById("tractorModal"));
            const tractorSearchInput = document.getElementById("tractorSearchInput");
            const tractorResults = document.getElementById("tractorSearchResults");

            document.getElementById("openTractorModal")?.addEventListener("click", function () {
                tractorSearchInput.value = "";
                tractorResults.innerHTML = '<tr><td colspan="4" class="text-muted text-center py-3">لطفاً حداقل ۲ کاراکتر برای جستجو وارد کنید.</td></tr>';
                tractorModal.show();
                setTimeout(() => tractorSearchInput.focus(), 200);
            });

            let tractorTimeout;
            tractorSearchInput?.addEventListener("input", function () {
                clearTimeout(tractorTimeout);
                const term = this.value.trim();

                if (term.length < 2) {
                    tractorResults.innerHTML = '<tr><td colspan="4" class="text-muted text-center py-3">لطفاً حداقل ۲ کاراکتر برای جستجو وارد کنید.</td></tr>';
                    return;
                }

                tractorResults.innerHTML = '<tr><td colspan="4" class="text-center py-3"><div class="spinner-border spinner-border-sm"></div> در حال جستجو...</td></tr>';
                tractorTimeout = setTimeout(() => loadTractors(term), 350);
            });

            function loadTractors(term) {
                fetch(`/TractorAssignment/SearchAvailableTractors?term=${encodeURIComponent(term)}`)
                    .then(r => r.json())
                    .then(data => {
                        if (!data || data.length === 0) {
                            tractorResults.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">موردی یافت نشد.</td></tr>';
                            return;
                        }

                        tractorResults.innerHTML = data.map(x => `
                            <tr>
                                <td>${x.policePlateNumber ?? ""}</td>
                                <td>${x.tractorType ?? "-"}</td>
                                <td>${x.capacity ?? "-"} ${x.capacityUnit ?? ""}</td>
                                <td>
                                    <button type="button"
                                            class="btn btn-primary btn-sm js-select-tractor"
                                            data-id="${x.id}"
                                            data-text="${x.policePlateNumber ?? ""}">
                                        انتخاب
                                    </button>
                                </td>
                            </tr>
                        `).join("");

                        tractorResults.querySelectorAll(".js-select-tractor").forEach(btn => {
                            btn.addEventListener("click", function () {
                                document.getElementById("TractorId").value = this.dataset.id;
                                document.getElementById("TractorPlateNumber").value = this.dataset.text;
                                tractorModal.hide();
                            });
                        });
                    })
                    .catch(() => {
                        tractorResults.innerHTML = '<tr><td colspan="4" class="text-center text-danger py-3">خطا در جستجو.</td></tr>';
                    });
            }

            const driverModal = new bootstrap.Modal(document.getElementById("driverModal"));
            const driverSearchInput = document.getElementById("driverSearchInput");
            const driverResults = document.getElementById("driverSearchResults");

            document.getElementById("openDriverModal")?.addEventListener("click", function () {
                driverSearchInput.value = "";
                driverResults.innerHTML = '<tr><td colspan="4" class="text-muted text-center py-3">لطفاً حداقل ۲ کاراکتر برای جستجو وارد کنید.</td></tr>';
                driverModal.show();
                setTimeout(() => driverSearchInput.focus(), 200);
            });

            let driverTimeout;
            driverSearchInput?.addEventListener("input", function () {
                clearTimeout(driverTimeout);
                const term = this.value.trim();

                if (term.length < 2) {
                    driverResults.innerHTML = '<tr><td colspan="4" class="text-muted text-center py-3">لطفاً حداقل ۲ کاراکتر برای جستجو وارد کنید.</td></tr>';
                    return;
                }

                driverResults.innerHTML = '<tr><td colspan="4" class="text-center py-3"><div class="spinner-border spinner-border-sm"></div> در حال جستجو...</td></tr>';
                driverTimeout = setTimeout(() => loadDrivers(term), 350);
            });

            function loadDrivers(term) {
                fetch(`/TractorAssignment/SearchAvailableDrivers?term=${encodeURIComponent(term)}`)
                    .then(r => r.json())
                    .then(data => {
                        if (!data || data.length === 0) {
                            driverResults.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">موردی یافت نشد.</td></tr>';
                            return;
                        }

                        driverResults.innerHTML = data.map(x => `
                            <tr>
                                <td>${x.fullName ?? ""}</td>
                                <td>${x.nationalId ?? "-"}</td>
                                <td>${x.phoneNumber ?? "-"}</td>
                                <td>
                                    <button type="button"
                                            class="btn btn-primary btn-sm js-select-driver"
                                            data-id="${x.id}"
                                            data-text="${x.fullName ?? ""}">
                                        انتخاب
                                    </button>
                                </td>
                            </tr>
                        `).join("");

                        driverResults.querySelectorAll(".js-select-driver").forEach(btn => {
                            btn.addEventListener("click", function () {
                                document.getElementById("DriverProfileId").value = this.dataset.id;
                                document.getElementById("DriverFullName").value = this.dataset.text;
                                driverModal.hide();
                            });
                        });
                    })
                    .catch(() => {
                        driverResults.innerHTML = '<tr><td colspan="4" class="text-center text-danger py-3">خطا در جستجو.</td></tr>';
                    });
            }

            document.getElementById("clearDriver")?.addEventListener("click", function () {
                document.getElementById("DriverProfileId").value = "";
                document.getElementById("DriverFullName").value = "";
            });
        });
    </script>
}
