@* Replace the existing #loadingModal block in Views/TractorAssignment/Details.cshtml with this modal. *@
<div class="modal fade" id="loadingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form asp-action="ConfirmLoadingWithDocuments" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()
                <input type="hidden" name="assignmentId" value="@Model.Assignment.Id" />
                <div class="modal-header py-2">
                    <h6 class="modal-title">ثبت بارگیری</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"></button>
                </div>

                <div class="modal-body small">
                    <div class="mb-2">
                        <label class="form-label">وزن خالص بارگیری <span class="text-danger">*</span></label>
                        <input type="number"
                               name="loadedAmount"
                               class="form-control form-control-sm"
                               step="0.001"
                               min="0.001"
                               required
                               placeholder="وزن خالص بارگیری" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label">حجم خالص بارگیری</label>
                        <input type="number"
                               name="loadingNetVolume"
                               class="form-control form-control-sm"
                               step="0.001"
                               min="0"
                               placeholder="اختیاری" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label">شماره بارنامه</label>
                        <input type="text"
                               name="loadingBillOfLadingNumber"
                               class="form-control form-control-sm"
                               maxlength="100"
                               placeholder="اختیاری" />
                    </div>

                    <div class="mb-0">
                        <label class="form-label">مدارک بارگیری <span class="text-danger">*</span></label>
                        <input type="file"
                               name="loadingDocuments"
                               class="form-control form-control-sm"
                               multiple
                               required />
                        <div class="form-text small">
                            حداقل یک فایل مدرک بارگیری الزامی است. برای چند مدرک، چند فایل را همزمان انتخاب کنید.
                        </div>
                    </div>
                </div>

                <div class="modal-footer py-2 gap-2">
                    <button type="submit" class="btn btn-success btn-sm px-3">ثبت بارگیری</button>
                    <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">انصراف</button>
                </div>
            </form>
        </div>
    </div>
</div>
