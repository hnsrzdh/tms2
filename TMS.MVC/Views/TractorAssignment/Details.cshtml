@section Scripts {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        var assignmentId = @assignment.Id;
        var map;
        var markers = [];

        document.addEventListener("DOMContentLoaded", function () {
            initMap();
            loadLocationHistory();
        });

                document.addEventListener("DOMContentLoaded", function () {
            const baseCurrencySelect = document.getElementById("financialBaseCurrency");
            const infoBox = document.getElementById("exchangeRateInfoBox");
            const infoTitle = document.getElementById("exchangeRateInfoTitle");
            const infoText = document.getElementById("exchangeRateInfoText");

            function updateExchangeRateInputs() {
                const baseCurrency = baseCurrencySelect?.value || "ریال";
                const inputs = document.querySelectorAll(".exchange-rate-input");
                let hasDifferentCurrency = false;

                inputs.forEach(input => {
                    const sourceCurrency = input.dataset.sourceCurrency || "ریال";
                    const title = input.dataset.title || "مبلغ";
                    const wrapper = input.closest(".col-md-2");
                    const help = wrapper?.querySelector(".exchange-rate-help");

                    if (sourceCurrency === baseCurrency) {
                        input.value = "1";
                        input.readOnly = true;
                        input.classList.add("bg-light");

                        if (help) {
                            help.textContent = `${sourceCurrency} با ${baseCurrency} یکسان است؛ نرخ تبدیل 1 است.`;
                        }
                    } else {
                        hasDifferentCurrency = true;
                        input.readOnly = false;
                        input.classList.remove("bg-light");

                        if (!input.value || Number(input.value) <= 0 || input.value === "1") {
                            input.value = "";
                        }

                        if (help) {
                            help.textContent = `هر 1 ${sourceCurrency} برای ${title} برابر چند ${baseCurrency} است؟`;
                        }
                    }
                });

                if (infoBox && infoTitle && infoText) {
                    infoBox.classList.remove("alert-warning", "alert-primary");

                    if (hasDifferentCurrency) {
                        infoBox.classList.add("alert-warning");
                        infoTitle.textContent = "نرخ تبدیل لازم است: ";
                        infoText.textContent = `برخی مبالغ با ارز مبنای تسویه متفاوت هستند. نرخ تبدیل را نسبت به ${baseCurrency} وارد کنید.`;
                    } else {
                        infoBox.classList.add("alert-primary");
                        infoTitle.textContent = "واحدهای پولی یکسان هستند: ";
                        infoText.textContent = `همه مبالغ با ارز مبنای تسویه (${baseCurrency}) یکسان هستند و نرخ تبدیل همه موارد برابر 1 است.`;
                    }
                }
            }

            baseCurrencySelect?.addEventListener("change", updateExchangeRateInputs);
            updateExchangeRateInputs();
        });
        function initMap() {
            map = L.map("map").setView([35.6892, 51.3890], 6);

            L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
                maxZoom: 19,
                attribution: "OpenStreetMap"
            }).addTo(map);
        }

        function loadLocationHistory() {
            fetch(`/TractorAssignment/GetLocationHistory?assignmentId=${assignmentId}`)
                .then(r => r.json())
                .then(data => {
                    clearMarkers();

                    if (!data || data.length === 0) {
                        return;
                    }

                    var bounds = [];

                    data.forEach(loc => {
                        const lat = Number(loc.latitude);
                        const lng = Number(loc.longitude);

                        if (isNaN(lat) || isNaN(lng)) return;

                        const popupText = `${loc.timestamp ?? ""}<br>${loc.notes ?? ""}`;
                        var marker = L.marker([lat, lng]).bindPopup(popupText).addTo(map);

                        markers.push(marker);
                        bounds.push([lat, lng]);
                    });

                    if (bounds.length > 0) {
                        map.fitBounds(bounds);
                    }
                });
        }

        function clearMarkers() {
            markers.forEach(m => map.removeLayer(m));
            markers = [];
        }

        function refreshMap() {
            loadLocationHistory();
        }
    </script>
}
