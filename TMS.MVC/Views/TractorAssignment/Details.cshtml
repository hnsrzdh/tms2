@using System.Globalization
@using TMS.MVC.Models
@using TMS.MVC.ViewModels
@model TMS.MVC.ViewModels.TractorAssignmentDetailsViewModel

@{
    ViewData["Title"] = "جزئیات سفر کشنده";

    string ToJalali(DateTime? date)
    {
        if (!date.HasValue) return "-";
        var pc = new PersianCalendar();
        var d = date.Value;
        return $"{pc.GetYear(d):0000}/{pc.GetMonth(d):00}/{pc.GetDayOfMonth(d):00}";
    }

    string Money(decimal? value)
    {
        return (value ?? 0).ToString("N0");
    }

    var assignment = Model.Assignment;
    var sub = assignment.SubHavaleh;
    var havaleh = sub?.Havaleh;

    var unit = havaleh?.Unit ?? "کیلوگرم";

    var driverPricePer1000Unit = sub?.DriverPricePer1000Unit ?? 0;
    var driverPriceCurrency = sub?.DriverPriceCurrency ?? "ریال";

    var driverTip = sub?.DriverTip ?? 0;
    var driverTipCurrency = sub?.DriverTipCurrency ?? driverPriceCurrency;

    var driverStopFee = sub?.DriverStopFee ?? 0;
    var driverStopFeeCurrency = sub?.DriverStopFeeCurrency ?? driverPriceCurrency;

    var delayPenaltyPerDay = sub?.LateDeliveryPenalty ?? 0;
    var delayPenaltyCurrency = sub?.LateDeliveryPenaltyCurrency ?? driverPriceCurrency;

    var penaltyPerUnit = havaleh?.ShortagePenaltyPerUnit ?? 0;
    var shortagePenaltyCurrency = "ریال";

    var unloadedAmount = assignment.UnloadedAmount ?? 0;
    var loadedAmount = assignment.LoadedAmount ?? 0;

    var allowedShortage = sub?.AcceptableWeightLoss ?? 0;
    var rawShortageAmount = Math.Max(0, loadedAmount - unloadedAmount);
    var chargeableShortageAmount = Math.Max(0, rawShortageAmount - allowedShortage);

    var loadingDelayDays = CalculateDelayDays(assignment.AssignmentDate, assignment.LoadingEndDate, sub?.AllowedLoadingTime);
    var deliveryDelayDays = CalculateDelayDays(assignment.AssignmentDate, assignment.UnloadingEndDate, sub?.AllowedDeliveryTime);
    var totalDelayDays = loadingDelayDays + deliveryDelayDays;

    var baseCurrency = assignment.FinancialBaseCurrency ?? driverPriceCurrency;

    Func<string?, decimal?, decimal> rateToBase = (currency, savedRate) =>
        string.Equals(currency ?? baseCurrency, baseCurrency, StringComparison.OrdinalIgnoreCase)
            ? 1m
            : (savedRate ?? 0m);

    var driverPriceRate = rateToBase(driverPriceCurrency, assignment.DriverPriceExchangeRateToBase);
    var driverTipRate = rateToBase(driverTipCurrency, assignment.DriverTipExchangeRateToBase);
    var driverStopFeeRate = rateToBase(driverStopFeeCurrency, assignment.DriverStopFeeExchangeRateToBase);
    var delayPenaltyRate = rateToBase(delayPenaltyCurrency, assignment.DelayPenaltyExchangeRateToBase);
    var shortagePenaltyRate = rateToBase(shortagePenaltyCurrency, assignment.ShortagePenaltyExchangeRateToBase);

    var baseFareOriginal = (unloadedAmount / 1000m) * driverPricePer1000Unit;
    var baseFare = baseFareOriginal * driverPriceRate;

    var stopHours = CalculateStopHours(assignment);
    var stopFeeOriginal = stopHours * driverStopFee;
    var stopFeeTotal = stopFeeOriginal * driverStopFeeRate;

    var driverTipConverted = driverTip * driverTipRate;

    var shortagePenaltyOriginal = chargeableShortageAmount * penaltyPerUnit;
    var shortagePenalty = shortagePenaltyOriginal * shortagePenaltyRate;

    var delayPenaltyOriginal = totalDelayDays * delayPenaltyPerDay;
    var delayPenalty = delayPenaltyOriginal * delayPenaltyRate;

    var calculatedTotalFare = baseFare + driverTipConverted + stopFeeTotal - shortagePenalty - delayPenalty;
    if (calculatedTotalFare < 0) calculatedTotalFare = 0;

    var totalFare = assignment.FinancialApprovedAmount ?? assignment.PayableAmount ?? assignment.FinalFare ?? calculatedTotalFare;
    var settlementCurrency = assignment.FinancialBaseCurrency ?? baseCurrency;

    var needsExchangeRate =
        !string.Equals(driverPriceCurrency, baseCurrency, StringComparison.OrdinalIgnoreCase) ||
        !string.Equals(driverTipCurrency, baseCurrency, StringComparison.OrdinalIgnoreCase) ||
        !string.Equals(driverStopFeeCurrency, baseCurrency, StringComparison.OrdinalIgnoreCase) ||
        !string.Equals(delayPenaltyCurrency, baseCurrency, StringComparison.OrdinalIgnoreCase) ||
        !string.Equals(shortagePenaltyCurrency, baseCurrency, StringComparison.OrdinalIgnoreCase);
}

@functions {
    private DateTime? GetDocumentApprovalDate(TractorAssignment assignment)
    {
        var unloadingApprovedDates = assignment.UnloadingDocuments
            .Where(d => d.IsApproved && d.ApprovalDate.HasValue)
            .Select(d => d.ApprovalDate!.Value)
            .ToList();

        var loadingApprovedDates = assignment.LoadingDocuments
            .Where(d => d.IsApproved && d.ApprovalDate.HasValue)
            .Select(d => d.ApprovalDate!.Value)
            .ToList();

        if (unloadingApprovedDates.Any())
            return unloadingApprovedDates.Max();

        if (loadingApprovedDates.Any())
            return loadingApprovedDates.Max();

        return null;
    }

    private decimal CalculateStopHours(TractorAssignment assignment)
    {
        var sub = assignment.SubHavaleh;
        if (sub == null) return 0;

        decimal totalStopHours = 0;

        if (assignment.ArrivalAtOriginDate.HasValue &&
            assignment.LoadingEndDate.HasValue &&
            sub.AllowedLoadingTime.HasValue)
        {
            var loadingHours = (decimal)(assignment.LoadingEndDate.Value - assignment.ArrivalAtOriginDate.Value).TotalHours;
            if (loadingHours > sub.AllowedLoadingTime.Value)
                totalStopHours += Math.Ceiling(loadingHours - sub.AllowedLoadingTime.Value);
        }

        if (assignment.ArrivalAtDestinationDate.HasValue &&
            assignment.UnloadingEndDate.HasValue &&
            sub.AllowedDeliveryTime.HasValue)
        {
            var unloadingHours = (decimal)(assignment.UnloadingEndDate.Value - assignment.ArrivalAtDestinationDate.Value).TotalHours;
            if (unloadingHours > sub.AllowedDeliveryTime.Value)
                totalStopHours += Math.Ceiling(unloadingHours - sub.AllowedDeliveryTime.Value);
        }

        return totalStopHours;
    }

    private int CalculateDelayDays(DateTime assignmentDate, DateTime? actualDate, int? allowedDays)
    {
        if (!actualDate.HasValue || !allowedDays.HasValue) return 0;

        var actualDays = (actualDate.Value.Date - assignmentDate.Date).Days;
        var delayDays = actualDays - allowedDays.Value;

        return delayDays > 0 ? delayDays : 0;
    }

    public class TimelineStep
    {
        public int StatusValue { get; set; }
        public string Title { get; set; } = "";
        public string SubTitle { get; set; } = "";
        public string Icon { get; set; } = "";
        public DateTime? Date { get; set; }
        public string Description { get; set; } = "";
        public string? CancelledBy { get; set; }
    }

    string GetStatusDisplay(AssignmentStatus status) => status switch
    {
        AssignmentStatus.Assigned => "تخصیص داده شده",
        AssignmentStatus.ArrivedAtOrigin => "رسیده به مبدا",
        AssignmentStatus.Loading => "در حال بارگیری",
        AssignmentStatus.Loaded => "بارگیری شده",
        AssignmentStatus.InTransit => "در راه",
        AssignmentStatus.ArrivedAtDestination => "رسیده به مقصد",
        AssignmentStatus.Unloading => "در حال تخلیه",
        AssignmentStatus.Unloaded => "تخلیه شده",
        AssignmentStatus.Completed => "تکمیل شده",
        AssignmentStatus.CancellationRequested => "درخواست لغو",
        AssignmentStatus.Cancelled => "لغو شده",
        _ => "نامشخص"
    };

    string GetStatusBadgeClass(AssignmentStatus status) => status switch
    {
        AssignmentStatus.Assigned => "bg-secondary",
        AssignmentStatus.ArrivedAtOrigin => "bg-info text-dark",
        AssignmentStatus.Loading => "bg-info text-dark",
        AssignmentStatus.Loaded => "bg-primary",
        AssignmentStatus.InTransit => "bg-primary",
        AssignmentStatus.ArrivedAtDestination => "bg-success",
        AssignmentStatus.Unloading => "bg-warning text-dark",
        AssignmentStatus.Unloaded => "bg-warning text-dark",
        AssignmentStatus.Completed => "bg-success",
        AssignmentStatus.CancellationRequested => "bg-warning text-dark",
        AssignmentStatus.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}

<style>
    .assignment-details-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .assignment-details-compact .form-control,
    .assignment-details-compact .form-select,
    .assignment-details-compact .input-group-text,
    .assignment-details-compact .btn,
    .assignment-details-compact .table,
    .assignment-details-compact .badge,
    .assignment-details-compact .form-check-label {
        font-size: 0.82rem;
    }

        .assignment-details-compact .table > :not(caption) > * > * {
            padding: 0.45rem 0.55rem;
        }

    .assignment-details-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .assignment-details-compact .card-body {
        padding-top: 0.85rem;
    }

    .assignment-details-compact .small-muted {
        font-size: 0.78rem;
    }

    .assignment-details-compact .summary-box {
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 0.65rem 0.75rem;
        background: #f8f9fa;
        height: 100%;
    }

        .assignment-details-compact .summary-box small {
            font-size: 0.76rem;
        }

        .assignment-details-compact .summary-box .value {
            display: block;
            margin-top: 0.25rem;
            font-weight: 600;
            color: #495057;
        }

    .assignment-details-compact .operation-btn {
        width: 112px;
        min-height: 58px;
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.2rem;
    }

        .assignment-details-compact .operation-btn i {
            font-size: 1rem;
        }

    .assignment-details-compact .money-note {
        font-size: 0.76rem;
        color: #6c757d;
    }

    .advanced-timeline {
        position: relative;
        padding: 0.25rem 0;
    }

    .timeline-item {
        position: relative;
        padding-bottom: 1.1rem;
    }

    .timeline-node-wrapper {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
    }

    .timeline-node {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #e9ecef;
        z-index: 2;
        flex: 0 0 auto;
    }

    .timeline-node-wrapper.completed .timeline-node {
        background: #198754;
    }

    .timeline-node-wrapper.current .timeline-node {
        background: #ffc107;
    }

    .timeline-node-wrapper.cancelled .timeline-node {
        background: #dc3545;
    }

    .timeline-connector {
        position: absolute;
        top: 30px;
        right: 15px;
        width: 2px;
        height: calc(100% - 30px);
        background: #e9ecef;
    }

        .timeline-connector.completed {
            background: #198754;
        }

    .timeline-content {
        flex: 1;
    }

        .timeline-content .description {
            font-size: 0.78rem;
            color: #6c757d;
            margin: 0.35rem 0 0;
        }

    .pulse-animation .timeline-node {
        animation: pulse 1.5s infinite;
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(255, 193, 7, .45);
        }

        70% {
            box-shadow: 0 0 0 8px rgba(255, 193, 7, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(255, 193, 7, 0);
        }
    }
</style>

<div class="container-fluid assignment-details-compact">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">داشبورد</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-action="Index" asp-route-subHavalehId="@Model.SubHavalehId">تخصیص کشنده‌ها</a>
                    </li>
                    <li class="breadcrumb-item active">جزئیات سفر</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid assignment-details-compact">
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success py-2 small">@TempData["Ok"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger py-2 small">@TempData["Error"]</div>
    }

    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning py-2 small">@TempData["Warning"]</div>
    }

    <div class="card mb-3">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">اطلاعات پایه سفر</h6>
                <small class="text-muted small-muted">نمای کلی سفر، مسیر، راننده، کشنده و وضعیت فعلی</small>
            </div>

            <div class="d-flex gap-2">
                <a asp-controller="Chat"
                   asp-action="Index"
                   asp-route-assignmentId="@assignment.Id"
                   class="btn btn-outline-primary btn-sm px-3">
                    صحبت با راننده
                </a>

                <a asp-action="Index"
                   asp-route-subHavalehId="@Model.SubHavalehId"
                   class="btn btn-secondary btn-sm px-3">
                    بازگشت
                </a>
            </div>
        </div>

        <div class="card-body">
            <div class="row g-2 mb-2">
                <div class="col-md-3">
                    <div class="summary-box text-center">
                        <small class="text-muted d-block">شماره حواله</small>
                        <span class="value">@Model.HavalehNumber</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="summary-box text-center">
                        <small class="text-muted d-block">زیرحواله</small>
                        <span class="value">@Model.SubHavalehTitle</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="summary-box text-center">
                        <small class="text-muted d-block">پلاک کشنده</small>
                        <span class="value">@Model.TractorPlateNumber</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="summary-box text-center">
                        <small class="text-muted d-block">راننده</small>
                        <span class="value">@Model.DriverFullName</span>
                    </div>
                </div>
            </div>

            <div class="row g-2">
                <div class="col-md-3">
                    <div class="summary-box text-center">
                        <small class="text-muted d-block">مبدا</small>
                        <span class="value">@Model.OriginCityDisplay</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="summary-box text-center">
                        <small class="text-muted d-block">مقصد</small>
                        <span class="value">@Model.DestinationCityDisplay</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="summary-box text-center">
                        <small class="text-muted d-block">تاریخ تخصیص</small>
                        <span class="value">@ToJalali(assignment.AssignmentDate)</span>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="summary-box text-center">
                        <small class="text-muted d-block">وضعیت</small>
                        <span class="badge @GetStatusBadgeClass(assignment.Status) mt-2">@GetStatusDisplay(assignment.Status)</span>
                    </div>
                </div>
            </div>

            @if (assignment.Status == AssignmentStatus.CancellationRequested || assignment.Status == AssignmentStatus.Cancelled)
            {
                <div class="alert @(assignment.Status == AssignmentStatus.Cancelled ? "alert-danger" : "alert-warning") py-2 small mt-3 mb-0">
                    <div><strong>وضعیت لغو:</strong> @GetStatusDisplay(assignment.Status)</div>
                    <div><strong>دلیل:</strong> @(assignment.CancellationReason ?? "ثبت نشده")</div>

                    @if (assignment.CancellationRequestDate.HasValue)
                    {
                        <div><strong>تاریخ درخواست:</strong> @ToJalali(assignment.CancellationRequestDate) - @assignment.CancellationRequestDate.Value.ToString("HH:mm")</div>
                    }

                    @if (assignment.CancellationDate.HasValue)
                    {
                        <div><strong>تاریخ لغو:</strong> @ToJalali(assignment.CancellationDate) - @assignment.CancellationDate.Value.ToString("HH:mm")</div>
                    }

                    @if (!string.IsNullOrWhiteSpace(assignment.CancelledBy))
                    {
                        <div><strong>لغو توسط:</strong> @assignment.CancelledBy</div>
                    }

                    @if (Model.ShowCancellationActions)
                    {
                        <div class="d-flex gap-2 mt-2">
                            <button type="button"
                                    class="btn btn-success btn-sm px-3"
                                    data-bs-toggle="modal"
                                    data-bs-target="#approveCancellationModal">
                                تایید لغو
                            </button>

                            <button type="button"
                                    class="btn btn-outline-danger btn-sm px-3"
                                    data-bs-toggle="modal"
                                    data-bs-target="#rejectCancellationModal">
                                رد درخواست
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <div class="row g-3">
        <div class="col-lg-6">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <div>
                        <h6 class="mb-0">خلاصه سفر</h6>
                        <small class="text-muted small-muted">مراحل انجام سفر از تخصیص تا تایید مدارک</small>
                    </div>

                    <span class="badge @GetStatusBadgeClass(assignment.Status)">@GetStatusDisplay(assignment.Status)</span>
                </div>

                <div class="card-body">
                    @{
                        var isCancelled = assignment.Status == AssignmentStatus.Cancelled;
                        var isCancellationRequested = assignment.Status == AssignmentStatus.CancellationRequested;

                        var allSteps = new List<TimelineStep>
                                        {
                                        new() { StatusValue = 0, Title = "تخصیص کشنده", SubTitle = "Tractor Assignment", Icon = "bi-truck-front-fill", Date = assignment.AssignmentDate, Description = $"کشنده «{Model.TractorPlateNumber}» تخصیص داده شد" + (Model.DriverFullName != "تعیین نشده" ? $" - راننده: {Model.DriverFullName}" : "") },
                                        new() { StatusValue = 1, Title = "رسیدن به مبدا", SubTitle = "Arrival at Origin", Icon = "bi-geo-alt-fill", Date = assignment.ArrivalAtOriginDate, Description = "کشنده به محل بارگیری رسید" },
                                        new() { StatusValue = 3, Title = "بارگیری", SubTitle = "Loading", Icon = "bi-box-seam-fill", Date = assignment.LoadingEndDate, Description = assignment.LoadedAmount.HasValue ? $"بارگیری: {assignment.LoadedAmount.Value:N0} {unit}" : "عملیات بارگیری انجام شد" },
                                        new() { StatusValue = 5, Title = "رسیدن به مقصد", SubTitle = "Arrival at Destination", Icon = "bi-geo-alt-fill", Date = assignment.ArrivalAtDestinationDate, Description = "کشنده به مقصد رسید" },
                                        new() { StatusValue = 7, Title = "تخلیه", SubTitle = "Unloading", Icon = "bi-droplet-fill", Date = assignment.UnloadingEndDate, Description = assignment.UnloadedAmount.HasValue ? $"تخلیه: {assignment.UnloadedAmount.Value:N0} {unit}" : "عملیات تخلیه انجام شد" },
                                        new() { StatusValue = 8, Title = "تایید مدارک", SubTitle = "Documents Approved", Icon = "bi-file-earmark-check-fill", Date = GetDocumentApprovalDate(assignment), Description = "مدارک توسط اپراتور تایید شد" }
                                        };

                        var cancellationRequestStep = new TimelineStep { StatusValue = 9, Title = "درخواست لغو", SubTitle = "Cancellation Request", Icon = "bi-exclamation-triangle-fill", Date = assignment.CancellationRequestDate, Description = assignment.CancellationReason ?? "-" };
                        var cancelledStep = new TimelineStep { StatusValue = 10, Title = "لغو شده", SubTitle = "Cancelled", Icon = "bi-x-circle-fill", Date = assignment.CancellationDate, Description = assignment.CancellationReason ?? "-", CancelledBy = assignment.CancelledBy };
                    }

                    <div class="advanced-timeline">
                        @if (isCancelled || isCancellationRequested)
                        {
                            foreach (var step in allSteps.Where(x => x.Date.HasValue))
                            {
                                <div class="timeline-item">
                                    <div class="timeline-connector completed"></div>
                                    <div class="timeline-node-wrapper completed">
                                        <div class="timeline-node"><i class="bi bi-check-lg text-white"></i></div>
                                        <div class="timeline-content">
                                            <div class="d-flex align-items-center gap-1 mb-1">
                                                <h6 class="mb-0 text-success">@step.Title</h6>
                                                <span class="badge bg-success rounded-pill">انجام</span>
                                            </div>
                                            <small class="text-muted d-block">@step.SubTitle</small>
                                            <small class="text-muted">@ToJalali(step.Date) - @step.Date!.Value.ToString("HH:mm")</small>
                                            <p class="description">@step.Description</p>
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (cancellationRequestStep.Date.HasValue)
                            {
                                <div class="timeline-item @(isCancelled ? "" : "timeline-item-last")">
                                    @if (isCancelled)
                                    {
                                        <div class="timeline-connector completed"></div>
                                    }
                                    <div class="timeline-node-wrapper @(isCancelled ? "completed" : "current pulse-animation")">
                                        <div class="timeline-node">
                                            <i class="bi @cancellationRequestStep.Icon text-white"></i>
                                        </div>
                                        <div class="timeline-content">
                                            <div class="d-flex align-items-center gap-1 mb-1">
                                                <h6 class="mb-0 @(isCancelled ? "text-success" : "text-warning")">@cancellationRequestStep.Title</h6>
                                                <span class="badge @(isCancelled ? "bg-success" : "bg-warning text-dark") rounded-pill">@(isCancelled ? "بررسی شده" : "در انتظار")</span>
                                            </div>
                                            <small class="text-muted d-block">@cancellationRequestStep.SubTitle</small>
                                            <small class="text-muted">@ToJalali(cancellationRequestStep.Date) - @cancellationRequestStep.Date!.Value.ToString("HH:mm")</small>
                                            <p class="description">@cancellationRequestStep.Description</p>
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (isCancelled && cancelledStep.Date.HasValue)
                            {
                                <div class="timeline-item timeline-item-last">
                                    <div class="timeline-node-wrapper cancelled">
                                        <div class="timeline-node"><i class="bi @cancelledStep.Icon text-white"></i></div>
                                        <div class="timeline-content">
                                            <div class="d-flex align-items-center gap-1 mb-1">
                                                <h6 class="mb-0 text-danger">@cancelledStep.Title</h6>
                                                <span class="badge bg-danger rounded-pill">لغو شده</span>
                                            </div>
                                            <small class="text-muted d-block">@cancelledStep.SubTitle</small>
                                            <small class="text-muted">@ToJalali(cancelledStep.Date) - @cancelledStep.Date!.Value.ToString("HH:mm")</small>
                                            <p class="description">@cancelledStep.Description</p>
                                            @if (!string.IsNullOrEmpty(cancelledStep.CancelledBy))
                                            {
                                                <small class="text-muted">لغو توسط: @cancelledStep.CancelledBy</small>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            var currentStatusValue = (int)assignment.Status;

                            for (int i = 0; i < allSteps.Count; i++)
                            {
                                var step = allSteps[i];
                                var isCompleted = step.StatusValue <= currentStatusValue;
                                var isNextStep = !isCompleted && step.StatusValue > currentStatusValue && (i == 0 || allSteps[i - 1].StatusValue <= currentStatusValue);
                                var isPending = !isCompleted && !isNextStep;
                                var isLast = i == allSteps.Count - 1;

                                var nodeClass = isCompleted ? "completed" : isNextStep ? "current pulse-animation" : "pending";
                                var iconClass = isCompleted ? "bi-check-lg text-white" : $"{step.Icon} {(isNextStep ? "text-white" : "text-muted")}";
                                var titleClass = isCompleted ? "text-success" : isNextStep ? "text-warning" : "text-muted";
                                var badgeClass = isCompleted ? "bg-success" : isNextStep ? "bg-warning text-dark" : "bg-light text-muted";
                                var badgeText = isCompleted ? "تکمیل" : isNextStep ? "اقدام بعدی" : "در انتظار";
                                var contentClass = isPending ? "opacity-50" : "";

                                <div class="timeline-item @(isLast ? "timeline-item-last" : "")">
                                    @if (!isLast)
                                    {
                                        <div class="timeline-connector @(isCompleted ? "completed" : "")"></div>
                                    }

                                    <div class="timeline-node-wrapper @nodeClass">
                                        <div class="timeline-node">
                                            <i class="bi @iconClass"></i>
                                        </div>
                                        <div class="timeline-content @contentClass">
                                            <div class="d-flex align-items-center gap-1 mb-1">
                                                <h6 class="mb-0 @titleClass">@step.Title</h6>
                                                <span class="badge @badgeClass rounded-pill">@badgeText</span>
                                            </div>
                                            <small class="text-muted d-block">@step.SubTitle</small>

                                            @if (step.Date.HasValue)
                                            {
                                                <small class="text-muted">@ToJalali(step.Date) - @step.Date.Value.ToString("HH:mm")</small>
                                            }
                                            else if (isNextStep)
                                            {
                                                <small class="text-muted fst-italic">در انتظار انجام</small>
                                            }

                                            @if (isCompleted || isNextStep)
                                            {
                                                <p class="description">@step.Description</p>
                                            }

                                            @if (step.StatusValue == 8 && (isCompleted || isNextStep))
                                            {
                                                var loadingDocsApproved = assignment.LoadingDocuments.Any() && assignment.LoadingDocuments.All(d => d.IsApproved);
                                                var unloadingDocsApproved = assignment.UnloadingDocuments.Any() && assignment.UnloadingDocuments.All(d => d.IsApproved);

                                                <div class="mt-1">
                                                    <small class="d-block @(loadingDocsApproved ? "text-success" : "text-warning")">
                                                        مدارک بارگیری: @(loadingDocsApproved ? "تایید" : "در انتظار")
                                                    </small>
                                                    <small class="d-block @(unloadingDocsApproved ? "text-success" : "text-warning")">
                                                        مدارک تخلیه: @(unloadingDocsApproved ? "تایید" : "در انتظار")
                                                    </small>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>

        </div>

        <div class="col-lg-6">
