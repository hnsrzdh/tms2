            </div>

        </div>
        <div class="card mb-3">
            <div class="card-header">
                <h6 class="mb-0">محاسبات مالی</h6>
                <small class="text-muted small-muted">
                    کرایه بر اساس مبلغ هر 1000 @unit محاسبه می‌شود. حق توقف ساعتی، جریمه تأخیر روزانه و کسری با لحاظ کسری مجاز محاسبه می‌شود.
                </small>
            </div>

            <div class="card-body">
                @if (!assignment.LoadedAmount.HasValue && !assignment.UnloadedAmount.HasValue)
                {
                    <div class="text-center text-muted py-3">
                        <i class="bi bi-hourglass-split fs-3"></i>
                        <p class="mt-2 mb-0">محاسبات مالی پس از ثبت بارگیری و تخلیه نمایش داده می‌شود.</p>
                    </div>
                }
                else
                {
                    <div class="row g-2 mb-3">
                        <div class="col-md-3">
                            <div class="summary-box text-center">
                                <small class="text-muted d-block">مقدار بارگیری شده</small>
                                <span class="value text-primary">@(assignment.LoadedAmount?.ToString("N0") ?? "-")</span>
                                <small class="text-muted">@unit</small>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="summary-box text-center">
                                <small class="text-muted d-block">مقدار تخلیه شده</small>
                                <span class="value text-info">@(assignment.UnloadedAmount?.ToString("N0") ?? "-")</span>
                                <small class="text-muted">@unit</small>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="summary-box text-center">
                                <small class="text-muted d-block">کسری کل</small>
                                <span class="value @(rawShortageAmount > 0 ? "text-danger" : "text-success")">@rawShortageAmount.ToString("N0")</span>
                                <small class="text-muted">@unit</small>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="summary-box text-center">
                                <small class="text-muted d-block">کسری مشمول جریمه</small>
                                <span class="value @(chargeableShortageAmount > 0 ? "text-danger" : "text-success")">@chargeableShortageAmount.ToString("N0")</span>
                                <small class="text-muted">@unit</small>
                            </div>
                        </div>
                    </div>

                    <form asp-action="ApproveFinancialCalculation" method="post" id="financialApprovalForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="assignmentId" value="@assignment.Id" />
                        <div class="row g-2 mb-3">
                            <div class="col-md-3">
                                <label class="form-label">ارز مبنای تسویه</label>
                                <select name="financialBaseCurrency"
                                        id="financialBaseCurrency"
                                        class="form-select form-select-sm">
                                    <option value="ریال" selected="@(baseCurrency == "ریال")">ریال</option>
                                    <option value="دلار" selected="@(baseCurrency == "دلار")">دلار</option>
                                    <option value="یورو" selected="@(baseCurrency == "یورو")">یورو</option>
                                </select>
                                <small class="text-muted small-muted">
                                    همه مبالغ برای تایید نهایی به این واحد تبدیل می‌شوند.
                                </small>
                            </div>

                            <div class="col-md-9">
                                <label class="form-label d-block">&nbsp;</label>
                                <div id="exchangeRateInfoBox"
                                     class="alert border py-2 small mb-0">
                                    <strong id="exchangeRateInfoTitle"></strong>
                                    <span id="exchangeRateInfoText"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row g-2 mb-3" id="exchangeRatesRow">
                            <div class="col-md-2">
                                <label class="form-label">نرخ کرایه</label>
                                <input name="driverPriceExchangeRateToBase"
                                       class="form-control form-control-sm exchange-rate-input"
                                       type="number"
                                       step="0.000001"
                                       min="0"
                                       value="@driverPriceRate"
                                       data-source-currency="@driverPriceCurrency"
                                       data-title="کرایه" />
                                <small class="text-muted small-muted exchange-rate-help"></small>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label">نرخ انعام</label>
                                <input name="driverTipExchangeRateToBase"
                                       class="form-control form-control-sm exchange-rate-input"
                                       type="number"
                                       step="0.000001"
                                       min="0"
                                       value="@driverTipRate"
                                       data-source-currency="@driverTipCurrency"
                                       data-title="انعام" />
                                <small class="text-muted small-muted exchange-rate-help"></small>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label">نرخ حق توقف</label>
                                <input name="driverStopFeeExchangeRateToBase"
                                       class="form-control form-control-sm exchange-rate-input"
                                       type="number"
                                       step="0.000001"
                                       min="0"
                                       value="@driverStopFeeRate"
                                       data-source-currency="@driverStopFeeCurrency"
                                       data-title="حق توقف" />
                                <small class="text-muted small-muted exchange-rate-help"></small>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label">نرخ جریمه تأخیر</label>
                                <input name="delayPenaltyExchangeRateToBase"
                                       class="form-control form-control-sm exchange-rate-input"
                                       type="number"
                                       step="0.000001"
                                       min="0"
                                       value="@delayPenaltyRate"
                                       data-source-currency="@delayPenaltyCurrency"
                                       data-title="جریمه تأخیر" />
                                <small class="text-muted small-muted exchange-rate-help"></small>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label">نرخ جریمه کسری</label>
                                <input name="shortagePenaltyExchangeRateToBase"
                                       class="form-control form-control-sm exchange-rate-input"
                                       type="number"
                                       step="0.000001"
                                       min="0"
                                       value="@shortagePenaltyRate"
                                       data-source-currency="@shortagePenaltyCurrency"
                                       data-title="جریمه کسری" />
                                <small class="text-muted small-muted exchange-rate-help"></small>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label d-block">&nbsp;</label>
                                <button type="submit" class="btn btn-outline-primary btn-sm w-100">
                                    محاسبه و ذخیره نرخ‌ها
                                </button>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-bordered table-sm align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 27%;">شرح</th>
                                        <th style="width: 48%;">فرمول / توضیح</th>
                                        <th class="text-center" style="width: 25%;">مبلغ در ارز مبنا (@baseCurrency)</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            <strong>کرایه حمل راننده</strong>
                                            <br />
                                            <small class="text-muted">بر اساس مقدار تخلیه شده</small>
                                        </td>
                                        <td class="text-muted">
                                            @driverPricePer1000Unit.ToString("N0") @driverPriceCurrency × (@unloadedAmount.ToString("N0") @unit ÷ 1000) × نرخ @driverPriceRate.ToString("N6")
                                            <div class="money-note">فی هر 1000 @unit</div>
                                        </td>
                                        <td class="text-center">
                                            <strong class="text-primary">@baseFare.ToString("N0") @baseCurrency</strong>
                                        </td>
                                    </tr>

                                    <tr>
                                        <td>
                                            <strong class="text-danger">جریمه کسری بار</strong>
                                            <br />
                                            <small class="text-muted">کسری کل: @rawShortageAmount.ToString("N0") @unit | کسری مجاز: @allowedShortage.ToString("N0") @unit</small>
                                        </td>
                                        <td class="text-muted">
                                            max(0, کسری کل - کسری مجاز) × @penaltyPerUnit.ToString("N0") @shortagePenaltyCurrency × نرخ @shortagePenaltyRate.ToString("N6")
                                        </td>
                                        <td class="text-center">
                                            <strong class="text-danger">@shortagePenalty.ToString("N0") @baseCurrency</strong>
                                        </td>
                                    </tr>

                                    @if (driverTip > 0)
                                    {
                                        <tr>
                                            <td><strong class="text-success">انعام راننده</strong></td>
                                            <td class="text-muted">@driverTip.ToString("N0") @driverTipCurrency × نرخ @driverTipRate.ToString("N6")</td>
                                            <td class="text-center"><strong class="text-success">@driverTipConverted.ToString("N0") @baseCurrency</strong></td>
                                        </tr>
                                    }

                                    @if (driverStopFee > 0)
                                    {
                                        <tr>
                                            <td>
                                                <strong class="text-warning">حق توقف راننده</strong>
                                                <br />
                                                <small class="text-muted">محاسبه ساعتی</small>
                                            </td>
                                            <td class="text-muted">
                                                @driverStopFee.ToString("N0") @driverStopFeeCurrency × @stopHours.ToString("N0") ساعت × نرخ @driverStopFeeRate.ToString("N6")
                                            </td>
                                            <td class="text-center"><strong class="text-warning">@stopFeeTotal.ToString("N0") @baseCurrency</strong></td>
                                        </tr>
                                    }

                                    <tr>
                                        <td>
                                            <strong class="text-danger">جریمه تأخیر</strong>
                                            <br />
                                            <small class="text-muted">بارگیری: @loadingDelayDays روز | تخلیه: @deliveryDelayDays روز</small>
                                        </td>
                                        <td class="text-muted">
                                            (@loadingDelayDays + @deliveryDelayDays) روز × @delayPenaltyPerDay.ToString("N0") @delayPenaltyCurrency × نرخ @delayPenaltyRate.ToString("N6")
                                            <div class="money-note">تاخیر بارگیری و تخلیه هر دو از تاریخ تخصیص محاسبه می‌شوند.</div>
                                        </td>
                                        <td class="text-center"><strong class="text-danger">@delayPenalty.ToString("N0") @baseCurrency</strong></td>
                                    </tr>
                                </tbody>

                                <tfoot>
                                    <tr class="table-success">
                                        <td class="fw-bold">مبلغ محاسبه‌شده سیستم</td>
                                        <td class="text-muted">کرایه + انعام + حق توقف - جریمه کسری - جریمه تأخیر</td>
                                        <td class="text-center fw-bold text-success">@calculatedTotalFare.ToString("N0") @baseCurrency</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>

                        <div class="row g-2 mt-3">
                            <div class="col-md-3">
                                <label class="form-label">مبلغ دستی نهایی</label>
                                <input name="manualAmount" class="form-control form-control-sm" type="number" step="1" min="0" value="@(assignment.FinancialManualAmount?.ToString("0.##"))" />
                                <small class="text-muted small-muted">در صورت نیاز به اصلاح دستی وارد شود.</small>
                            </div>

                            <div class="col-md-6">
                                <label class="form-label">توضیح تغییر مبلغ</label>
                                <input name="financialAdjustmentNote" class="form-control form-control-sm" value="@assignment.FinancialAdjustmentNote" placeholder="اگر مبلغ دستی وارد شد، دلیل تغییر را بنویسید..." />
                            </div>

                            <div class="col-md-3 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" name="useManualAmount" value="true" id="useManualAmount" @(assignment.FinancialManualAmount.HasValue ? "checked" : "") />
                                    <label class="form-check-label" for="useManualAmount">تایید با مبلغ دستی</label>
                                </div>
                            </div>
                        </div>

                        <div class="mt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                            <div>
                                @if (assignment.IsFinancialApproved)
                                {
                                    <span class="badge bg-success">مبلغ نهایی تایید شده</span>
                                    <small class="text-muted ms-2">
                                        @assignment.FinancialApprovedAmount?.ToString("N0") @settlementCurrency
                                        @if (assignment.FinancialApprovedDate.HasValue)
                                        {
                                            <span> | @ToJalali(assignment.FinancialApprovedDate) - @assignment.FinancialApprovedDate.Value.ToString("HH:mm")</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(assignment.FinancialApprovedBy))
                                        {
                                            <span> | توسط @assignment.FinancialApprovedBy</span>
                                        }
                                    </small>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">در انتظار تایید مبلغ نهایی</span>
                                }
                            </div>

                            <button type="submit" class="btn btn-success btn-sm px-3">تایید مبلغ نهایی</button>
                        </div>
                    </form>

                    <div class="mt-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            @if (assignment.IsSettled)
                            {
                                <span class="badge bg-success">تسویه شده</span>
                                <small class="text-muted ms-2">
                                    @if (assignment.SettledDate.HasValue)
                                    {
                                        <span>در تاریخ @ToJalali(assignment.SettledDate) - @assignment.SettledDate.Value.ToString("HH:mm")</span>
                                    }
                                    @if (!string.IsNullOrEmpty(assignment.SettledBy))
                                    {
                                        <span> توسط @assignment.SettledBy</span>
                                    }
                                    @if (assignment.SettledTo == "Driver")
                                    {
                                        <span> به کیف پول راننده (@Model.DriverFullName)</span>
                                    }
                                    else if (assignment.SettledTo == "Tractor")
                                    {
                                        <span> به کیف پول کشنده (@Model.TractorPlateNumber)</span>
                                    }
                                </small>
                            }
                            else if (assignment.UnloadedAmount.HasValue)
                            {
                                <span class="badge bg-warning text-dark">در انتظار تسویه</span>
                                @if (!assignment.IsFinancialApproved)
                                {
                                    <small class="text-muted ms-2">ابتدا مبلغ نهایی باید توسط اپراتور تایید شود.</small>
                                }
                            }
                        </div>

                        @if (assignment.UnloadedAmount.HasValue && !assignment.IsSettled && assignment.IsFinancialApproved)
                        {
                            <div class="d-flex gap-2">
                                @if (assignment.DriverProfileId.HasValue)
                                {
                                    <button type="button" class="btn btn-success btn-sm px-3" data-bs-toggle="modal" data-bs-target="#payToDriverModal">
                                        واریز به کیف پول راننده
                                    </button>
                                }

                                <button type="button" class="btn btn-primary btn-sm px-3" data-bs-toggle="modal" data-bs-target="#payToTractorModal">
                                    واریز به کیف پول کشنده
                                </button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
        <div class="card mb-3">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="mb-0">رهگیری مسیر</h6>
                    <small class="text-muted small-muted">آخرین موقعیت‌های ثبت‌شده کشنده</small>
                </div>

                <button type="button" class="btn btn-outline-primary btn-sm px-3" onclick="refreshMap()">
                    به‌روزرسانی
                </button>
            </div>

            <div class="card-body">
                <div id="map" style="height: 400px; border-radius: 0.75rem; overflow: hidden;"></div>
            </div>
        </div>
    </div>
</div>

