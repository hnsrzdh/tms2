                                        !Model.CanConfirmLoading &&
                                        !Model.CanConfirmDestinationArrival &&
                                        !Model.CanConfirmUnloading &&
                                        !Model.CanRequestCancellation &&
                                        !Model.CanCancelByAdmin)
                    {
                        <div class="text-center text-muted py-2">
                            <i class="bi bi-check-circle text-success fs-4"></i>
                            <p class="mb-0 mt-1">عملیات این سفر به پایان رسیده است.</p>
                        </div>
                    }
                </div>
            </div>


            <div class="card mb-3">
