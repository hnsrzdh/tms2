@using TMS.MVC.Models
@model TMS.MVC.ViewModels.TractorAssignmentIndexViewModel

@{
    ViewData["Title"] = "کشنده‌های تخصیص داده شده";
}

<style>
    .assignment-index-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .assignment-index-compact .form-control,
    .assignment-index-compact .form-select,
    .assignment-index-compact .btn,
    .assignment-index-compact .table,
    .assignment-index-compact .badge {
        font-size: 0.82rem;
    }

    .assignment-index-compact .table > :not(caption) > * > * {
        padding: 0.45rem 0.55rem;
    }

    .assignment-index-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .assignment-index-compact .card-body {
        padding-top: 0.85rem;
    }

    .assignment-index-compact .pagination .page-link {
        padding: 0.22rem 0.48rem;
        font-size: 0.78rem;
    }

    .assignment-index-compact .small-muted {
        font-size: 0.78rem;
    }

    .assignment-index-compact .summary-box {
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 0.65rem 0.75rem;
        background: #f8f9fa;
        height: 100%;
    }

    .assignment-index-compact .summary-box small {
        font-size: 0.76rem;
    }

    .assignment-index-compact .summary-box .value {
        display: block;
        margin-top: 0.25rem;
        font-weight: 600;
        color: #495057;
    }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">داشبورد</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-controller="Havalehs" asp-action="Index">حواله‌ها</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-controller="Havalehs" asp-action="SubHavalehDetails" asp-route-id="@Model.SubHavalehId">زیرحواله</a>
                    </li>
                    <li class="breadcrumb-item active">کشنده‌ها</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid assignment-index-compact">
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success py-2 small">@TempData["Ok"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger py-2 small">@TempData["Error"]</div>
    }

    @if (TempData["Warning"] != null)
    {
        <div class="alert alert-warning py-2 small">@TempData["Warning"]</div>
    }

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">کشنده‌های تخصیص داده شده</h6>
                <small class="text-muted small-muted">مدیریت کشنده‌ها و رانندگان تخصیص داده‌شده به این زیرحواله</small>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Assign"
                   asp-route-subHavalehId="@Model.SubHavalehId"
                   class="btn btn-primary btn-sm px-3">
                    تخصیص کشنده جدید
                </a>

                <a asp-controller="Havalehs"
                   asp-action="SubHavalehDetails"
                   asp-route-id="@Model.SubHavalehId"
                   class="btn btn-secondary btn-sm px-3">
                    بازگشت
                </a>
            </div>
        </div>

        <div class="card-body">
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <div class="summary-box">
                        <small class="text-muted">شماره حواله</small>
                        <span class="value">@Model.HavalehNumber</span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="summary-box">
                        <small class="text-muted">عنوان زیرحواله</small>
                        <span class="value">@(Model.SubHavalehTitle ?? "-")</span>
                    </div>
                </div>
            </div>

            <form id="filterForm" method="get" class="row g-2 mb-3">
                <input type="hidden" name="subHavalehId" value="@Model.SubHavalehId" />

                <div class="col-md-5">
                    <label class="form-label">جستجو</label>
                    <input type="text"
                           name="search"
                           value="@Model.Search"
                           class="form-control form-control-sm"
                           placeholder="جستجوی پلاک کشنده یا نام راننده..." />
                </div>

                <div class="col-md-3">
                    <label class="form-label">وضعیت</label>
                    <select name="statusFilter" class="form-select form-select-sm">
                        <option value="">همه وضعیت‌ها</option>
                        <option value="Assigned" selected="@(Model.StatusFilter == "Assigned")">تخصیص داده شده</option>
                        <option value="ArrivedAtOrigin" selected="@(Model.StatusFilter == "ArrivedAtOrigin")">رسیده به مبدا</option>
                        <option value="Loaded" selected="@(Model.StatusFilter == "Loaded")">بارگیری شده</option>
                        <option value="InTransit" selected="@(Model.StatusFilter == "InTransit")">در راه</option>
                        <option value="ArrivedAtDestination" selected="@(Model.StatusFilter == "ArrivedAtDestination")">رسیده به مقصد</option>
                        <option value="Unloaded" selected="@(Model.StatusFilter == "Unloaded")">تخلیه شده</option>
                        <option value="Completed" selected="@(Model.StatusFilter == "Completed")">تکمیل شده</option>
                        <option value="CancellationRequested" selected="@(Model.StatusFilter == "CancellationRequested")">درخواست لغو</option>
                        <option value="Cancelled" selected="@(Model.StatusFilter == "Cancelled")">لغو شده</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">تعداد</label>
                    <select name="pageSize" class="form-select form-select-sm">
                        <option value="10" selected="@(Model.PageSize == 10)">10 رکورد</option>
                        <option value="20" selected="@(Model.PageSize == 20)">20 رکورد</option>
                        <option value="50" selected="@(Model.PageSize == 50)">50 رکورد</option>
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label d-block">&nbsp;</label>
                    <button type="submit" class="btn btn-info btn-sm w-100">فیلتر</button>
                </div>
            </form>

            <div id="tractorAssignmentsList">
                @await Html.PartialAsync("_TractorAssignmentsList", Model)
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("filterForm");

            form?.addEventListener("submit", function (e) {
                e.preventDefault();
                loadAssignments(1);
            });

            attachPaginationEvents();
        });

        function loadAssignments(page = 1) {
            const form = document.getElementById("filterForm");
            const formData = new FormData(form);

            let url = `/TractorAssignment/GetAssignmentsList?subHavalehId=${@Model.SubHavalehId}&page=${page}`;
            url += `&search=${encodeURIComponent(formData.get("search") || "")}`;
            url += `&statusFilter=${encodeURIComponent(formData.get("statusFilter") || "")}`;
            url += `&pageSize=${encodeURIComponent(formData.get("pageSize") || "10")}`;

            fetch(url)
                .then(response => response.text())
                .then(html => {
                    document.getElementById("tractorAssignmentsList").innerHTML = html;
                    attachPaginationEvents();
                })
                .catch(error => {
                    console.error("Error:", error);
                    document.getElementById("tractorAssignmentsList").innerHTML = `
                        <div class="alert alert-danger text-center py-2 small">
                            خطا در بارگذاری اطلاعات. لطفاً مجدداً تلاش کنید.
                        </div>`;
                });
        }

        function attachPaginationEvents() {
            document.querySelectorAll("#tractorAssignmentsList .page-link[data-page]").forEach(link => {
                link.addEventListener("click", function (e) {
                    e.preventDefault();

                    const page = this.getAttribute("data-page");
                    if (page && !isNaN(page)) {
                        loadAssignments(parseInt(page));
                    }
                });
            });
        }

        function refreshTractorAssignments() {
            loadAssignments(1);
        }
    </script>
}
