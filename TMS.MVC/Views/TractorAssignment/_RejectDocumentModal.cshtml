<div class="modal fade" id="rejectDocumentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title">رد مدرک</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"></button>
            </div>

            <div class="modal-body small">
                <label class="form-label">دلیل رد مدرک <span class="text-danger">*</span></label>
                <textarea id="rejectionNote"
                          class="form-control form-control-sm"
                          rows="3"
                          required
                          placeholder="لطفاً دلیل رد مدرک را وارد کنید..."></textarea>
                <small class="text-muted d-block mt-1">این توضیح برای پیگیری وضعیت مدرک ذخیره می‌شود.</small>
            </div>

            <div class="modal-footer py-2 gap-2">
                <button type="button" class="btn btn-danger btn-sm px-3" onclick="submitRejectDocument()">ثبت رد</button>
                <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">انصراف</button>
            </div>
        </div>
    </div>
</div>
