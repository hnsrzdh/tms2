@model TMS.MVC.ViewModels.TractorWalletWithdrawalCreateVm

@{
    ViewData["Title"] = "درخواست برداشت از کیف پول کشنده";
}

<style>
    .withdrawal-create-compact .form-label { margin-bottom: .25rem; font-size: .82rem; }
    .withdrawal-create-compact .form-control,
    .withdrawal-create-compact .form-select,
    .withdrawal-create-compact .btn,
    .withdrawal-create-compact .badge { font-size: .82rem; }
    .withdrawal-create-compact .card-header { padding-top: .65rem; padding-bottom: .65rem; }
    .withdrawal-create-compact .card-body { padding-top: .85rem; }
    .withdrawal-create-compact .small-muted { font-size: .78rem; }
    .withdrawal-create-compact span.text-danger { font-size: .75rem; }
    .withdrawal-create-compact .summary-box { border: 1px solid #e5e7eb; border-radius: .75rem; padding: .7rem .8rem; background: #f8f9fa; height: 100%; }
    .withdrawal-create-compact .summary-box small { display: block; color: #6c757d; font-size: .76rem; margin-bottom: .2rem; }
    .withdrawal-create-compact .summary-box .value { display: block; font-weight: 700; color: #343a40; }
    .withdrawal-create-compact .wallet-box { border-color: rgba(25,135,84,.25); background: rgba(25,135,84,.06); }
    .withdrawal-create-compact .wallet-box .value { color: #198754; font-size: 1.05rem; }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12"><h4>@ViewData["Title"]</h4></div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Tractors" asp-action="Index">کشنده‌ها</a></li>
                    <li class="breadcrumb-item"><a asp-controller="Tractors" asp-action="Details" asp-route-id="@Model.TractorId">جزئیات کشنده</a></li>
                    <li class="breadcrumb-item active">درخواست برداشت</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid withdrawal-create-compact">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">ثبت درخواست برداشت از کیف پول کشنده</h6>
                <small class="text-muted small-muted">درخواست پس از ثبت در لیست بخش مالی برای پرداخت نمایش داده می‌شود.</small>
            </div>
            <a asp-controller="Tractors" asp-action="Details" asp-route-id="@Model.TractorId" class="btn btn-secondary btn-sm px-3">بازگشت</a>
        </div>

        <div class="card-body">
            <div class="row g-2 mb-3">
                <div class="col-md-4"><div class="summary-box"><small>کشنده</small><span class="value">@(Model.PolicePlateNumber ?? "-")</span></div></div>
                <div class="col-md-4"><div class="summary-box"><small>مالک</small><span class="value">@(Model.OwnerName ?? "-")</span></div></div>
                <div class="col-md-4"><div class="summary-box wallet-box"><small>موجودی کیف پول</small><span class="value">@Model.WalletBalance.ToString("N0") ریال</span></div></div>
            </div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="TractorId" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="Amount" class="form-label"></label>
                        <div class="input-group input-group-sm">
                            <input asp-for="Amount" class="form-control form-control-sm" type="number" min="1" step="1" />
                            <span class="input-group-text">ریال</span>
                        </div>
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <div class="col-md-8">
                        <label asp-for="RequestNote" class="form-label"></label>
                        <textarea asp-for="RequestNote" class="form-control form-control-sm" rows="3" placeholder="توضیح اختیاری برای بخش مالی..."></textarea>
                        <span asp-validation-for="RequestNote" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-3 d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary btn-sm px-3">ثبت درخواست</button>
                    <a asp-controller="Tractors" asp-action="Details" asp-route-id="@Model.TractorId" class="btn btn-secondary btn-sm px-3">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>
