@model TMS.MVC.ViewModels.TractorBankAccountUpsertViewModel

@{
    ViewData["Title"] = "افزودن اطلاعات بانکی کشنده";
}

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item active">داشبورد</li>
                    <li class="breadcrumb-item">کشنده‌ها</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="AddBankAccount" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="TractorId" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-4">
                        <label asp-for="AccountOwnerName" class="form-label"></label>
                        <input asp-for="AccountOwnerName" class="form-control" />
                        <span asp-validation-for="AccountOwnerName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="BankName" class="form-label"></label>
                        <input asp-for="BankName" class="form-control" />
                        <span asp-validation-for="BankName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 d-flex align-items-center">
                        <div class="form-check mt-4">
                            <input asp-for="IsDefault" class="form-check-input" />
                            <label asp-for="IsDefault" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="AccountNumber" class="form-label"></label>
                        <input asp-for="AccountNumber" class="form-control" />
                        <span asp-validation-for="AccountNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="CardNumber" class="form-label"></label>
                        <input asp-for="CardNumber" class="form-control" />
                        <span asp-validation-for="CardNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="ShebaNumber" class="form-label"></label>
                        <input asp-for="ShebaNumber" class="form-control" />
                        <span asp-validation-for="ShebaNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">ذخیره</button>
                    <a asp-action="Details" asp-route-id="@Model.TractorId" class="btn btn-secondary">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>
