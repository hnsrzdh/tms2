@model TMS.MVC.ViewModels.TractorContactUpsertViewModel

@{
    ViewData["Title"] = "افزودن راه ارتباطی کشنده";
}

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item active">داشبورد</li>
                    <li class="breadcrumb-item">کشنده‌ها</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    <div class="card shadow-sm">
        <div class="card-body">
            <form asp-action="AddContact" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="TractorId" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="ContactValue" class="form-label"></label>
                        <input asp-for="ContactValue" class="form-control" />
                        <span asp-validation-for="ContactValue" class="text-danger"></span>
                    </div>

                    <div class="row m-2">
                        <div class="col-md-2 mb-3 form-check mt-4 me-3">
                            <input asp-for="HasSms" class="form-check-input" />
                            <label asp-for="HasSms" class="form-check-label"></label>
                        </div>

                        <div class="col-md-2 mb-3 form-check mt-4 me-3">
                            <input asp-for="HasWhatsApp" class="form-check-input" />
                            <label asp-for="HasWhatsApp" class="form-check-label"></label>
                        </div>

                        <div class="col-md-2 mb-3 form-check mt-4 me-3">
                            <input asp-for="IsFax" class="form-check-input" />
                            <label asp-for="IsFax" class="form-check-label"></label>
                        </div>

                        <div class="col-md-2 mb-3 form-check mt-4 me-3">
                            <input asp-for="IsPhone" class="form-check-input" />
                            <label asp-for="IsPhone" class="form-check-label"></label>
                        </div>

                        <div class="col-md-2 mb-3 form-check mt-4 me-3">
                            <input asp-for="IsEmail" class="form-check-input" />
                            <label asp-for="IsEmail" class="form-check-label"></label>
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-success">ذخیره</button>
                    <a asp-action="Details" asp-route-id="@Model.TractorId" class="btn btn-secondary">بازگشت</a>
                </div>
            </form>
        </div>
    </div>
</div>
