@using System.Globalization
@model TMS.MVC.Models.Tractor

@{
    ViewData["Title"] = "مشخصات کامل کشنده";

    string ToJalali(DateTime? date)
    {
        if (!date.HasValue)
            return "-";

        var pc = new PersianCalendar();
        var d = date.Value;
        return $"{pc.GetYear(d):0000}/{pc.GetMonth(d):00}/{pc.GetDayOfMonth(d):00}";
    }

    var ownerName = Model.OwnerApplicationUser == null
        ? "-"
        : (
            !string.IsNullOrWhiteSpace(((Model.OwnerApplicationUser.FirstName ?? "") + " " + (Model.OwnerApplicationUser.LastName ?? "")).Trim())
                ? ((Model.OwnerApplicationUser.FirstName ?? "") + " " + (Model.OwnerApplicationUser.LastName ?? "")).Trim()
                : (Model.OwnerApplicationUser.Email ?? "-")
          );

    var statusText = Model.Status?.Trim() ?? "-";
    var statusClass = statusText == "فعال"
        ? "bg-success"
        : statusText == "غیرفعال"
            ? "bg-danger"
            : "bg-secondary";
}

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item active">داشبورد</li>
                    <li class="breadcrumb-item">کشنده‌ها</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid">
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success">@TempData["Ok"]</div>
    }

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4>اطلاعات کلی</h4>
            <div class="d-flex gap-2 mt-2">
                <a asp-action="Index" class="btn btn-secondary">بازگشت</a>
            </div>
        </div>
        <div class="card-body row">
            <div class="col-md-4 mb-2"><strong>پلاک انتظامی:</strong> @Model.PolicePlateNumber</div>
            <div class="col-md-4 mb-2"><strong>مالک:</strong> @ownerName</div>
            <div class="col-md-4 mb-2">
                <strong>وضعیت:</strong>
                <span class="badge rounded-pill @statusClass px-3 py-2">@statusText</span>
            </div>

            <div class="col-md-4 mb-2"><strong>شناسه ملی:</strong> @(string.IsNullOrWhiteSpace(Model.NationalId) ? "-" : Model.NationalId)</div>
            <div class="col-md-4 mb-2"><strong>شماره هوشمند:</strong> @(string.IsNullOrWhiteSpace(Model.TractorSmartCardNumber) ? "-" : Model.TractorSmartCardNumber)</div>
            <div class="col-md-4 mb-2"><strong>شماره پرونده:</strong> @(string.IsNullOrWhiteSpace(Model.FileNumber) ? "-" : Model.FileNumber)</div>

            <div class="col-md-4 mb-2"><strong>شناسه کشنده:</strong> @(string.IsNullOrWhiteSpace(Model.TractorIdentifier) ? "-" : Model.TractorIdentifier)</div>
            <div class="col-md-4 mb-2"><strong>حداکثر ظرفیت:</strong> @(Model.MaxLoadCapacity.HasValue ? string.Format("{0:N0}", Model.MaxLoadCapacity) : "-")</div>
            <div class="col-md-4 mb-2"><strong>معاینه فنی:</strong> @ToJalali(Model.TechnicalInspectionExpireDate)</div>

            <div class="col-md-4 mb-2"><strong>بیمه ثالث:</strong> @ToJalali(Model.ThirdPartyInsuranceExpireDate)</div>
            <div class="col-md-4 mb-2"><strong>سال تولید:</strong> @(Model.ProductionYear?.ToString() ?? "-")</div>
            <div class="col-md-4 mb-2"><strong>تعداد محور:</strong> @(Model.AxleCount?.ToString() ?? "-")</div>

            <div class="col-md-4 mb-2"><strong>سیستم:</strong> @(string.IsNullOrWhiteSpace(Model.SystemName) ? "-" : Model.SystemName)</div>
            <div class="col-md-4 mb-2"><strong>نوع کشنده:</strong> @(string.IsNullOrWhiteSpace(Model.TractorType) ? "-" : Model.TractorType)</div>
            <div class="col-md-4 mb-2"><strong>پلاک ترانزیت:</strong> @(string.IsNullOrWhiteSpace(Model.TransitPlateNumber) ? "-" : Model.TransitPlateNumber)</div>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4>اطلاعات بانکی</h4>
            <a asp-action="AddBankAccount" asp-route-tractorId="@Model.Id" class="btn btn-primary">افزودن</a>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>نام صاحب حساب</th>
                        <th>نام بانک</th>
                        <th>شماره حساب</th>
                        <th>شماره کارت</th>
                        <th>شماره شبا</th>
                        <th>پیش فرض</th>
                        <th>توضیحات</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.BankAccounts.Any())
                    {
                        @foreach (var item in Model.BankAccounts.OrderByDescending(x => x.IsDefault).ThenBy(x => x.Id))
                        {
                            <tr>
                                <td>@(string.IsNullOrWhiteSpace(item.AccountOwnerName) ? "-" : item.AccountOwnerName)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.BankName) ? "-" : item.BankName)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.AccountNumber) ? "-" : item.AccountNumber)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.CardNumber) ? "-" : item.CardNumber)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.ShebaNumber) ? "-" : item.ShebaNumber)</td>
                                <td class="text-center">
                                    @if (item.IsDefault)
                                    {
                                        <span class="text-success fw-bold fs-5">✓</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </td>
                                <td>@(string.IsNullOrWhiteSpace(item.Description) ? "-" : item.Description)</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="EditBankAccount" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                        <form asp-action="DeleteBankAccount" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="tractorId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4">موردی ثبت نشده است.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4>شماره تماس‌ها</h4>
            <a asp-action="AddContact" asp-route-tractorId="@Model.Id" class="btn btn-primary">افزودن</a>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>عنوان</th>
                        <th>راه ارتباطی</th>
                        <th>پیامک</th>
                        <th>واتساپ</th>
                        <th>فکس</th>
                        <th>تلفن</th>
                        <th>ایمیل</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Contacts.Any())
                    {
                        @foreach (var item in Model.Contacts.OrderBy(x => x.Id))
                        {
                            <tr>
                                <td>@item.Title</td>
                                <td>@item.ContactValue</td>
                                <td>@(item.HasSms ? "بله" : "-")</td>
                                <td>@(item.HasWhatsApp ? "بله" : "-")</td>
                                <td>@(item.IsFax ? "بله" : "-")</td>
                                <td>@(item.IsPhone ? "بله" : "-")</td>
                                <td>@(item.IsEmail ? "بله" : "-")</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="EditContact" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                        <form asp-action="DeleteContact" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="tractorId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4">موردی ثبت نشده است.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h4>آدرس‌ها</h4>
            <a asp-action="AddAddress" asp-route-tractorId="@Model.Id" class="btn btn-primary">افزودن</a>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-bordered table-striped">
                <thead>
                    <tr>
                        <th>عنوان</th>
                        <th>آدرس</th>
                        <th>عملیات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Addresses.Any())
                    {
                        @foreach (var item in Model.Addresses.OrderBy(x => x.Id))
                        {
                            <tr>
                                <td>@(string.IsNullOrWhiteSpace(item.Title) ? "-" : item.Title)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.AddressText) ? "-" : item.AddressText)</td>
                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-action="EditAddress" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">ویرایش</a>
                                        <form asp-action="DeleteAddress" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input type="hidden" name="tractorId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger">حذف</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4">موردی ثبت نشده است.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>