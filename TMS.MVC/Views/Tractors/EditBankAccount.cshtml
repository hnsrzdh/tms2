@model TMS.MVC.ViewModels.TractorBankAccountUpsertViewModel

@{
    ViewData["Title"] = "ویرایش اطلاعات بانکی کشنده";
}

<style>
    .tractor-compact .form-label { margin-bottom: 0.25rem; font-size: 0.82rem; }
    .tractor-compact .form-control,
    .tractor-compact .form-select,
    .tractor-compact .btn,
    .tractor-compact .table,
    .tractor-compact .badge,
    .tractor-compact .form-check-label,
    .tractor-compact .form-text { font-size: 0.82rem; }
    .tractor-compact .table > :not(caption) > * > * { padding: 0.45rem 0.55rem; }
    .tractor-compact .card-header { padding-top: 0.65rem; padding-bottom: 0.65rem; }
    .tractor-compact .card-body { padding-top: 0.85rem; }
    .tractor-compact .pagination .page-link { padding: 0.22rem 0.48rem; font-size: 0.78rem; }
    .tractor-compact .small-muted { font-size: 0.78rem; }
    .tractor-compact .field-validation-valid,
    .tractor-compact .field-validation-error { font-size: 0.75rem; }
    .tractor-compact .form-check { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0; }
    .tractor-compact .form-check-input { margin-top: 0; }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">داشبورد</a></li>
                    <li class="breadcrumb-item"><a asp-action="Index">کشنده‌ها</a></li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid tractor-compact">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">@ViewData["Title"]</h6>
                <small class="text-muted small-muted">ویرایش اطلاعات بانکی کشنده</small>
            </div>
        </div>

        <div class="card-body">
            <form asp-action="EditBankAccount" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="TractorId" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="row g-2">
                    <div class="col-md-4">
                        <label asp-for="AccountOwnerName" class="form-label"></label>
                        <input asp-for="AccountOwnerName" class="form-control form-control-sm" />
                        <span asp-validation-for="AccountOwnerName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="BankName" class="form-label"></label>
                        <input asp-for="BankName" class="form-control form-control-sm" />
                        <span asp-validation-for="BankName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 d-flex align-items-center">
                        <div class="form-check mt-4">
                            <input asp-for="IsDefault" class="form-check-input" />
                            <label asp-for="IsDefault" class="form-check-label"></label>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="AccountNumber" class="form-label"></label>
                        <input asp-for="AccountNumber" class="form-control form-control-sm" />
                        <span asp-validation-for="AccountNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="CardNumber" class="form-label"></label>
                        <input asp-for="CardNumber" class="form-control form-control-sm" />
                        <span asp-validation-for="CardNumber" class="text-danger"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="ShebaNumber" class="form-label"></label>
                        <input asp-for="ShebaNumber" class="form-control form-control-sm" />
                        <span asp-validation-for="ShebaNumber" class="text-danger"></span>
                    </div>


                    <div class="col-md-12">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control form-control-sm" rows="4"></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-3">
                    <button type="submit" class="btn btn-primary btn-sm">ذخیره تغییرات</button>
                    <a asp-action="Details" asp-route-id="@Model.TractorId" class="btn btn-secondary btn-sm">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>

