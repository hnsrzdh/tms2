@using TMS.MVC.ViewModels
@model TransportAgreementUpsertViewModel

@{
    ViewData["Title"] = "ثبت تفاهم‌نامه حمل";
}

<style>
    .transport-agreement-form-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .transport-agreement-form-compact .form-control,
    .transport-agreement-form-compact .form-select,
    .transport-agreement-form-compact .btn,
    .transport-agreement-form-compact .table,
    .transport-agreement-form-compact .badge {
        font-size: 0.82rem;
    }

    .transport-agreement-form-compact .table > :not(caption) > * > * {
        padding: 0.45rem 0.55rem;
    }

    .transport-agreement-form-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .transport-agreement-form-compact .card-body {
        padding-top: 0.85rem;
    }

    .transport-agreement-form-compact .field-validation-valid,
    .transport-agreement-form-compact .field-validation-error {
        font-size: 0.75rem;
    }

    .transport-agreement-form-compact .small-muted {
        font-size: 0.78rem;
    }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">داشبورد</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-action="Index">تفاهم‌نامه‌های حمل</a>
                    </li>
                    <li class="breadcrumb-item active">ثبت تفاهم‌نامه</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid transport-agreement-form-compact">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">ثبت تفاهم‌نامه حمل</h6>
                <small class="text-muted small-muted">ثبت اطلاعات صاحب کالا، مسیر، محصول، مقدار و وضعیت تفاهم‌نامه</small>
            </div>
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post" id="agreementForm">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <label asp-for="Title" class="form-label"></label>
                        <input asp-for="Title" class="form-control form-control-sm" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CargoOwnerName" class="form-label"></label>
                        <input asp-for="CargoOwnerName" class="form-control form-control-sm" />
                        <span asp-validation-for="CargoOwnerName" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Origin" class="form-label"></label>
                        <div class="input-group input-group-sm">
                            <input asp-for="Origin" class="form-control" readonly />
                            <button type="button"
                                    class="btn btn-outline-secondary js-open-city-modal"
                                    data-target-input="Origin"
                                    data-modal-title="انتخاب شهر مبدا">
                                انتخاب
                            </button>
                        </div>
                        <span asp-validation-for="Origin" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Destination" class="form-label"></label>
                        <div class="input-group input-group-sm">
                            <input asp-for="Destination" class="form-control" readonly />
                            <button type="button"
                                    class="btn btn-outline-secondary js-open-city-modal"
                                    data-target-input="Destination"
                                    data-modal-title="انتخاب شهر مقصد">
                                انتخاب
                            </button>
                        </div>
                        <span asp-validation-for="Destination" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ProductName" class="form-label"></label>
                        <div class="input-group input-group-sm">
                            <input asp-for="ProductName" class="form-control" readonly />
                            <button type="button"
                                    class="btn btn-outline-secondary js-open-product-modal"
                                    data-target-input="ProductName"
                                    data-modal-title="انتخاب محصول">
                                انتخاب
                            </button>
                        </div>
                        <span asp-validation-for="ProductName" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Amount" class="form-label"></label>
                        <input asp-for="Amount" class="form-control form-control-sm js-amount-input" autocomplete="off" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Unit" class="form-label"></label>
                        <select asp-for="Unit" class="form-select form-select-sm">
                            <option value="">انتخاب کنید</option>
                            <option value="لیتر">لیتر</option>
                            <option value="کیلوگرم">کیلوگرم</option>
                        </select>
                        <span asp-validation-for="Unit" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Status" class="form-label"></label>
                        <input asp-for="Status" class="form-control form-control-sm" />
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>
                </div>

                <hr class="my-3" />

                <div class="d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary btn-sm px-3">ذخیره</button>
                    <a asp-action="Index" class="btn btn-secondary btn-sm px-3">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="cityPickerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="cityPickerTitle">انتخاب شهر</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"></button>
            </div>
            <div class="modal-body small">
                <div class="mb-3">
                    <input type="text" id="citySearchInput" class="form-control form-control-sm" placeholder="جستجوی شهر..." />
                </div>

                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle">
                        <thead>
                            <tr>
                                <th>کشور</th>
                                <th>استان</th>
                                <th>شهر</th>
                                <th style="width:100px;">انتخاب</th>
                            </tr>
                        </thead>
                        <tbody id="citySearchResults">
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">برای جستجو، عبارتی وارد کنید.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="productPickerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h6 class="modal-title" id="productPickerTitle">انتخاب محصول</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"></button>
            </div>
            <div class="modal-body small">
                <div class="mb-3">
                    <input type="text" id="productSearchInput" class="form-control form-control-sm" placeholder="جستجوی محصول..." />
                </div>

                <div class="table-responsive">
                    <table class="table table-hover table-sm align-middle">
                        <thead>
                            <tr>
                                <th>نام محصول</th>
                                <th style="width:100px;">انتخاب</th>
                            </tr>
                        </thead>
                        <tbody id="productSearchResults">
                            <tr>
                                <td colspan="2" class="text-center text-muted py-3">برای جستجو، عبارتی وارد کنید.</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            let currentTargetInputId = null;

            const cityModalEl = document.getElementById("cityPickerModal");
            const cityModal = new bootstrap.Modal(cityModalEl);
            const cityTitle = document.getElementById("cityPickerTitle");
            const citySearchInput = document.getElementById("citySearchInput");
            const citySearchResults = document.getElementById("citySearchResults");

            const productModalEl = document.getElementById("productPickerModal");
            const productModal = new bootstrap.Modal(productModalEl);
            const productTitle = document.getElementById("productPickerTitle");
            const productSearchInput = document.getElementById("productSearchInput");
            const productSearchResults = document.getElementById("productSearchResults");

            document.querySelectorAll(".js-open-city-modal").forEach(btn => {
                btn.addEventListener("click", function () {
                    currentTargetInputId = this.dataset.targetInput;
                    cityTitle.textContent = this.dataset.modalTitle || "انتخاب شهر";
                    citySearchInput.value = "";
                    citySearchResults.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">برای جستجو، عبارتی وارد کنید.</td></tr>';
                    cityModal.show();
                    setTimeout(() => citySearchInput.focus(), 300);
                });
            });

            document.querySelectorAll(".js-open-product-modal").forEach(btn => {
                btn.addEventListener("click", function () {
                    currentTargetInputId = this.dataset.targetInput;
                    productTitle.textContent = this.dataset.modalTitle || "انتخاب محصول";
                    productSearchInput.value = "";
                    productSearchResults.innerHTML = '<tr><td colspan="2" class="text-center text-muted py-3">برای جستجو، عبارتی وارد کنید.</td></tr>';
                    productModal.show();
                    setTimeout(() => productSearchInput.focus(), 300);
                });
            });

            let citySearchTimeout;
            citySearchInput.addEventListener("input", function () {
                clearTimeout(citySearchTimeout);
                const term = this.value.trim();

                citySearchTimeout = setTimeout(() => {
                    if (!term) {
                        citySearchResults.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">برای جستجو، عبارتی وارد کنید.</td></tr>';
                        return;
                    }

                    fetch(`/TransportAgreements/SearchCities?term=${encodeURIComponent(term)}`)
                        .then(r => r.json())
                        .then(data => {
                            if (!data || data.length === 0) {
                                citySearchResults.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">موردی یافت نشد.</td></tr>';
                                return;
                            }

                            citySearchResults.innerHTML = data.map(x => `
                                <tr>
                                    <td>${x.countryName ?? ""}</td>
                                    <td>${x.provinceName ?? ""}</td>
                                    <td>${x.name ?? ""}</td>
                                    <td>
                                        <button type="button" class="btn btn-primary btn-sm js-select-city" data-name="${x.name}">
                                            انتخاب
                                        </button>
                                    </td>
                                </tr>
                            `).join("");

                            document.querySelectorAll(".js-select-city").forEach(btn => {
                                btn.addEventListener("click", function () {
                                    const name = this.dataset.name;
                                    const input = document.getElementById(currentTargetInputId);
                                    if (input) input.value = name;
                                    cityModal.hide();
                                });
                            });
                        });
                }, 300);
            });

            let productSearchTimeout;
            productSearchInput.addEventListener("input", function () {
                clearTimeout(productSearchTimeout);
                const term = this.value.trim();

                productSearchTimeout = setTimeout(() => {
                    if (!term) {
                        productSearchResults.innerHTML = '<tr><td colspan="2" class="text-center text-muted py-3">برای جستجو، عبارتی وارد کنید.</td></tr>';
                        return;
                    }

                    fetch(`/TransportAgreements/SearchProducts?term=${encodeURIComponent(term)}`)
                        .then(r => r.json())
                        .then(data => {
                            if (!data || data.length === 0) {
                                productSearchResults.innerHTML = '<tr><td colspan="2" class="text-center text-muted py-3">موردی یافت نشد.</td></tr>';
                                return;
                            }

                            productSearchResults.innerHTML = data.map(x => `
                                <tr>
                                    <td>${x.name ?? ""}</td>
                                    <td>
                                        <button type="button" class="btn btn-primary btn-sm js-select-product" data-name="${x.name}">
                                            انتخاب
                                        </button>
                                    </td>
                                </tr>
                            `).join("");

                            document.querySelectorAll(".js-select-product").forEach(btn => {
                                btn.addEventListener("click", function () {
                                    const name = this.dataset.name;
                                    const input = document.getElementById(currentTargetInputId);
                                    if (input) input.value = name;
                                    productModal.hide();
                                });
                            });
                        });
                }, 300);
            });

            document.querySelectorAll(".js-amount-input").forEach(input => {
                input.addEventListener("input", function () {
                    let value = this.value.replace(/,/g, "").replace(/[^\d.]/g, "");
                    if (!value) {
                        this.value = "";
                        return;
                    }

                    const parts = value.split(".");
                    parts[0] = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, ",");

                    this.value = parts.length > 1
                        ? parts[0] + "." + parts[1]
                        : parts[0];
                });
            });

            document.getElementById("agreementForm")?.addEventListener("submit", function () {
                document.querySelectorAll(".js-amount-input").forEach(input => {
                    input.value = input.value.replace(/,/g, "");
                });
            });
        });
    </script>
}
