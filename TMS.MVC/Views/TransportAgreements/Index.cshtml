@using TMS.MVC.ViewModels
@model TransportAgreementIndexViewModel

@{
    ViewData["Title"] = "مدیریت تفاهم‌نامه‌های حمل";
}

<style>
    .transport-agreement-index-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .transport-agreement-index-compact .form-control,
    .transport-agreement-index-compact .form-select,
    .transport-agreement-index-compact .btn,
    .transport-agreement-index-compact .table,
    .transport-agreement-index-compact .badge {
        font-size: 0.82rem;
    }

    .transport-agreement-index-compact .table > :not(caption) > * > * {
        padding: 0.45rem 0.55rem;
    }

    .transport-agreement-index-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .transport-agreement-index-compact .card-body {
        padding-top: 0.85rem;
    }

    .transport-agreement-index-compact .pagination .page-link {
        padding: 0.22rem 0.48rem;
        font-size: 0.78rem;
    }

    .transport-agreement-index-compact .small-muted {
        font-size: 0.78rem;
    }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>
            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">داشبورد</a>
                    </li>
                    <li class="breadcrumb-item active">تفاهم‌نامه‌های حمل</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid transport-agreement-index-compact">
    @if (TempData["Ok"] != null)
    {
        <div class="alert alert-success py-2 small">@TempData["Ok"]</div>
    }

    @if (TempData["Err"] != null)
    {
        <div class="alert alert-danger py-2 small">@TempData["Err"]</div>
    }

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">تفاهم‌نامه‌های حمل</h6>
                <small class="text-muted small-muted">مدیریت تفاهم‌نامه‌ها، مبدا، مقصد، محصول، مقدار و وضعیت</small>
            </div>

            <div class="d-flex gap-2">
                <a asp-action="Create" class="btn btn-primary btn-sm px-3">
                    ثبت تفاهم‌نامه جدید
                </a>
            </div>
        </div>

        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-2 mb-3">
                <div class="col-md-9">
                    <label class="form-label">جستجو</label>
                    <input type="text"
                           name="search"
                           value="@Model.Search"
                           class="form-control form-control-sm"
                           placeholder="جستجو بر اساس عنوان، صاحب کالا، مبدا، مقصد، محصول یا وضعیت" />
                </div>

                <div class="col-md-2">
                    <label class="form-label">تعداد</label>
                    <select name="pageSize" class="form-select form-select-sm">
                        <option value="10" selected="@(Model.PageSize == 10)">10 رکورد</option>
                        <option value="20" selected="@(Model.PageSize == 20)">20 رکورد</option>
                        <option value="50" selected="@(Model.PageSize == 50)">50 رکورد</option>
                    </select>
                </div>

                <div class="col-md-1">
                    <label class="form-label d-block">&nbsp;</label>
                    <button type="submit" class="btn btn-info btn-sm w-100">
                        فیلتر
                    </button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover table-sm align-middle">
                    <thead>
                        <tr>
                            <th style="width:55px;">#</th>
                            <th>عنوان</th>
                            <th>صاحب کالا</th>
                            <th>مبدا</th>
                            <th>مقصد</th>
                            <th>محصول</th>
                            <th>مقدار</th>
                            <th>وضعیت</th>
                            <th style="width:145px;">عملیات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Items.Any())
                        {
                            var rowNo = Model.RowNumberStart;
                            foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@rowNo</td>
                                    <td>@item.Title</td>
                                    <td>@item.CargoOwnerName</td>
                                    <td>@item.Origin</td>
                                    <td>@item.Destination</td>
                                    <td>@item.ProductName</td>
                                    <td>@string.Format("{0:N0}", item.Amount) @item.Unit</td>
                                    <td>
                                        <span class="badge bg-info text-dark">@item.Status</span>
                                    </td>
                                    <td>
                                        <div>
                                            <a asp-action="Edit"
                                               asp-route-id="@item.Id"
                                               class="btn btn-outline-primary btn-sm">
                                                ویرایش
                                            </a>

                                            <button type="button"
                                                    class="btn btn-outline-danger btn-sm js-delete-btn"
                                                    data-id="@item.Id"
                                                    data-title="@item.Title">
                                                حذف
                                            </button>
                                        </div>
                                    </td>
                                </tr>

                                rowNo++;
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="9" class="text-center text-muted py-4">
                                    موردی یافت نشد.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-2">
                    <div class="text-muted small">
                        صفحه @Model.Page از @Model.TotalPages - تعداد کل: @Model.TotalItems
                    </div>

                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-primary">
                            <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="1"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-search="@Model.Search">
                                    اول
                                </a>
                            </li>

                            <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(Model.Page - 1)"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-search="@Model.Search">
                                    قبلی
                                </a>
                            </li>

                            @{
                                var startPage = Math.Max(1, Model.Page - 2);
                                var endPage = Math.Min(Model.TotalPages, Model.Page + 2);
                            }

                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == Model.Page ? "active" : "")">
                                    <a class="page-link"
                                       asp-action="Index"
                                       asp-route-page="@i"
                                       asp-route-pageSize="@Model.PageSize"
                                       asp-route-search="@Model.Search">
                                        @i
                                    </a>
                                </li>
                            }

                            <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@(Model.Page + 1)"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-search="@Model.Search">
                                    بعدی
                                </a>
                            </li>

                            <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@Model.TotalPages"
                                   asp-route-pageSize="@Model.PageSize"
                                   asp-route-search="@Model.Search">
                                    آخر
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>

<div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <form method="post" asp-action="Delete">
                @Html.AntiForgeryToken()

                <div class="modal-header py-2">
                    <h6 class="modal-title">تایید حذف</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="بستن"></button>
                </div>

                <div class="modal-body small">
                    <input type="hidden" id="deleteId" name="id" />
                    <input type="hidden" name="page" value="@Model.Page" />
                    <input type="hidden" name="pageSize" value="@Model.PageSize" />
                    <input type="hidden" name="search" value="@Model.Search" />

                    <p id="deleteText" class="mb-0"></p>
                </div>

                <div class="modal-footer py-2 gap-2">
                    <button type="submit" class="btn btn-danger btn-sm px-3">حذف</button>
                    <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">انصراف</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const modalEl = document.getElementById("deleteModal");
            const modal = new bootstrap.Modal(modalEl);

            const deleteIdInput = document.getElementById("deleteId");
            const deleteText = document.getElementById("deleteText");

            document.querySelectorAll(".js-delete-btn").forEach(btn => {
                btn.addEventListener("click", function () {
                    const id = this.dataset.id;
                    const title = this.dataset.title;

                    deleteIdInput.value = id;
                    deleteText.textContent = `آیا از حذف تفاهم‌نامه حمل "${title}" مطمئن هستید؟`;

                    modal.show();
                });
            });
        });
    </script>
}
