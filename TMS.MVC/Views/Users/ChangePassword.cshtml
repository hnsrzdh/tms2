@using TMS.MVC.Models.ViewModels
@model ChangePasswordViewModel

@{
    ViewData["Title"] = "تغییر رمز عبور";
}

<style>
    .user-form-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .user-form-compact .form-control,
    .user-form-compact .btn,
    .user-form-compact .form-text {
        font-size: 0.82rem;
    }

    .user-form-compact .field-validation-valid,
    .user-form-compact .field-validation-error {
        font-size: 0.75rem;
    }

    .user-form-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .user-form-compact .card-body {
        padding-top: 0.85rem;
    }

    .user-form-compact .small-muted {
        font-size: 0.78rem;
    }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>

            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">داشبورد</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-action="Index">کاربران</a>
                    </li>
                    <li class="breadcrumb-item active">تغییر رمز عبور</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid user-form-compact">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">تغییر رمز عبور</h6>
                <small class="text-muted small-muted">ثبت رمز عبور جدید برای کاربر انتخاب‌شده</small>
            </div>

        </div>

        <div class="card-body">
            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Email" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <label class="form-label">ایمیل / نام کاربری</label>
                        <input class="form-control form-control-sm" value="@Model.Email" readonly />
                    </div>

                    <div class="col-md-6"></div>

                    <div class="col-md-6">
                        <label asp-for="NewPassword" class="form-label"></label>
                        <input asp-for="NewPassword" class="form-control form-control-sm" />
                        <span asp-validation-for="NewPassword" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ConfirmNewPassword" class="form-label"></label>
                        <input asp-for="ConfirmNewPassword" class="form-control form-control-sm" />
                        <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                    </div>
                </div>

                <hr class="my-3" />

                <div class="d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary btn-sm px-3">ذخیره رمز جدید</button>
                    <a asp-action="Index" class="btn btn-secondary btn-sm px-3">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>