@using TMS.MVC.Models.ViewModels
@model UserEditViewModel

@{
    ViewData["Title"] = "ویرایش کاربر";
}

<style>
    .user-form-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .user-form-compact .form-control,
    .user-form-compact .form-select,
    .user-form-compact .btn,
    .user-form-compact .form-check-label,
    .user-form-compact .badge,
    .user-form-compact .form-text {
        font-size: 0.82rem;
    }

    .user-form-compact .field-validation-valid,
    .user-form-compact .field-validation-error {
        font-size: 0.75rem;
    }

    .user-form-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .user-form-compact .card-body {
        padding-top: 0.85rem;
    }

    .user-form-compact .small-muted {
        font-size: 0.78rem;
    }

    .user-form-compact .roles-box {
        border: 1px solid #e5e7eb;
        border-radius: 0.45rem;
        padding: 0.75rem;
        background: #fff;
    }

    .user-form-compact .form-check {
        min-height: 28px;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        margin-bottom: 0;
    }

    .user-form-compact .form-check-input {
        margin-top: 0;
    }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>

            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">داشبورد</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-action="Index">کاربران</a>
                    </li>
                    <li class="breadcrumb-item active">ویرایش کاربر</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid user-form-compact">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">ویرایش کاربر</h6>
                <small class="text-muted small-muted">ویرایش اطلاعات کاربر و نقش‌های دسترسی</small>
            </div>

        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                <div class="row g-2">
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label">ایمیل / نام کاربری</label>
                        <input asp-for="Email" class="form-control form-control-sm" readonly />
                        <span asp-validation-for="Email" class="text-danger"></span>
                        <div class="form-text">نام کاربری قابل تغییر نیست.</div>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="FirstName" class="form-label"></label>
                        <input asp-for="FirstName" class="form-control form-control-sm" />
                        <span asp-validation-for="FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="LastName" class="form-label"></label>
                        <input asp-for="LastName" class="form-control form-control-sm" />
                        <span asp-validation-for="LastName" class="text-danger"></span>
                    </div>

                    <div class="col-12 mt-2">
                        <label class="form-label">رول‌های کاربر</label>

                        <div class="roles-box">
                            <div class="row g-2">
                                @if (Model.AvailableRoles != null && Model.AvailableRoles.Any())
                                {
                                    for (int i = 0; i < Model.AvailableRoles.Count; i++)
                                    {
                                        var role = Model.AvailableRoles[i];
                                        var isBaseUserRole = role.Name == "User";

                                        <div class="col-md-4">
                                            <div class="form-check">
                                                @if (isBaseUserRole)
                                                {
                                                    <input type="hidden" name="SelectedRoles" value="@role.Name" />
                                                }

                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       name="SelectedRoles"
                                                       value="@role.Name"
                                                       id="role_@i"
                                                       @(isBaseUserRole || role.Selected ? "checked" : null)
                                                       @(isBaseUserRole ? "disabled" : null) />

                                                <label class="form-check-label" for="role_@i">
                                                    @role.Title
                                                    <span class="text-muted small">(@role.Name)</span>

                                                    @if (isBaseUserRole)
                                                    {
                                                        <span class="badge bg-secondary ms-1">اجباری</span>
                                                    }
                                                </label>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="col-12">
                                        <div class="text-muted small">رولی برای نمایش وجود ندارد.</div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-3" />

                <div class="d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-primary btn-sm px-3">ذخیره تغییرات</button>
                    <a asp-action="Index" class="btn btn-secondary btn-sm px-3">انصراف</a>
                </div>
            </form>
        </div>
    </div>
</div>