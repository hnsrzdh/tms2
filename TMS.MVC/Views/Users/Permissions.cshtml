@using TMS.MVC.Models.ViewModels
@model UserPermissionsEditViewModel

@{
    ViewData["Title"] = "مدیریت دسترسی‌های کاربر";
}

<style>
    .user-permissions-compact .form-label {
        margin-bottom: 0.25rem;
        font-size: 0.82rem;
    }

    .user-permissions-compact .form-control,
    .user-permissions-compact .form-select,
    .user-permissions-compact .btn,
    .user-permissions-compact .form-check-label,
    .user-permissions-compact .badge {
        font-size: 0.82rem;
    }

    .user-permissions-compact .card-header {
        padding-top: 0.65rem;
        padding-bottom: 0.65rem;
    }

    .user-permissions-compact .card-body {
        padding-top: 0.85rem;
    }

    .user-permissions-compact .small-muted {
        font-size: 0.78rem;
    }

    .user-permissions-compact .permission-card {
        border: 1px solid #e5e7eb;
        border-radius: 0.45rem;
        padding: 0.55rem 0.65rem;
        height: 100%;
        background: #fff;
    }

        .user-permissions-compact .permission-card .form-check {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            margin-bottom: 0;
        }

        .user-permissions-compact .permission-card .form-check-input {
            margin-top: 0;
        }

    .user-permissions-compact .permission-key {
        font-size: 0.74rem;
        direction: ltr;
        text-align: left;
    }

    .user-permissions-compact .category-card {
        margin-bottom: 0.75rem;
    }
</style>

<div class="container-fluid">
    <div class="page-title">
        <div class="row">
            <div class="col-sm-6 col-12">
                <h4>@ViewData["Title"]</h4>
            </div>

            <div class="col-sm-6 col-12">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a asp-controller="Home" asp-action="Index">داشبورد</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a asp-action="Index">کاربران</a>
                    </li>
                    <li class="breadcrumb-item active">دسترسی‌ها</li>
                </ol>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid user-permissions-compact">
    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div>
                <h6 class="mb-0">دسترسی‌های کاربر</h6>
                <small class="text-muted small-muted">
                    کاربر:
                    <strong>@Model.Email</strong>
                    @if (!string.IsNullOrWhiteSpace(Model.FullName))
                    {
                        <span>- @Model.FullName</span>
                    }
                </small>
            </div>

        </div>

        <div class="card-body">
            <form asp-action="Permissions" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="UserId" />
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="FullName" />

                @if (Model.Categories != null && Model.Categories.Any())
                {
                    for (int i = 0; i < Model.Categories.Count; i++)
                    {
                        <div class="card category-card">
                            <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <div>
                                    <h6 class="mb-0">@Model.Categories[i].Category</h6>
                                </div>

                                <div class="d-flex gap-2">
                                    <button type="button"
                                            class="btn btn-outline-success btn-sm px-3 js-check-category"
                                            data-index="@i">
                                        انتخاب همه
                                    </button>

                                    <button type="button"
                                            class="btn btn-outline-secondary btn-sm px-3 js-uncheck-category"
                                            data-index="@i">
                                        حذف انتخاب
                                    </button>
                                </div>
                            </div>

                            <div class="card-body">
                                <input type="hidden" asp-for="Categories[@i].Category" />

                                <div class="row g-2">
                                    @for (int j = 0; j < Model.Categories[i].Items.Count; j++)
                                    {
                                        <input type="hidden" asp-for="Categories[@i].Items[@j].PermissionDefinitionId" />
                                        <input type="hidden" asp-for="Categories[@i].Items[@j].Key" />
                                        <input type="hidden" asp-for="Categories[@i].Items[@j].Title" />

                                        <div class="col-md-4">
                                            <div class="permission-card">
                                                <div class="form-check">
                                                    <input asp-for="Categories[@i].Items[@j].Selected"
                                                           class="form-check-input permission-checkbox category-@i" />

                                                    <label asp-for="Categories[@i].Items[@j].Selected" class="form-check-label">
                                                        @Model.Categories[i].Items[j].Title
                                                    </label>
                                                </div>

                                                <div class="text-muted permission-key mt-1">
                                                    @Model.Categories[i].Items[j].Key
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }

                    <hr class="my-3" />

                    <div class="d-flex justify-content-end gap-2">
                        <button type="submit" class="btn btn-primary btn-sm px-3">
                            ذخیره دسترسی‌ها
                        </button>

                        <a asp-action="Index" class="btn btn-secondary btn-sm px-3">
                            انصراف
                        </a>
                    </div>
                }
                else
                {
                    <div class="alert alert-info py-2 small">
                        هیچ دسترسی‌ای برای نمایش تعریف نشده است.
                    </div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary btn-sm px-3">
                            بازگشت
                        </a>
                    </div>
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.querySelectorAll(".js-check-category").forEach(btn => {
                btn.addEventListener("click", function () {
                    const index = this.dataset.index;
                    document.querySelectorAll(".category-" + index).forEach(chk => chk.checked = true);
                });
            });

            document.querySelectorAll(".js-uncheck-category").forEach(btn => {
                btn.addEventListener("click", function () {
                    const index = this.dataset.index;
                    document.querySelectorAll(".category-" + index).forEach(chk => chk.checked = false);
                });
            });
        });
    </script>
}